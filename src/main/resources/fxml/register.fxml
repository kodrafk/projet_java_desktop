<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.projet.gui.RegisterController"
           prefWidth="1100" prefHeight="760">

    <Pane style="-fx-background-color:linear-gradient(to bottom right,#e8f5e9,#fffde7,#fce4ec);"/>
    <Circle radius="28" fill="#EF5350" opacity="0.6" StackPane.alignment="CENTER_LEFT" translateX="80" translateY="60"/>
    <Ellipse radiusX="22" radiusY="30" fill="#66BB6A" opacity="0.7" StackPane.alignment="TOP_RIGHT" translateX="-90" translateY="120"/>
    <Circle radius="16" fill="#7E57C2" opacity="0.5" StackPane.alignment="BOTTOM_LEFT" translateX="160" translateY="-120"/>

    <VBox StackPane.alignment="TOP_CENTER" maxWidth="Infinity">
        <!-- Navbar -->
        <HBox prefHeight="60" alignment="CENTER_LEFT"
              style="-fx-background-color:rgba(255,255,255,0.9);-fx-border-color:transparent transparent #E8EDE8 transparent;-fx-border-width:0 0 1 0;-fx-padding:0 40;">
            <Label text="🥗 NutriLife" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Hyperlink text="Already have an account? Login" onAction="#handleGoLogin"
                       style="-fx-font-size:13px;-fx-text-fill:#2E7D32;-fx-border-color:transparent;"/>
        </HBox>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                    style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;">
            <VBox alignment="TOP_CENTER" style="-fx-background-color:transparent;-fx-padding:32 0 60 0;">

                <Label text="Join Us Today"
                       style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                <Label text="Start your nutrition journey"
                       style="-fx-font-size:13px;-fx-text-fill:#6B7280;-fx-padding:6 0 20 0;"/>

                <VBox spacing="12" prefWidth="460" maxWidth="460"
                      style="-fx-background-color:white;-fx-background-radius:20;-fx-padding:28 36;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.10),24,0,0,6);">

                    <!-- Status / error banner -->
                    <Label fx:id="errorLabel" text="" wrapText="true" maxWidth="388"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-padding:8 12;
                                  -fx-background-radius:8;"/>

                    <!-- ── Quick sign-up options ── -->
                    <VBox spacing="8">
                        <Label text="Quick sign-up"
                               style="-fx-font-size:11px;-fx-text-fill:#94A3B8;-fx-font-weight:bold;"/>
                        <HBox spacing="10">
                            <!-- Google Sign Up -->
                            <Button text="🌐  Sign up with Google" onAction="#handleGoogleSignUp"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="42"
                                    style="-fx-background-color:#FFF7ED;-fx-text-fill:#EA580C;
                                           -fx-font-size:12px;-fx-font-weight:bold;
                                           -fx-background-radius:10;-fx-cursor:hand;
                                           -fx-border-color:#FED7AA;-fx-border-radius:10;
                                           -fx-border-width:1;"/>
                            <!-- Face ID Sign Up -->
                            <Button text="🎭  Sign up with Face ID" onAction="#handleFaceIdSignUp"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="42"
                                    style="-fx-background-color:#EFF6FF;-fx-text-fill:#1D4ED8;
                                           -fx-font-size:12px;-fx-font-weight:bold;
                                           -fx-background-radius:10;-fx-cursor:hand;
                                           -fx-border-color:#BFDBFE;-fx-border-radius:10;
                                           -fx-border-width:1;"/>
                        </HBox>
                    </VBox>

                    <!-- Divider -->
                    <HBox alignment="CENTER" spacing="10">
                        <Separator HBox.hgrow="ALWAYS"/>
                        <Label text="or fill in the form"
                               style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                        <Separator HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <!-- Name row -->
                    <HBox spacing="12">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="First Name *"
                                   style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                            <TextField fx:id="firstNameField" promptText="John"
                                       style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                              -fx-border-radius:10;-fx-background-radius:10;
                                              -fx-padding:9 12;-fx-font-size:13px;"/>
                            <Label fx:id="errFirstName" text=""
                                   style="-fx-text-fill:#DC2626;-fx-font-size:10px;"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Last Name *"
                                   style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                            <TextField fx:id="lastNameField" promptText="Doe"
                                       style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                              -fx-border-radius:10;-fx-background-radius:10;
                                              -fx-padding:9 12;-fx-font-size:13px;"/>
                            <Label fx:id="errLastName" text=""
                                   style="-fx-text-fill:#DC2626;-fx-font-size:10px;"/>
                        </VBox>
                    </HBox>

                    <!-- Email -->
                    <VBox spacing="4">
                        <Label text="Email *"
                               style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                        <TextField fx:id="emailField" promptText="your.email@example.com"
                                   style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                          -fx-border-radius:10;-fx-background-radius:10;
                                          -fx-padding:9 12;-fx-font-size:13px;"/>
                        <Label fx:id="errEmail" text=""
                               style="-fx-text-fill:#DC2626;-fx-font-size:10px;"/>
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="4">
                        <Label text="Password * (min 8 chars)"
                               style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                        <PasswordField fx:id="passwordField" promptText="At least 8 characters"
                                       style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                              -fx-border-radius:10;-fx-background-radius:10;
                                              -fx-padding:9 12;-fx-font-size:13px;"/>
                        <Label fx:id="errPassword" text=""
                               style="-fx-text-fill:#DC2626;-fx-font-size:10px;"/>
                    </VBox>

                    <!-- Confirm Password -->
                    <VBox spacing="4">
                        <Label text="Confirm Password *"
                               style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="Repeat your password"
                                       style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                              -fx-border-radius:10;-fx-background-radius:10;
                                              -fx-padding:9 12;-fx-font-size:13px;"/>
                        <Label fx:id="errConfirm" text=""
                               style="-fx-text-fill:#DC2626;-fx-font-size:10px;"/>
                    </VBox>

                    <!-- Birthday -->
                    <VBox spacing="4">
                        <Label text="Birthday * (must be 18+)"
                               style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                        <DatePicker fx:id="birthdayPicker" maxWidth="Infinity"
                                    style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                           -fx-border-radius:10;-fx-background-radius:10;"/>
                        <Label fx:id="errBirthday" text=""
                               style="-fx-text-fill:#DC2626;-fx-font-size:10px;"/>
                    </VBox>

                    <!-- Weight / Height -->
                    <HBox spacing="12">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Weight (kg) *"
                                   style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                            <TextField fx:id="weightField" promptText="70"
                                       style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                              -fx-border-radius:10;-fx-background-radius:10;
                                              -fx-padding:9 12;-fx-font-size:13px;"/>
                            <Label fx:id="errWeight" text=""
                                   style="-fx-text-fill:#DC2626;-fx-font-size:10px;"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Height (cm) *"
                                   style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                            <TextField fx:id="heightField" promptText="175"
                                       style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                              -fx-border-radius:10;-fx-background-radius:10;
                                              -fx-padding:9 12;-fx-font-size:13px;"/>
                            <Label fx:id="errHeight" text=""
                                   style="-fx-text-fill:#DC2626;-fx-font-size:10px;"/>
                        </VBox>
                    </HBox>

                    <!-- Captcha -->
                    <VBox spacing="4">
                        <Label fx:id="captchaLabel" text="What is ? + ??"
                               style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                        <TextField fx:id="captchaField" promptText="Answer"
                                   style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                          -fx-border-radius:10;-fx-background-radius:10;
                                          -fx-padding:9 12;-fx-font-size:13px;"/>
                        <Label fx:id="errCaptcha" text=""
                               style="-fx-text-fill:#DC2626;-fx-font-size:10px;"/>
                    </VBox>

                    <!-- Submit -->
                    <Button fx:id="registerButton" text="Create My Account" onAction="#handleRegister"
                            maxWidth="Infinity" prefHeight="46"
                            style="-fx-background-color:#2E7D32;-fx-text-fill:white;-fx-font-size:14px;
                                   -fx-font-weight:bold;-fx-background-radius:12;-fx-cursor:hand;
                                   -fx-border-color:transparent;"/>

                    <HBox alignment="CENTER" spacing="4">
                        <Label text="Already have an account?"
                               style="-fx-font-size:12px;-fx-text-fill:#6B7280;"/>
                        <Hyperlink text="Login" onAction="#handleGoLogin"
                                   style="-fx-font-size:12px;-fx-text-fill:#2E7D32;
                                          -fx-font-weight:bold;-fx-border-color:transparent;"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>
</StackPane>
