<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.projet.gui.RegisterController"
           prefWidth="1100" prefHeight="760">

    <!-- Gradient background -->
    <Pane style="-fx-background-color: linear-gradient(to bottom right, #e8f5e9, #fffde7, #fce4ec);"/>

    <!-- Colored decorative shapes -->
    <Circle radius="28" fill="#EF5350" opacity="0.75"
             StackPane.alignment="CENTER_LEFT" translateX="100" translateY="60"/>
    <Circle radius="8" fill="#66BB6A" opacity="0.9"
             StackPane.alignment="CENTER_LEFT" translateX="118" translateY="32"/>

    <Ellipse radiusX="22" radiusY="30" fill="#66BB6A" opacity="0.8"
             StackPane.alignment="TOP_RIGHT" translateX="-100" translateY="130"/>
    <Ellipse radiusX="10" radiusY="14" fill="#A5D6A7" opacity="0.9"
             StackPane.alignment="TOP_RIGHT" translateX="-100" translateY="130"/>

    <Ellipse radiusX="14" radiusY="26" fill="#FF7043" opacity="0.8"
             StackPane.alignment="BOTTOM_RIGHT" translateX="-120" translateY="-100"/>
    <Circle radius="6" fill="#66BB6A" opacity="0.9"
             StackPane.alignment="BOTTOM_RIGHT" translateX="-120" translateY="-126"/>

    <Ellipse radiusX="26" radiusY="20" fill="#FFEE58" opacity="0.85"
             StackPane.alignment="BOTTOM_LEFT" translateX="80" translateY="-60"/>

    <Circle radius="14" fill="#7E57C2" opacity="0.7"
             StackPane.alignment="TOP_LEFT" translateX="220" translateY="160"/>
    <Circle radius="10" fill="#9575CD" opacity="0.6"
             StackPane.alignment="TOP_LEFT" translateX="244" translateY="148"/>
    <Circle radius="10" fill="#9575CD" opacity="0.6"
             StackPane.alignment="TOP_LEFT" translateX="208" translateY="148"/>

    <Ellipse radiusX="16" radiusY="20" fill="#E53935" opacity="0.75"
             StackPane.alignment="BOTTOM_RIGHT" translateX="-260" translateY="-260"/>
    <Circle radius="5" fill="#66BB6A" opacity="0.9"
             StackPane.alignment="BOTTOM_RIGHT" translateX="-260" translateY="-280"/>

    <!-- Top nav bar -->
    <VBox StackPane.alignment="TOP_CENTER" maxWidth="Infinity">
        <HBox prefHeight="64" alignment="CENTER_LEFT"
              style="-fx-background-color: rgba(255,255,255,0.88); -fx-border-color: transparent transparent #E8EDE8 transparent; -fx-border-width: 0 0 1 0; -fx-padding: 0 40;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane prefWidth="36" prefHeight="36">
                    <Ellipse radiusX="18" radiusY="12" fill="#2E7D32"/>
                    <Ellipse radiusX="14" radiusY="8" fill="#4CAF50" translateY="-2"/>
                    <Circle radius="4" fill="#FF7043" translateX="-5" translateY="-4"/>
                    <Circle radius="3" fill="#FFEE58" translateX="4" translateY="-5"/>
                    <Circle radius="3" fill="#EF5350" translateX="0" translateY="-6"/>
                </StackPane>
                <Label text="Nutri Coach Pro"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a2e1a; -fx-font-family: Georgia;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="28" alignment="CENTER">
                <Label text="Home"       style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-cursor: hand;"/>
                <Label text="About"      style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-cursor: hand;"/>
                <Label text="My Kitchen" style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-cursor: hand;"/>
                <Label text="Events"     style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-cursor: hand;"/>
                <Label text="Wellness"   style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-cursor: hand;"/>
                <Label text="Blog"       style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-cursor: hand;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="12" alignment="CENTER">
                <Button text="Sign In" onAction="#handleGoLogin"
                        style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: transparent; -fx-padding: 8 16;"/>
                <Button text="Sign Up"
                        style="-fx-background-color: #F97316; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 22; -fx-cursor: hand; -fx-border-color: transparent;"/>
            </HBox>
        </HBox>

        <!-- Scrollable form -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                    VBox.vgrow="ALWAYS">
            <VBox alignment="TOP_CENTER" style="-fx-background-color: transparent; -fx-padding: 36 0 60 0;">

                <Label text="Join Us Today"
                       style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #1a2e1a; -fx-font-family: Georgia;"/>
                <Label text="Start your nutrition journey with us"
                       style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-padding: 6 0 28 0;"/>

                <!-- White card -->
                <VBox spacing="14" prefWidth="420" maxWidth="420"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 30 36; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 24, 0, 0, 6);">

                    <!-- First + Last name -->
                    <HBox spacing="14">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="First Name" style="-fx-font-size: 13px; -fx-text-fill: #1a2e1a; -fx-font-weight: bold;"/>
                            <TextField fx:id="fieldFirstName" promptText="John"
                                       style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                            <Label fx:id="errFirstName" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 10px;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Last Name" style="-fx-font-size: 13px; -fx-text-fill: #1a2e1a; -fx-font-weight: bold;"/>
                            <TextField fx:id="fieldLastName" promptText="Doe"
                                       style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                            <Label fx:id="errLastName" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 10px;"/>
                        </VBox>
                    </HBox>

                    <!-- Email -->
                    <VBox spacing="5">
                        <Label text="Email" style="-fx-font-size: 13px; -fx-text-fill: #1a2e1a; -fx-font-weight: bold;"/>
                        <TextField fx:id="fieldEmail" promptText="your.email@example.com"
                                   style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                        <Label fx:id="errEmail" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 10px;"/>
                    </VBox>

                    <!-- Phone -->
                    <VBox spacing="5">
                        <Label text="Phone Number" style="-fx-font-size: 13px; -fx-text-fill: #1a2e1a; -fx-font-weight: bold;"/>
                        <TextField fx:id="fieldPhone" promptText="+21650830876"
                                   style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                        <Label text="Include country code (e.g., +21650830876 for Tunisia)"
                               style="-fx-font-size: 10px; -fx-text-fill: #9CA3AF;"/>
                        <Label fx:id="errPhone" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 10px;"/>
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="5">
                        <Label text="Password" style="-fx-font-size: 13px; -fx-text-fill: #1a2e1a; -fx-font-weight: bold;"/>
                        <HBox spacing="0" alignment="CENTER_LEFT">
                            <PasswordField fx:id="fieldPassword" promptText="Enter a strong password"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10 0 0 10; -fx-background-radius: 10 0 0 10; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                            <TextField fx:id="fieldPasswordVisible" promptText="Enter a strong password"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10 0 0 10; -fx-background-radius: 10 0 0 10; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                            <Button fx:id="btnTogglePwd" text="👁" onAction="#handleTogglePassword"
                                    prefHeight="42" prefWidth="42"
                                    style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 0 10 10 0; -fx-background-radius: 0 10 10 0; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-width: 1 1 1 0;"/>
                        </HBox>
                        <Label fx:id="errPassword" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 10px;"/>
                    </VBox>

                    <!-- Confirm Password -->
                    <VBox spacing="5">
                        <Label text="Confirm Password" style="-fx-font-size: 13px; -fx-text-fill: #1a2e1a; -fx-font-weight: bold;"/>
                        <HBox spacing="0" alignment="CENTER_LEFT">
                            <PasswordField fx:id="fieldConfirmPassword" promptText="Repeat your password"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10 0 0 10; -fx-background-radius: 10 0 0 10; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                            <TextField fx:id="fieldConfirmVisible" promptText="Repeat your password"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10 0 0 10; -fx-background-radius: 10 0 0 10; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                            <Button fx:id="btnToggleConfirm" text="👁" onAction="#handleToggleConfirm"
                                    prefHeight="42" prefWidth="42"
                                    style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 0 10 10 0; -fx-background-radius: 0 10 10 0; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-width: 1 1 1 0;"/>
                        </HBox>
                        <Label fx:id="errConfirmPassword" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 10px;"/>
                    </VBox>

                    <!-- Birthday -->
                    <VBox spacing="5">
                        <Label text="Birthday (must be 18+)" style="-fx-font-size: 13px; -fx-text-fill: #1a2e1a; -fx-font-weight: bold;"/>
                        <HBox spacing="8">
                            <ComboBox fx:id="cbBirthDay" promptText="Day" prefWidth="80"
                                      style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px; -fx-cursor: hand;"/>
                            <ComboBox fx:id="cbBirthMonth" promptText="Month" prefWidth="130"
                                      style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px; -fx-cursor: hand;"/>
                            <ComboBox fx:id="cbBirthYear" promptText="Year" prefWidth="100"
                                      style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px; -fx-cursor: hand;"/>
                        </HBox>
                        <Label fx:id="errBirthday" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 10px;"/>
                    </VBox>

                    <!-- Weight / Height -->
                    <HBox spacing="14">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Weight (kg)" style="-fx-font-size: 13px; -fx-text-fill: #1a2e1a; -fx-font-weight: bold;"/>
                            <TextField fx:id="fieldWeight" promptText="70"
                                       style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                            <Label fx:id="errWeight" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 10px;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Height (cm)" style="-fx-font-size: 13px; -fx-text-fill: #1a2e1a; -fx-font-weight: bold;"/>
                            <TextField fx:id="fieldHeight" promptText="175"
                                       style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 12; -fx-font-size: 13px;"/>
                            <Label fx:id="errHeight" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 10px;"/>
                        </VBox>
                    </HBox>

                    <Label fx:id="errGeneral" text=""
                           style="-fx-text-fill: #DC2626; -fx-font-size: 11px; -fx-font-weight: bold;"/>

                    <!-- Submit -->
                    <Button fx:id="btnSubmit" text="Create My Account" onAction="#handleRegister"
                            maxWidth="Infinity" prefHeight="48"
                            style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: transparent;"/>

                    <!-- Sign in link -->
                    <HBox alignment="CENTER" spacing="4">
                        <Label text="Already have an account?"
                               style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
                        <Button text="Sign In" onAction="#handleGoLogin"
                                style="-fx-background-color: transparent; -fx-text-fill: #2E7D32; -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: transparent; -fx-padding: 0;"/>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>

</StackPane>
