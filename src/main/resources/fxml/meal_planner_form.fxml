<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.projet.controllers.MealPlannerFormController"
            style="-fx-background-color: #F8FAFC;">

    <VBox spacing="20" style="-fx-background-color: #F8FAFC;">
        <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

        <!-- TITRE -->
        <VBox alignment="CENTER" spacing="6"
              style="-fx-background-color: #1F4D3A;
                     -fx-background-radius: 16;
                     -fx-padding: 20;">
            <Label text="SMART ANTI-WASTE MEAL PLANNER"
                   style="-fx-text-fill: white;
                          -fx-font-size: 22px;
                          -fx-font-weight: bold;"/>
            <Label text="Optimized based on your stock and expiry dates"
                   style="-fx-text-fill: #a7d5c1;
                          -fx-font-size: 13px;"/>
        </VBox>

        <!-- FORM -->
        <VBox fx:id="vboxForm" spacing="16">

            <!-- PROFIL USER -->
            <VBox spacing="10"
                  style="-fx-background-color: white;
                         -fx-background-radius: 12;
                         -fx-padding: 18;
                         -fx-border-color: #E2E8F0;
                         -fx-border-radius: 12;">

                <Label text="Profile"
                       style="-fx-font-weight: bold;
                              -fx-font-size: 15px;
                              -fx-text-fill: #1E293B;"/>

                <HBox spacing="30">
                    <VBox spacing="4">
                        <Label text="Name"
                               style="-fx-text-fill: #64748B; -fx-font-size: 11px;"/>
                        <Label fx:id="labelNom" text="—"
                               style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1E293B;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Weight"
                               style="-fx-text-fill: #64748B; -fx-font-size: 11px;"/>
                        <Label fx:id="labelPoids" text="—"
                               style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1E293B;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Height"
                               style="-fx-text-fill: #64748B; -fx-font-size: 11px;"/>
                        <Label fx:id="labelTaille" text="—"
                               style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1E293B;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Goal"
                               style="-fx-text-fill: #64748B; -fx-font-size: 11px;"/>
                        <Label fx:id="labelObjectif" text="Weight Loss"
                               style="-fx-font-weight: bold;
                                      -fx-font-size: 14px;
                                      -fx-text-fill: #F59E0B;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- OPTIONS -->
            <VBox spacing="10"
                  style="-fx-background-color: white;
                         -fx-background-radius: 12;
                         -fx-padding: 18;
                         -fx-border-color: #E2E8F0;
                         -fx-border-radius: 12;">

                <Label text="Generation Options"
                       style="-fx-font-weight: bold;
                              -fx-font-size: 15px;
                              -fx-text-fill: #1E293B;"/>
                <Label text="Prioritize ingredients near expiry"
                       style="-fx-text-fill: #10B981; -fx-font-size: 13px;"/>
                <Label text="Balance daily calories"
                       style="-fx-text-fill: #10B981; -fx-font-size: 13px;"/>
                <Label text="Respect dietary preferences"
                       style="-fx-text-fill: #10B981; -fx-font-size: 13px;"/>
            </VBox>

            <!-- RÉGIME + ALLERGIES + OBJECTIF -->
            <HBox spacing="16">

                <!-- RÉGIME -->
                <VBox spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-background-radius: 12;
                             -fx-padding: 18;
                             -fx-border-color: #E2E8F0;
                             -fx-border-radius: 12;">

                    <Label text="Diet"
                           style="-fx-font-weight: bold;
                                  -fx-font-size: 15px;
                                  -fx-text-fill: #1E293B;"/>

                    <fx:define>
                        <ToggleGroup fx:id="toggleRegime"/>
                    </fx:define>

                    <RadioButton text="Standard"
                                 toggleGroup="$toggleRegime"
                                 selected="true"
                                 style="-fx-font-size: 13px; -fx-text-fill: #1E293B;"/>
                    <RadioButton text="Végétarien"
                                 fx:id="radioVegetarien"
                                 toggleGroup="$toggleRegime"
                                 style="-fx-font-size: 13px; -fx-text-fill: #1E293B;"/>
                    <RadioButton text="Végan"
                                 fx:id="radioVegan"
                                 toggleGroup="$toggleRegime"
                                 style="-fx-font-size: 13px; -fx-text-fill: #1E293B;"/>
                    <RadioButton text="Halal"
                                 fx:id="radioHalal"
                                 toggleGroup="$toggleRegime"
                                 style="-fx-font-size: 13px; -fx-text-fill: #1E293B;"/>
                </VBox>

                <!-- ALLERGIES -->
                <VBox spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-background-radius: 12;
                             -fx-padding: 18;
                             -fx-border-color: #E2E8F0;
                             -fx-border-radius: 12;">

                    <Label text="Allergies"
                           style="-fx-font-weight: bold;
                                  -fx-font-size: 15px;
                                  -fx-text-fill: #1E293B;"/>

                    <CheckBox fx:id="checkLactose" text="Lactose"
                              style="-fx-font-size: 13px; -fx-text-fill: #1E293B;"/>
                    <CheckBox fx:id="checkGluten" text="Gluten"
                              style="-fx-font-size: 13px; -fx-text-fill: #1E293B;"/>
                    <CheckBox fx:id="checkNoix" text="Nuts"
                              style="-fx-font-size: 13px; -fx-text-fill: #1E293B;"/>
                    <CheckBox fx:id="checkOeufs" text="Eggs"
                              style="-fx-font-size: 13px; -fx-text-fill: #1E293B;"/>
                </VBox>

                <!-- OBJECTIF -->
                <VBox spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-background-radius: 12;
                             -fx-padding: 18;
                             -fx-border-color: #E2E8F0;
                             -fx-border-radius: 12;">

                    <Label text="Goal"
                           style="-fx-font-weight: bold;
                                  -fx-font-size: 15px;
                                  -fx-text-fill: #1E293B;"/>

                    <ChoiceBox fx:id="choiceObjectif"
                               maxWidth="Infinity"
                               style="-fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <!-- STOCK -->
            <VBox spacing="10"
                  style="-fx-background-color: white;
                         -fx-background-radius: 12;
                         -fx-padding: 18;
                         -fx-border-color: #E2E8F0;
                         -fx-border-radius: 12;">

                <Label text="Stock Overview"
                       style="-fx-font-weight: bold;
                              -fx-font-size: 15px;
                              -fx-text-fill: #1E293B;"/>

                <Label fx:id="labelUrgent" text="—"
                       style="-fx-font-size: 13px; -fx-text-fill: #EA580C; -fx-font-weight: bold;"/>
                <Label fx:id="labelBientot" text="—"
                       style="-fx-font-size: 13px; -fx-text-fill: #DC2626; -fx-font-weight: bold;"/>
                <Label fx:id="labelOk" text="—"
                       style="-fx-font-size: 13px; -fx-text-fill: #10B981; -fx-font-weight: bold;"/>
            </VBox>

            <!-- BOUTON -->
            <Button text="GENERATE MY SMART PLAN"
                    onAction="#onGenererPlan"
                    maxWidth="Infinity"
                    style="-fx-background-color: #1F4D3A;
                           -fx-text-fill: white;
                           -fx-font-size: 16px;
                           -fx-font-weight: bold;
                           -fx-padding: 16px;
                           -fx-background-radius: 12;
                           -fx-cursor: hand;"/>
        </VBox>

        <!-- LOADING -->
        <VBox fx:id="vboxLoading" spacing="20"
              alignment="CENTER" visible="false" managed="false"
              style="-fx-background-color: white;
                     -fx-background-radius: 16;
                     -fx-padding: 40;
                     -fx-border-color: #E2E8F0;
                     -fx-border-radius: 16;">

            <Label text="Generating your plan..."
                   style="-fx-font-size: 20px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1F4D3A;"/>

            <ProgressBar fx:id="progressBar" progress="0"
                         maxWidth="Infinity" prefHeight="20"
                         style="-fx-accent: #1F4D3A;"/>

            <Label fx:id="labelProgress" text="0%"
                   style="-fx-font-size: 14px; -fx-text-fill: #64748B;"/>

            <Label fx:id="labelStep" text="Initializing..."
                   style="-fx-font-size: 13px; -fx-text-fill: #1E293B;"/>
        </VBox>

    </VBox>
</ScrollPane>