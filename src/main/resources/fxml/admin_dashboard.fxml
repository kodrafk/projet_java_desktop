<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.projet.gui.AdminDashboardController"
            prefWidth="1320" prefHeight="780"
            style="-fx-background-color:#F0F4F8;">

    <!-- Sidebar -->
    <left>
        <VBox prefWidth="220" spacing="4"
              style="-fx-background-color:#0F2820;-fx-padding:0 0 20 0;">
            <HBox alignment="CENTER" style="-fx-padding:24 0 20 0;">
                <Label text="🥗 NutriLife" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:white;"/>
            </HBox>

            <!-- Admin info -->
            <VBox alignment="CENTER" spacing="4" style="-fx-padding:0 16 20 16;">
                <StackPane prefWidth="48" prefHeight="48" style="-fx-background-color:#2E7D5A;-fx-background-radius:24;">
                    <Label fx:id="lblAdminAvatar" text="A" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                </StackPane>
                <Label fx:id="lblAdminName"  text="" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Label fx:id="lblAdminEmail" text="" style="-fx-font-size:10px;-fx-text-fill:#A8C4B8;"/>
            </VBox>

            <Separator style="-fx-background-color:#1E4A35;"/>

            <Button fx:id="btnDashboard"  text="📊  Dashboard"       onAction="#handleDashboard"  prefHeight="44" maxWidth="Infinity"
                    style="-fx-background-color:#2E7D5A;-fx-text-fill:white;-fx-font-size:12.5px;-fx-font-weight:bold;-fx-background-radius:10;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:0 0 0 14;"/>
            <Button fx:id="btnUsers"      text="👥  User Management"  onAction="#handleUsers"      prefHeight="44" maxWidth="Infinity"
                    style="-fx-background-color:transparent;-fx-text-fill:#A8C4B8;-fx-font-size:12.5px;-fx-background-radius:10;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:0 0 0 14;"/>
            <Button fx:id="btnStatistics" text="📈  Statistics"       onAction="#handleStatistics" prefHeight="44" maxWidth="Infinity"
                    style="-fx-background-color:transparent;-fx-text-fill:#A8C4B8;-fx-font-size:12.5px;-fx-background-radius:10;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:0 0 0 14;"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Button text="🚪  Logout" onAction="#handleLogout" prefHeight="44" maxWidth="Infinity"
                    style="-fx-background-color:#DC2626;-fx-text-fill:white;-fx-font-size:12.5px;-fx-font-weight:bold;-fx-background-radius:10;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:0 0 0 14;-fx-margin:0 12 0 12;"/>
        </VBox>
    </left>

    <!-- Main content -->
    <center>
        <StackPane fx:id="contentArea">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                        style="-fx-background-color:#F0F4F8;-fx-background:#F0F4F8;-fx-border-color:transparent;">
                <VBox spacing="20" style="-fx-padding:28 32;">
                    <Label text="Admin Dashboard" style="-fx-font-size:24px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>

                    <!-- KPI cards -->
                    <HBox spacing="16">
                        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6"
                              style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:20;-fx-border-color:#E2E8F0;-fx-border-radius:14;">
                            <Label text="Total Users" style="-fx-font-size:12px;-fx-text-fill:#64748B;-fx-font-weight:bold;"/>
                            <Label fx:id="lblTotalUsers" text="0" style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6"
                              style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:20;-fx-border-color:#E2E8F0;-fx-border-radius:14;">
                            <Label text="Active Users" style="-fx-font-size:12px;-fx-text-fill:#64748B;-fx-font-weight:bold;"/>
                            <Label fx:id="lblActiveUsers" text="0" style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#16A34A;"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6"
                              style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:20;-fx-border-color:#E2E8F0;-fx-border-radius:14;">
                            <Label text="Inactive Users" style="-fx-font-size:12px;-fx-text-fill:#64748B;-fx-font-weight:bold;"/>
                            <Label fx:id="lblInactiveUsers" text="0" style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#DC2626;"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6"
                              style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:20;-fx-border-color:#E2E8F0;-fx-border-radius:14;">
                            <Label text="Administrators" style="-fx-font-size:12px;-fx-text-fill:#64748B;-fx-font-weight:bold;"/>
                            <Label fx:id="lblAdmins" text="0" style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#7C3AED;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>
        </StackPane>
    </center>
</BorderPane>
