<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.effect.DropShadow?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17"
           fx:controller="tn.esprit.projet.gui.RecipeManagementController"
           style="-fx-background-color: #F8FAFC;">

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <VBox spacing="0">
            
            <!-- HERO SECTION (Updated: Neutral & Desktop Friendly) -->
            <StackPane prefHeight="240" style="-fx-background-color: white; -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-border-width: 0 0 1 0;">
                <VBox alignment="CENTER" spacing="12">
                    <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>
                    <Label text="Explore our Recipes" style="-fx-font-size: 40px; -fx-font-weight: 900; -fx-text-fill: #1E293B;"/>
                    <Label text="Discover healthy, delicious recipes tailored to your nutritional goals" 
                           style="-fx-font-size: 16px; -fx-text-fill: #64748B;"/>
                    
                    <!-- Search Bar (Desktop Style) -->
                    <HBox alignment="CENTER" maxWidth="800" prefHeight="60"
                          style="-fx-background-color: #F8FAFC; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-padding: 0 10 0 25;">
                        <VBox.margin><Insets top="20"/></VBox.margin>
                        <Label text="🔍" style="-fx-font-size: 18px; -fx-text-fill: #94A3B8;"/>
                        <TextField fx:id="txtSearch" promptText="Search a recipe, an ingredient..." 
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 15px; -fx-text-fill: #1E293B;"/>
                        <Button text="Search" onAction="#handleRefresh"
                                prefHeight="44" prefWidth="120"
                                style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 14px;"/>
                    </HBox>
                </VBox>
            </StackPane>

            <!-- MAIN CONTENT AREA -->
            <VBox spacing="35">
                <padding><Insets top="45" right="30" bottom="60" left="30"/></padding>

                <!-- FILTERS BAR -->
                <HBox alignment="CENTER_LEFT" spacing="25" prefHeight="80"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-border-color: #E2E8F0; -fx-border-radius: 20; -fx-padding: 0 30;">
                    
                    <Label text="TYPE :" style="-fx-font-weight: 900; -fx-text-fill: #1E293B; -fx-font-size: 14px;"/>
                    <HBox fx:id="filterPillsContainer" spacing="12" alignment="CENTER_LEFT">
                        <!-- Pills added dynamically in controller -->
                    </HBox>

                    <Region prefWidth="1" prefHeight="35" style="-fx-background-color: #E2E8F0;"/>
                    
                    <Label text="SORT :" style="-fx-font-weight: 900; -fx-text-fill: #1E293B; -fx-font-size: 14px;"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Button text="⏱ Time" onAction="#handleRefresh"
                                style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 8 18; -fx-text-fill: #64748B; -fx-font-size: 13px; -fx-cursor: hand;"/>
                        <Button text="⭐ Difficulty" onAction="#handleRefresh"
                                style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 8 18; -fx-text-fill: #64748B; -fx-font-size: 13px; -fx-cursor: hand;"/>
                        <Button text="📝 Name ↑" onAction="#handleRefresh"
                                style="-fx-background-color: white; -fx-border-color: #F59E0B; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 8 18; -fx-text-fill: #F59E0B; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </HBox>
                </HBox>

                <!-- RESULTS INFO -->
                <HBox alignment="CENTER_LEFT" prefHeight="80" spacing="12"
                      style="-fx-background-color: white;
             -fx-background-radius: 16;
             -fx-border-color: #E2E8F0;
             -fx-border-radius: 16;
             -fx-padding: 0 30;">

                    <Label fx:id="lblTableInfo"
                           text="0 recipe(s) found"
                           style="-fx-font-size: 18px;
                  -fx-text-fill: #F59E0B;
                  -fx-font-weight: 900;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Bouton Historique -->
                    <Button text="History"
                            onAction="#handleOpenHistorique"
                            prefHeight="50"
                            style="-fx-background-color: white;
                   -fx-text-fill: #1F4D3A;
                   -fx-font-weight: bold;
                   -fx-background-radius: 25;
                   -fx-border-color: #1F4D3A;
                   -fx-border-radius: 25;
                   -fx-cursor: hand;
                   -fx-font-size: 14px;
                   -fx-padding: 0 22;"/>

                    <!-- Bouton Meal Planner -->
                    <Button text="Smart Meal Planner"
                            onAction="#handleOpenMealPlanner"
                            prefHeight="50"
                            style="-fx-background-color: #1F4D3A;
                   -fx-text-fill: white;
                   -fx-font-weight: bold;
                   -fx-background-radius: 25;
                   -fx-cursor: hand;
                   -fx-font-size: 14px;
                   -fx-padding: 0 22;"/>

                    <!-- Bouton Add Recipe -->
                    <Button text="Add my recipe"
                            onAction="#handleAddNew"
                            prefHeight="50"
                            prefWidth="200"
                            style="-fx-background-color: #F59E0B;
                   -fx-text-fill: white;
                   -fx-font-weight: bold;
                   -fx-background-radius: 25;
                   -fx-cursor: hand;
                   -fx-font-size: 15px;"/>
                </HBox>

                <!-- RECIPES GRID -->
                <FlowPane fx:id="recipesGrid" hgap="25" vgap="30" alignment="CENTER" maxWidth="Infinity">
                    <!-- Cards added dynamically in controller -->
                </FlowPane>

                <!-- EMPTY STATE -->
                <VBox fx:id="emptyState" alignment="CENTER" spacing="15" visible="false" managed="false" style="-fx-padding: 60 0;">
                    <Label text="👨‍🍳" style="-fx-font-size: 50px;"/>
                    <Label text="No recipe found" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                    <Label text="Try modifying your filters or search terms" style="-fx-text-fill: #64748B;"/>
                    <Button text="See all recipes" onAction="#handleRefresh"
                            style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 25; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </VBox>

                <!-- PAGINATION -->
                <VBox alignment="CENTER" spacing="12" fx:id="paginationContainer">
                    <HBox fx:id="paginationHBox" alignment="CENTER" spacing="8">
                        <!-- Pagination buttons added dynamically -->
                    </HBox>
                    <Label fx:id="lblPaginationInfo" text="Page 1 sur 1" style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
                </VBox>
                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- 🤖 RECOMMENDED FOR YOU SECTION                         -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <VBox fx:id="recommendationSection"
                      spacing="20"
                      visible="false"
                      managed="false"
                      style="-fx-background-color: #F0FDF4;
             -fx-background-radius: 20;
             -fx-border-color: #A7F3D0;
             -fx-border-radius: 20;
             -fx-padding: 25 30 25 30;">

                    <!-- Loading State -->
                    <VBox fx:id="recommendationLoading"
                          alignment="CENTER"
                          spacing="15"
                          visible="false"
                          managed="false"
                          style="-fx-padding: 30 0;">
                        <ProgressIndicator style="-fx-progress-color: #1F4D3A;"/>
                        <Label text="🤖 AI is analyzing your preferences..."
                               style="-fx-font-size: 14px; -fx-text-fill: #64748B;"/>
                    </VBox>

                    <!-- Empty State -->
                    <VBox fx:id="recommendationEmpty"
                          alignment="CENTER"
                          spacing="12"
                          visible="false"
                          managed="false"
                          style="-fx-padding: 30 0;">
                        <Label text="🤖" style="-fx-font-size: 40px;"/>
                        <Label text="No recommendations yet"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                        <Label text="Add recipes to favorites to get personalized suggestions"
                               style="-fx-text-fill: #64748B;"/>
                        <Button text="❤️ Browse Recipes"
                                onAction="#handleBrowseRecipesForReco"
                                style="-fx-background-color: #1F4D3A; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 10;
                       -fx-padding: 10 25; -fx-cursor: hand;"/>
                    </VBox>

                    <!-- Header -->
                    <HBox fx:id="recommendationHeader"
                          alignment="CENTER_LEFT"
                          spacing="10"
                          visible="true"
                          managed="true">
                        <Label text="🤖" style="-fx-font-size: 28px;"/>
                        <VBox spacing="2">
                            <Label text="Recommended For You"
                                   style="-fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: #1E293B;"/>
                            <Label text="Personalized recipes based on your favorites &amp; available stock"
                                   style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnRefreshRecommendations"
                                text="🔄 Refresh"
                                onAction="#handleRefreshRecommendations"
                                style="-fx-background-color: transparent;
                       -fx-text-fill: #1F4D3A; -fx-font-weight: bold;
                       -fx-border-color: #A7F3D0; -fx-border-radius: 20;
                       -fx-background-radius: 20; -fx-padding: 8 18;
                       -fx-cursor: hand; -fx-font-size: 13px;"/>
                    </HBox>

                    <!-- Separator -->
                    <Separator style="-fx-background-color: #A7F3D0; -fx-pref-height: 1;"/>

                    <!-- Cards Container (scrollable horizontal) -->
                    <HBox fx:id="recommendationCardsContainer"
                          spacing="20"
                          alignment="CENTER_LEFT"
                          style="-fx-padding: 5 0 5 0;">
                        <!-- Cartes ajoutées dynamiquement dans le controller -->
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </ScrollPane>

    <!-- MODAL FORM OVERLAY (AJOUT/EDIT) -->
    <StackPane fx:id="modalOverlay" visible="false" managed="false" style="-fx-background-color: #0F172AA6;">
        <VBox spacing="0" maxWidth="650" maxHeight="650" style="-fx-background-color: white; -fx-background-radius: 20;">
            
            <HBox alignment="CENTER_LEFT" prefHeight="70" style="-fx-background-color: white; -fx-background-radius: 20 20 0 0; -fx-padding: 0 30; -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-border-width: 0 0 1 0;">
                <Label fx:id="lblModalTitle" text="👨‍🍳 Add my recipe" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #1E293B;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="✕" onAction="#handleCloseModal" style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-size: 24px; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background-color: white; -fx-background: white; -fx-border-color: transparent;">
                <VBox spacing="30" style="-fx-padding: 35;">
                    <!-- General Error Message -->
                    <Label fx:id="lblGeneralError" text="⚠️ Please correct the errors below." 
                           visible="false" managed="false" 
                           style="-fx-background-color: #FEE2E2; -fx-text-fill: #DC2626; -fx-padding: 12 20; -fx-background-radius: 8; -fx-font-weight: bold; -fx-font-size: 14px; -fx-max-width: Infinity;"/>
                    
                    <!-- Form Grid -->
                    <GridPane hgap="25" vgap="25">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <VBox spacing="8" GridPane.columnSpan="2">
                            <Label text="Recipe Name *" style="-fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <TextField fx:id="txtNom" promptText="e.g. Classic Margherita Pizza" prefHeight="45"
                                       style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10;"/>
                            <Label fx:id="lblNomError" visible="false" managed="false" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
                        </VBox>

                        <VBox spacing="8" GridPane.rowIndex="1">
                            <Label text="Dish Type *" style="-fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <ComboBox fx:id="cmbType" maxWidth="Infinity" prefHeight="45"
                                      style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10;"/>
                            <Label fx:id="lblTypeError" visible="false" managed="false" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
                        </VBox>

                        <VBox spacing="8" GridPane.rowIndex="1" GridPane.columnIndex="1">
                            <Label text="Difficulty *" style="-fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <ComboBox fx:id="cmbDifficulte" maxWidth="Infinity" prefHeight="45"
                                      style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10;"/>
                            <Label fx:id="lblDifficulteError" visible="false" managed="false" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
                        </VBox>

                        <VBox spacing="8" GridPane.rowIndex="2">
                            <Label text="Preparation Time (min) *" style="-fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <TextField fx:id="txtTemps" promptText="e.g. 45" prefHeight="45"
                                       style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10;"/>
                            <Label fx:id="lblTempsError" visible="false" managed="false" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
                        </VBox>

                        <VBox spacing="8" GridPane.rowIndex="2" GridPane.columnIndex="1">
                            <Label text="Image URL" style="-fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <TextField fx:id="txtImage" promptText="https://images.unsplash.com/..." prefHeight="45"
                                       style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10;"/>
                            <Label fx:id="lblImageError" visible="false" managed="false" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
                        </VBox>

                        <VBox spacing="8" GridPane.rowIndex="3" GridPane.columnSpan="2">
                            <Label text="Description" style="-fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <TextArea fx:id="txtDescription" prefHeight="100" wrapText="true"
                                      style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10;"/>
                            <Label fx:id="lblDescriptionError" visible="false" managed="false" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
                        </VBox>
                    </GridPane>

                    <!-- Ingredients Section (New based on Twig) -->
                    <VBox spacing="15">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="🥕 Ingredients" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <ComboBox fx:id="cmbIngredients" promptText="Search an ingredient..." prefWidth="250"
                                      style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-background-radius: 8; -fx-border-radius: 8;"/>
                        </HBox>
                        <VBox fx:id="recipeIngredientsContainer" spacing="10"/>
                    </VBox>

                    <!-- Steps Section -->
                    <VBox spacing="15">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="📝 Preparation Steps" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="+ Add Step" onAction="#handleAddStep"
                                    style="-fx-background-color: #F0FDF4; -fx-text-fill: #166534; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 15;">
                                <graphic>
                                    <SVGPath content="M12 5V19M5 12H19" fill="transparent" stroke="#166534" strokeWidth="2.5"/>
                                </graphic>
                            </Button>
                        </HBox>
                        <VBox fx:id="stepsContainer" spacing="12"/>
                    </VBox>
                </VBox>
            </ScrollPane>

            <HBox alignment="CENTER_RIGHT" spacing="20" prefHeight="100" style="-fx-padding: 0 40; -fx-border-color: #E2E8F0; -fx-border-width: 1 0 0 0;">
                <Button text="Cancel" onAction="#handleCloseModal" prefHeight="50" prefWidth="130"
                        style="-fx-background-color: transparent; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-text-fill: #64748B; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 15px;"/>
                <Button text="Save Recipe" onAction="#handleSave" prefHeight="50" prefWidth="180"
                        style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-font-weight: 900; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 15px;"/>
            </HBox>
        </VBox>
    </StackPane>

    <!-- RECIPE DETAILS OVERLAY -->
    <StackPane fx:id="detailsOverlay" visible="false" managed="false" style="-fx-background-color: #0F172AA6;">
        <VBox spacing="0" maxWidth="500" maxHeight="550" style="-fx-background-color: white; -fx-background-radius: 20;">
            <HBox alignment="CENTER_LEFT" prefHeight="70" style="-fx-background-color: #F59E0B; -fx-background-radius: 20 20 0 0; -fx-padding: 0 30;">
                <Label fx:id="lblDetailsNom" text="Recipe Details" style="-fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="✕" onAction="#handleCloseDetails" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 24px; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>
            
            <ScrollPane fitToWidth="true" style="-fx-background-color: white; -fx-background: white; -fx-border-color: transparent;">
                <VBox spacing="20" style="-fx-padding: 30;">
                    <HBox spacing="20">
                        <Label fx:id="lblDetailsType" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-padding: 5 12; -fx-background-radius: 10; -fx-font-weight: bold;"/>
                        <Label fx:id="lblDetailsTemps" style="-fx-text-fill: #64748B; -fx-font-weight: bold;"/>
                        <Label fx:id="lblDetailsDifficulte" style="-fx-text-fill: #64748B; -fx-font-weight: bold;"/>
                    </HBox>
                    
                    <Label text="Description" style="-fx-font-size: 16px; -fx-font-weight: 900; -fx-text-fill: #1E293B;"/>
                    <Label fx:id="txtDetailsDescription" wrapText="true" style="-fx-text-fill: #475569; -fx-line-spacing: 1.5;"/>
                    
                    <Separator/>
                    
                    <Label text="Preparation Steps" style="-fx-font-size: 16px; -fx-font-weight: 900; -fx-text-fill: #1E293B;"/>
                    <VBox fx:id="detailsStepsContainer" spacing="10"/>
                </VBox>
            </ScrollPane>
        </VBox>
    </StackPane>
</StackPane>