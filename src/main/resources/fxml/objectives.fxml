<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.projet.gui.ObjectivesController"
      style="-fx-background-color: #F6FBF7;"
      spacing="0">

    <!-- ═══ HEADER ═══ -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #163A2E; -fx-padding: 20 32;">
        <VBox spacing="4">
            <Label text="Nutrition Tracking"
                   style="-fx-font-size: 11px; -fx-text-fill: #A7C4B8; -fx-font-weight: bold;"/>
            <Label text="My Nutrition Objectives"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Track your dietary goals and monitor your progress week by week."
                   style="-fx-font-size: 12px; -fx-text-fill: #A7C4B8;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnNewObjective" text="+ New Objective" onAction="#handleNewObjective"
                style="-fx-background-color: #2E7D5A; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 20; -fx-cursor: hand;"/>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background: #F6FBF7; -fx-background-color: #F6FBF7; -fx-border-color: transparent;">
        <VBox spacing="20" style="-fx-background-color: #F6FBF7;">
            <padding><Insets top="24" right="32" bottom="32" left="32"/></padding>

            <!-- ═══ ACTIVE BANNER ═══ -->
            <VBox fx:id="activeBanner" spacing="0" managed="false" visible="false"
                  style="-fx-background-color: #163A2E; -fx-background-radius: 14; -fx-padding: 20 24;">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="● ACTIVE NOW"
                                   style="-fx-font-size: 11px; -fx-text-fill: #52b788; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label fx:id="activeBannerTitle" text=""
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label fx:id="activeBannerMeta" text=""
                               style="-fx-font-size: 12px; -fx-text-fill: #A7C4B8;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="8">
                        <Label fx:id="activeBannerProgress" text="0%"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <ProgressBar fx:id="activeBannerBar" progress="0" prefWidth="120"
                                     style="-fx-accent: #52b788;"/>
                        <Button fx:id="btnViewLogs" text="View Logs →" onAction="#handleViewLogs"
                                style="-fx-background-color: #2E7D5A; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 12px; -fx-cursor: hand;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ═══ STATS ROW ═══ -->
            <HBox fx:id="statsRow" spacing="12" alignment="CENTER_LEFT">
                <HBox spacing="8" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10 16; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                    <Label text="●" style="-fx-text-fill: #2E7D5A; -fx-font-size: 10px;"/>
                    <Label fx:id="lblActiveCount" text="0"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                    <Label text="Active" style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10 16; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                    <Label text="●" style="-fx-text-fill: #f0ad4e; -fx-font-size: 10px;"/>
                    <Label fx:id="lblPausedCount" text="0"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                    <Label text="Paused" style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10 16; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                    <Label text="●" style="-fx-text-fill: #64748B; -fx-font-size: 10px;"/>
                    <Label fx:id="lblPendingCount" text="0"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                    <Label text="Pending" style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10 16; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                    <Label text="●" style="-fx-text-fill: #1F4D3A; -fx-font-size: 10px;"/>
                    <Label fx:id="lblDoneCount" text="0"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                    <Label text="Completed" style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                </HBox>
            </HBox>

            <!-- ═══ SEARCH + SORT ═══ -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search objectives by title..."
                           prefWidth="380" prefHeight="40"
                           style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 12; -fx-font-size: 13px;"/>
                <ComboBox fx:id="sortCombo" prefWidth="200" prefHeight="40"
                          style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-font-size: 13px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblCount" text="0 objectives"
                       style="-fx-font-size: 12px; -fx-text-fill: #64748B; -fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-padding: 8 14;"/>
            </HBox>

            <!-- ═══ OBJECTIVES LIST ═══ -->
            <VBox fx:id="objectivesContainer" spacing="12"/>

            <!-- ═══ EMPTY STATE ═══ -->
            <VBox fx:id="emptyState" alignment="CENTER" spacing="16" managed="false" visible="false"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 60 40; -fx-border-color: #E2E8F0; -fx-border-radius: 14;">
                <Label text="📊" style="-fx-font-size: 48px;"/>
                <Label text="No objectives yet"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                <Label text="Set a nutritional goal and begin your wellness journey."
                       style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
                <Button text="+ Create First Objective" onAction="#handleNewObjective"
                        style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 12 24; -fx-cursor: hand;"/>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
