<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.effect.DropShadow?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.projet.gui.StatisticsDashboardController"
      spacing="0" prefWidth="650" prefHeight="450"
      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #E2E8F0; -fx-border-width: 1;">

    <!-- ══════════════════ HEADER ══════════════════ -->
    <HBox fx:id="headerPane" alignment="CENTER_LEFT" spacing="12" prefHeight="60"
          style="-fx-background-color: #1A5C40; -fx-padding: 0 25; -fx-background-radius: 15 15 0 0;">
        <effect>
            <DropShadow color="#00000022" radius="8" offsetY="3"/>
        </effect>

        <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTitle" text="Recipe Insights"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label fx:id="lblSubtitle" text="Data visualization and analysis"
                   style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.8);"/>
        </VBox>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Label text="Criteria:" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            <ComboBox fx:id="comboCriteria" prefWidth="200" prefHeight="36"
                      style="-fx-background-color: white; -fx-background-radius: 8; -fx-font-size: 13px; -fx-cursor: hand;"/>
        </HBox>
        
        <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-cursor: hand;">
            <graphic>
                <SVGPath content="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                         fill="white" scaleX="1.1" scaleY="1.1"/>
            </graphic>
        </Button>
    </HBox>

    <!-- ══════════════════ CONTENT AREA ══════════════════ -->
    <StackPane VBox.vgrow="ALWAYS" style="-fx-background-color: #F8FAFC; -fx-background-radius: 0 0 15 15;">
        <VBox fx:id="contentArea" alignment="TOP_CENTER" spacing="0" style="-fx-padding: 25;">
            <!-- Single Chart will be injected here -->
        </VBox>
    </StackPane>

</VBox>
