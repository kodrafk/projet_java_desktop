<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.projet.gui.DailyLogsController"
      style="-fx-background-color: #F6FBF7;" spacing="0">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #163A2E; -fx-padding: 20 32;">
        <VBox spacing="4">
            <Label text="Daily Tracking"
                   style="-fx-font-size: 11px; -fx-text-fill: #A7C4B8; -fx-font-weight: bold;"/>
            <Label fx:id="lblHeaderTitle" text="Daily Logs"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label fx:id="lblHeaderSub" text=""
                   style="-fx-font-size: 12px; -fx-text-fill: #A7C4B8;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="← Back" onAction="#handleBack"
                style="-fx-background-color: transparent; -fx-text-fill: #A7C4B8; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: #2F5A4A; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 16;"/>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background: #F6FBF7; -fx-background-color: #F6FBF7; -fx-border-color: transparent;">
        <VBox spacing="20" style="-fx-background-color: #F6FBF7;">
            <padding><Insets top="24" right="32" bottom="32" left="32"/></padding>

            <!-- Summary Grid -->
            <HBox spacing="14">
                <VBox alignment="CENTER" spacing="6" prefWidth="160"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-border-color: #E2E8F0; -fx-border-radius: 14;">
                    <Label text="📊" style="-fx-font-size: 22px;"/>
                    <Label fx:id="lblProgress" text="0%"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #eb7147;"/>
                    <Label text="PROGRESS" style="-fx-font-size: 10px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="6" prefWidth="160"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-border-color: #E2E8F0; -fx-border-radius: 14;">
                    <Label text="✓" style="-fx-font-size: 22px; -fx-text-fill: #2E7D5A;"/>
                    <Label fx:id="lblDaysLogged" text="0/7"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2E7D5A;"/>
                    <Label text="DAYS LOGGED" style="-fx-font-size: 10px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="6" prefWidth="160"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-border-color: #E2E8F0; -fx-border-radius: 14;">
                    <Label text="⏱" style="-fx-font-size: 22px;"/>
                    <Label fx:id="lblDaysLeft" text="7"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #eb7147;"/>
                    <Label text="DAYS LEFT" style="-fx-font-size: 10px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="6" prefWidth="160"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-border-color: #E2E8F0; -fx-border-radius: 14;">
                    <Label text="🔥" style="-fx-font-size: 22px;"/>
                    <Label fx:id="lblAvgCal" text="—"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                    <Label text="AVG CALORIES" style="-fx-font-size: 10px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- Day Cards -->
            <VBox fx:id="dayCardsContainer" spacing="12"/>

        </VBox>
    </ScrollPane>
</VBox>
