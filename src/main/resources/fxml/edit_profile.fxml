<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="580" prefHeight="660"
            style="-fx-background-color:#F8FAFC;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.projet.gui.UserProfileController">

    <!-- ── HEADER ── -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="56" spacing="12"
              style="-fx-background-color:#1E293B; -fx-padding:0 20;">
            <StackPane prefWidth="36" prefHeight="36"
                       style="-fx-background-color:#2E7D5A; -fx-background-radius:18;">
                <Label text="✏" style="-fx-font-size:16px; -fx-text-fill:white;"/>
            </StackPane>
            <VBox spacing="1">
                <Label text="Edit Profile"
                       style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:white;"/>
                <Label text="Update your personal information"
                       style="-fx-font-size:11px; -fx-text-fill:#94A3B8;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#handleClose"
                    style="-fx-background-color:transparent; -fx-text-fill:#94A3B8;
                           -fx-font-size:18px; -fx-cursor:hand; -fx-padding:4 10;
                           -fx-background-radius:6;"/>
        </HBox>
    </top>

    <!-- ── CONTENT ── -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color:#F8FAFC; -fx-background:#F8FAFC;
                           -fx-border-color:transparent; -fx-padding:0;">
            <VBox spacing="14" style="-fx-background-color:#F8FAFC; -fx-padding:20 24 10 24;">

                <!-- Photo card -->
                <VBox spacing="12"
                      style="-fx-background-color:white; -fx-background-radius:14;
                             -fx-padding:18; -fx-border-color:#E2E8F0;
                             -fx-border-radius:14; -fx-border-width:1;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),6,0,0,2);">
                    <Label text="Profile Photo"
                           style="-fx-font-size:12px; -fx-font-weight:bold;
                                  -fx-text-fill:#374151;"/>
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <StackPane prefWidth="68" prefHeight="68"
                                   style="-fx-background-color:#2E7D5A;
                                          -fx-background-radius:34;
                                          -fx-effect:dropshadow(gaussian,rgba(46,125,90,0.3),8,0,0,2);">
                            <Label fx:id="lblAvatarInitials" text="?"
                                   style="-fx-font-size:22px; -fx-font-weight:bold;
                                          -fx-text-fill:white;"/>
                            <ImageView fx:id="imgPhoto" fitWidth="68" fitHeight="68"
                                       preserveRatio="true" visible="false"/>
                        </StackPane>
                        <VBox spacing="6">
                            <Button fx:id="btnChoosePhoto" text="📷  Change Photo"
                                    onAction="#handleChoosePhoto" prefHeight="34"
                                    style="-fx-background-color:#F1F5F9;
                                           -fx-border-color:#CBD5E1; -fx-border-radius:8;
                                           -fx-background-radius:8; -fx-font-size:12px;
                                           -fx-cursor:hand; -fx-padding:0 16;"/>
                            <Label text="JPEG or PNG · max 2 MB"
                                   style="-fx-font-size:10px; -fx-text-fill:#94A3B8;"/>
                            <Label fx:id="errPhoto" text=""
                                   style="-fx-text-fill:#DC2626; -fx-font-size:10px;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Personal info card -->
                <VBox spacing="14"
                      style="-fx-background-color:white; -fx-background-radius:14;
                             -fx-padding:18; -fx-border-color:#E2E8F0;
                             -fx-border-radius:14; -fx-border-width:1;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),6,0,0,2);">

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="👤" style="-fx-font-size:14px;"/>
                        <Label text="Personal Information"
                               style="-fx-font-size:13px; -fx-font-weight:bold;
                                      -fx-text-fill:#1E293B;"/>
                    </HBox>

                    <!-- First + Last name -->
                    <HBox spacing="14">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="First Name *"
                                   style="-fx-font-size:11px; -fx-font-weight:bold;
                                          -fx-text-fill:#475569;"/>
                            <TextField fx:id="fieldFirstName" promptText="John"
                                       style="-fx-background-color:#F8FAFC;
                                              -fx-border-color:#E2E8F0; -fx-border-radius:8;
                                              -fx-background-radius:8; -fx-padding:9 12;
                                              -fx-font-size:13px;"/>
                            <Label fx:id="errFirstName" text=""
                                   style="-fx-text-fill:#DC2626; -fx-font-size:10px;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Last Name *"
                                   style="-fx-font-size:11px; -fx-font-weight:bold;
                                          -fx-text-fill:#475569;"/>
                            <TextField fx:id="fieldLastName" promptText="Doe"
                                       style="-fx-background-color:#F8FAFC;
                                              -fx-border-color:#E2E8F0; -fx-border-radius:8;
                                              -fx-background-radius:8; -fx-padding:9 12;
                                              -fx-font-size:13px;"/>
                            <Label fx:id="errLastName" text=""
                                   style="-fx-text-fill:#DC2626; -fx-font-size:10px;"/>
                        </VBox>
                    </HBox>

                    <!-- Weight + Height -->
                    <HBox spacing="14">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Weight (kg)"
                                   style="-fx-font-size:11px; -fx-font-weight:bold;
                                          -fx-text-fill:#475569;"/>
                            <TextField fx:id="fieldWeight" promptText="e.g. 70.5"
                                       style="-fx-background-color:#F8FAFC;
                                              -fx-border-color:#E2E8F0; -fx-border-radius:8;
                                              -fx-background-radius:8; -fx-padding:9 12;
                                              -fx-font-size:13px;"/>
                            <Label fx:id="errWeight" text=""
                                   style="-fx-text-fill:#DC2626; -fx-font-size:10px;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Height (cm)"
                                   style="-fx-font-size:11px; -fx-font-weight:bold;
                                          -fx-text-fill:#475569;"/>
                            <TextField fx:id="fieldHeight" promptText="e.g. 175"
                                       style="-fx-background-color:#F8FAFC;
                                              -fx-border-color:#E2E8F0; -fx-border-radius:8;
                                              -fx-background-radius:8; -fx-padding:9 12;
                                              -fx-font-size:13px;"/>
                            <Label fx:id="errHeight" text=""
                                   style="-fx-text-fill:#DC2626; -fx-font-size:10px;"/>
                        </VBox>
                    </HBox>

                    <!-- Phone -->
                    <VBox spacing="5">
                        <Label text="Phone Number"
                               style="-fx-font-size:11px; -fx-font-weight:bold;
                                      -fx-text-fill:#475569;"/>
                        <TextField fx:id="fieldPhone" promptText="+216 XX XXX XXX"
                                   style="-fx-background-color:#F8FAFC;
                                          -fx-border-color:#E2E8F0; -fx-border-radius:8;
                                          -fx-background-radius:8; -fx-padding:9 12;
                                          -fx-font-size:13px;"/>
                    </VBox>
                </VBox>

                <!-- Welcome message card -->
                <VBox spacing="10"
                      style="-fx-background-color:white; -fx-background-radius:14;
                             -fx-padding:18; -fx-border-color:#E2E8F0;
                             -fx-border-radius:14; -fx-border-width:1;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),6,0,0,2);">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="💬" style="-fx-font-size:14px;"/>
                        <VBox spacing="1">
                            <Label text="Welcome Message"
                                   style="-fx-font-size:13px; -fx-font-weight:bold;
                                          -fx-text-fill:#1E293B;"/>
                            <Label text="Shown on your profile page"
                                   style="-fx-font-size:10px; -fx-text-fill:#94A3B8;"/>
                        </VBox>
                    </HBox>
                    <TextArea fx:id="fieldWelcomeMessage" prefRowCount="3" wrapText="true"
                              promptText="Write a short message about yourself..."
                              style="-fx-background-color:#F8FAFC;
                                     -fx-border-color:#E2E8F0; -fx-border-radius:8;
                                     -fx-background-radius:8; -fx-padding:8 12;
                                     -fx-font-size:13px;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- ── FOOTER ── -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12" prefHeight="60"
              style="-fx-background-color:white;
                     -fx-border-color:#E2E8F0 transparent transparent transparent;
                     -fx-border-width:1 0 0 0; -fx-padding:0 24;">
            <Button text="Cancel" onAction="#handleClose"
                    prefHeight="38" prefWidth="100"
                    style="-fx-background-color:#F1F5F9; -fx-border-color:#CBD5E1;
                           -fx-border-radius:10; -fx-background-radius:10;
                           -fx-font-size:13px; -fx-cursor:hand;
                           -fx-text-fill:#374151;"/>
            <Button text="💾  Save Changes" onAction="#handleSave"
                    prefHeight="38" prefWidth="150"
                    style="-fx-background-color:#2E7D5A; -fx-text-fill:white;
                           -fx-font-size:13px; -fx-font-weight:bold;
                           -fx-background-radius:10; -fx-cursor:hand;
                           -fx-effect:dropshadow(gaussian,rgba(46,125,90,0.4),6,0,0,2);"/>
        </HBox>
    </bottom>
</BorderPane>
