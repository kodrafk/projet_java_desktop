<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.projet.gui.EditProfileController"
           prefWidth="580" prefHeight="700">

    <Pane style="-fx-background-color:linear-gradient(to bottom right,#e8f5e9,#fffde7,#fce4ec);"/>
    <Circle radius="18" fill="#66BB6A" opacity="0.4" StackPane.alignment="TOP_RIGHT" translateX="-30" translateY="40"/>

    <VBox StackPane.alignment="TOP_CENTER" maxWidth="Infinity">

        <!-- Header -->
        <HBox prefHeight="56" alignment="CENTER_LEFT"
              style="-fx-background-color:rgba(255,255,255,0.92);
                     -fx-border-color:transparent transparent #E8EDE8 transparent;
                     -fx-border-width:0 0 1 0;-fx-padding:0 24;">
            <Label text="✏️  Edit my profile"
                   style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
        </HBox>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                    style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;">
            <VBox spacing="14" style="-fx-padding:20 28 28 28;">

                <!-- Photo upload -->
                <VBox spacing="8" alignment="CENTER"
                      style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:18;
                             -fx-border-color:#E8F5E9;-fx-border-radius:14;-fx-border-width:1;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),10,0,0,2);">
                    <Label text="📸  Profile photo"
                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                    <StackPane prefWidth="90" prefHeight="90"
                               style="-fx-background-color:#E8F5E9;-fx-background-radius:45;
                                      -fx-border-color:#C8E6C9;-fx-border-radius:45;-fx-border-width:2;">
                        <ImageView fx:id="photoView" fitWidth="90" fitHeight="90"
                                   preserveRatio="true" style="-fx-background-radius:45;"/>
                        <Label text="👤" style="-fx-font-size:32px;-fx-opacity:0.4;"/>
                    </StackPane>
                    <Button text="Choose a photo" onAction="#handleUploadPhoto"
                            style="-fx-background-color:#2E7D32;-fx-text-fill:white;-fx-font-size:12px;
                                   -fx-font-weight:bold;-fx-background-radius:10;-fx-cursor:hand;
                                   -fx-border-color:transparent;-fx-padding:8 18;"/>
                    <Label fx:id="lblPhotoHint" text="JPEG, PNG, GIF ou WebP — max 2MB"
                           style="-fx-font-size:10px;-fx-text-fill:#94A3B8;"/>
                    <Label fx:id="errPhoto" text="" style="-fx-text-fill:#DC2626;-fx-font-size:10px;"/>
                </VBox>

                <!-- Name row -->
                <HBox spacing="12">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="First Name *"
                               style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                        <TextField fx:id="firstNameField" promptText="Jean"
                                   style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                          -fx-border-radius:10;-fx-background-radius:10;
                                          -fx-padding:10 12;-fx-font-size:13px;"/>
                        <Label fx:id="errFirstName" text=""
                               style="-fx-text-fill:#DC2626;-fx-font-size:10px;"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Last Name *"
                               style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                        <TextField fx:id="lastNameField" promptText="Dupont"
                                   style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                          -fx-border-radius:10;-fx-background-radius:10;
                                          -fx-padding:10 12;-fx-font-size:13px;"/>
                        <Label fx:id="errLastName" text=""
                               style="-fx-text-fill:#DC2626;-fx-font-size:10px;"/>
                    </VBox>
                </HBox>

                <!-- Birthday -->
                <VBox spacing="4">
                    <Label text="Date of Birth *"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                    <DatePicker fx:id="birthdayPicker" maxWidth="Infinity"
                                style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                       -fx-border-radius:10;-fx-background-radius:10;"/>
                    <Label fx:id="errBirthday" text=""
                           style="-fx-text-fill:#DC2626;-fx-font-size:10px;"/>
                </VBox>

                <!-- Weight + Height with live BMI -->
                <VBox spacing="8"
                      style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:14 16;
                             -fx-border-color:#E8F5E9;-fx-border-radius:12;-fx-border-width:1;">
                    <Label text="⚖️  Body Measurements"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                    <HBox spacing="12">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Weight (kg) *"
                                   style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                            <TextField fx:id="weightField" promptText="70"
                                       style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                              -fx-border-radius:10;-fx-background-radius:10;
                                              -fx-padding:10 12;-fx-font-size:13px;"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Height (cm) *"
                                   style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                            <TextField fx:id="heightField" promptText="175"
                                       style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                              -fx-border-radius:10;-fx-background-radius:10;
                                              -fx-padding:10 12;-fx-font-size:13px;"/>
                        </VBox>
                    </HBox>
                    <!-- Live BMI preview -->
                    <Label fx:id="errWeight" text="Enter your weight and height to see your BMI"
                           style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                    <Label fx:id="errHeight" text=""
                           style="-fx-text-fill:#DC2626;-fx-font-size:10px;"/>
                </VBox>

                <!-- Info box -->
                <VBox spacing="4"
                      style="-fx-background-color:#F0FDF4;-fx-background-radius:10;-fx-padding:10 14;
                             -fx-border-color:#BBF7D0;-fx-border-radius:10;-fx-border-width:1;">
                    <Label text="💡  After saving"
                           style="-fx-font-size:11px;-fx-font-weight:bold;-fx-text-fill:#166534;"/>
                    <Label text="We will calculate your BMI, ideal weight and give you personalized advice."
                           wrapText="true"
                           style="-fx-font-size:11px;-fx-text-fill:#166534;"/>
                </VBox>

                <!-- Buttons -->
                <HBox spacing="10">
                    <Button text="💾  Save" onAction="#handleSave"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="46"
                            style="-fx-background-color:#2E7D32;-fx-text-fill:white;-fx-font-size:14px;
                                   -fx-font-weight:bold;-fx-background-radius:12;-fx-cursor:hand;
                                   -fx-border-color:transparent;"/>
                    <Button text="Cancel" onAction="#handleCancel"
                            prefHeight="46" prefWidth="110"
                            style="-fx-background-color:white;-fx-text-fill:#6B7280;-fx-font-size:13px;
                                   -fx-background-radius:12;-fx-cursor:hand;
                                   -fx-border-color:#E2E8F0;-fx-border-width:1;-fx-border-radius:12;"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</StackPane>
