<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="460" prefHeight="420"
            style="-fx-background-color:#F8FAFC;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.projet.gui.ChangePasswordController">

    <!-- ── HEADER ── -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="56" spacing="12"
              style="-fx-background-color:#1E293B; -fx-padding:0 20;">
            <StackPane prefWidth="36" prefHeight="36"
                       style="-fx-background-color:#7C3AED; -fx-background-radius:18;">
                <Label text="🔒" style="-fx-font-size:16px;"/>
            </StackPane>
            <VBox spacing="1">
                <Label text="Change Password"
                       style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:white;"/>
                <Label text="Keep your account secure"
                       style="-fx-font-size:11px; -fx-text-fill:#94A3B8;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#handleCancel"
                    style="-fx-background-color:transparent; -fx-text-fill:#94A3B8;
                           -fx-font-size:18px; -fx-cursor:hand; -fx-padding:4 10;
                           -fx-background-radius:6;"/>
        </HBox>
    </top>

    <!-- ── CONTENT ── -->
    <center>
        <VBox spacing="0" style="-fx-background-color:#F8FAFC;">

            <!-- Security tip banner -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color:#EFF6FF; -fx-padding:10 20;
                         -fx-border-color:#BFDBFE transparent transparent transparent;
                         -fx-border-width:0 0 1 0;">
                <Label text="ℹ" style="-fx-font-size:14px; -fx-text-fill:#1D4ED8;"/>
                <Label text="Use at least 8 characters with letters and numbers."
                       style="-fx-font-size:11px; -fx-text-fill:#1D4ED8;"/>
            </HBox>

            <!-- Fields -->
            <VBox spacing="16" style="-fx-padding:24 24 16 24;">

                <!-- Current password -->
                <VBox spacing="5">
                    <Label text="Current Password *"
                           style="-fx-font-size:12px; -fx-font-weight:bold;
                                  -fx-text-fill:#374151;"/>
                    <PasswordField fx:id="fieldCurrent"
                                   promptText="Enter your current password"
                                   style="-fx-background-color:white;
                                          -fx-border-color:#E2E8F0; -fx-border-radius:8;
                                          -fx-background-radius:8; -fx-padding:10 12;
                                          -fx-font-size:13px;"/>
                    <Label fx:id="errCurrent" text=""
                           style="-fx-text-fill:#DC2626; -fx-font-size:10px;"/>
                </VBox>

                <Separator style="-fx-opacity:0.5;"/>

                <!-- New password -->
                <VBox spacing="5">
                    <Label text="New Password *"
                           style="-fx-font-size:12px; -fx-font-weight:bold;
                                  -fx-text-fill:#374151;"/>
                    <PasswordField fx:id="fieldNew"
                                   promptText="Min 8 characters"
                                   style="-fx-background-color:white;
                                          -fx-border-color:#E2E8F0; -fx-border-radius:8;
                                          -fx-background-radius:8; -fx-padding:10 12;
                                          -fx-font-size:13px;"/>
                    <Label fx:id="errNew" text=""
                           style="-fx-text-fill:#DC2626; -fx-font-size:10px;"/>
                </VBox>

                <!-- Confirm password -->
                <VBox spacing="5">
                    <Label text="Confirm New Password *"
                           style="-fx-font-size:12px; -fx-font-weight:bold;
                                  -fx-text-fill:#374151;"/>
                    <PasswordField fx:id="fieldConfirm"
                                   promptText="Repeat your new password"
                                   style="-fx-background-color:white;
                                          -fx-border-color:#E2E8F0; -fx-border-radius:8;
                                          -fx-background-radius:8; -fx-padding:10 12;
                                          -fx-font-size:13px;"/>
                    <Label fx:id="errConfirm" text=""
                           style="-fx-text-fill:#DC2626; -fx-font-size:10px;"/>
                </VBox>

            </VBox>
        </VBox>
    </center>

    <!-- ── FOOTER ── -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12" prefHeight="60"
              style="-fx-background-color:white;
                     -fx-border-color:#E2E8F0 transparent transparent transparent;
                     -fx-border-width:1 0 0 0; -fx-padding:0 24;">
            <Button text="Cancel" onAction="#handleCancel"
                    prefHeight="38" prefWidth="100"
                    style="-fx-background-color:#F1F5F9; -fx-border-color:#CBD5E1;
                           -fx-border-radius:10; -fx-background-radius:10;
                           -fx-font-size:13px; -fx-cursor:hand;
                           -fx-text-fill:#374151;"/>
            <Button fx:id="btnUpdate" text="🔐  Update Password"
                    onAction="#handleSave"
                    prefHeight="38" prefWidth="170"
                    style="-fx-background-color:#7C3AED; -fx-text-fill:white;
                           -fx-font-size:13px; -fx-font-weight:bold;
                           -fx-background-radius:10; -fx-cursor:hand;
                           -fx-effect:dropshadow(gaussian,rgba(124,58,237,0.4),6,0,0,2);"/>
        </HBox>
    </bottom>
</BorderPane>
