<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="420" prefHeight="340"
            style="-fx-background-color: #F0F4F8;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.projet.gui.ChangePasswordController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="54" spacing="12"
              style="-fx-background-color: #0F2820; -fx-padding: 0 20;">
            <Label text="Change Password"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#handleCancel"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 16px; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="14" style="-fx-background-color: #F0F4F8;">
            <padding><Insets top="20" right="24" bottom="10" left="24"/></padding>

            <VBox spacing="3">
                <Label text="Current Password *" style="-fx-font-size: 12px; -fx-text-fill: #475569;"/>
                <PasswordField fx:id="fieldCurrent" promptText="Enter current password"
                               style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 10; -fx-font-size: 13px;"/>
                <Label fx:id="errCurrent" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 10px;"/>
            </VBox>

            <VBox spacing="3">
                <Label text="New Password *" style="-fx-font-size: 12px; -fx-text-fill: #475569;"/>
                <PasswordField fx:id="fieldNew" promptText="Min 8 characters"
                               style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 10; -fx-font-size: 13px;"/>
                <Label fx:id="errNew" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 10px;"/>
            </VBox>

            <VBox spacing="3">
                <Label text="Confirm New Password *" style="-fx-font-size: 12px; -fx-text-fill: #475569;"/>
                <PasswordField fx:id="fieldConfirm" promptText="Repeat new password"
                               style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 10; -fx-font-size: 13px;"/>
                <Label fx:id="errConfirm" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 10px;"/>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12" prefHeight="54"
              style="-fx-background-color: white; -fx-border-color: #E2E8F0 transparent transparent transparent; -fx-border-width: 1 0 0 0; -fx-padding: 0 22;">
            <Button text="Cancel" onAction="#handleCancel" prefHeight="36" prefWidth="90"
                    style="-fx-background-color: #F1F5F9; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 12px; -fx-cursor: hand;"/>
            <Button text="Update Password" onAction="#handleSave" prefHeight="36" prefWidth="140" fx:id="btnUpdate"
                    style="-fx-background-color: #2E7D5A; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
        </HBox>
    </bottom>
</BorderPane>
