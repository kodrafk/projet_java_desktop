<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.projet.gui.VerifyCodeController"
           prefWidth="1100" prefHeight="720">

    <Pane style="-fx-background-color:linear-gradient(to bottom right,#e8f5e9,#fffde7,#fce4ec);"/>
    <Circle radius="20" fill="#7E57C2" opacity="0.6" StackPane.alignment="TOP_LEFT" translateX="200" translateY="150"/>

    <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="NEVER"
                style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;">
        <VBox alignment="CENTER" minHeight="720" style="-fx-background-color:transparent;-fx-padding:40 0;">

            <Label text="Enter Verification Code"
                   style="-fx-font-size:30px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
            <Label text="Enter the 6-digit code sent to your email"
                   style="-fx-font-size:13px;-fx-text-fill:#6B7280;-fx-padding:6 0 24 0;"/>

            <VBox spacing="16" prefWidth="440" maxWidth="440"
                  style="-fx-background-color:white;-fx-background-radius:20;-fx-padding:32 36;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.12),24,0,0,6);">

                <Label fx:id="emailLabel" text=""
                       style="-fx-font-size:12px;-fx-text-fill:#64748B;"/>

                <!-- Dev mode code display -->
                <Label fx:id="devCodeLabel" text="" wrapText="true"
                       style="-fx-font-size:12px;-fx-text-fill:#16A34A;-fx-font-weight:bold;
                              -fx-background-color:#F0FDF4;-fx-background-radius:8;-fx-padding:8 12;"/>

                <Label fx:id="errorLabel" text="" wrapText="true"
                       style="-fx-text-fill:#DC2626;-fx-font-size:12px;-fx-font-weight:bold;"/>

                <VBox spacing="6">
                    <Label text="6-Digit Code"
                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                    <TextField fx:id="codeField" promptText="000000"
                               style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                      -fx-border-radius:10;-fx-background-radius:10;
                                      -fx-padding:12 14;-fx-font-size:24px;-fx-alignment:center;"/>
                </VBox>

                <Button fx:id="verifyButton" text="Verify Code" onAction="#handleVerify"
                        maxWidth="Infinity" prefHeight="48"
                        style="-fx-background-color:#2E7D32;-fx-text-fill:white;-fx-font-size:14px;
                               -fx-font-weight:bold;-fx-background-radius:12;-fx-cursor:hand;
                               -fx-border-color:transparent;"/>

                <HBox alignment="CENTER">
                    <Hyperlink text="← Back" onAction="#handleBack"
                               style="-fx-font-size:12px;-fx-text-fill:#2E7D32;-fx-border-color:transparent;"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</StackPane>
