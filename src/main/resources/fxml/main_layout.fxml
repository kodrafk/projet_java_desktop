<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainBorderPane" prefHeight="750.0" prefWidth="1250.0"
            style="-fx-background-color: #F6FBF7;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.projet.gui.MainLayoutController">

    <!-- ===================== TOP ===================== -->
    <top>
        <VBox style="-fx-background-color: #163A2E;">
            <HBox alignment="CENTER_LEFT" prefHeight="64"
                  style="-fx-background-color: #163A2E;">
                <padding>
                    <Insets top="0" right="22" bottom="0" left="22"/>
                </padding>

                <!-- Logo -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fitHeight="36" fitWidth="36" preserveRatio="true">
                        <image><Image url="@../images/logo.png"/></image>
                    </ImageView>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label text="Nutri Coach Pro"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Smart nutrition dashboard"
                               style="-fx-font-size: 10px; -fx-text-fill: #A7C4B8;"/>
                    </VBox>
                </HBox>

                <Region prefWidth="18"/>
                <Region prefWidth="1" prefHeight="34"
                        style="-fx-background-color: #2F5A4A; -fx-min-width: 1; -fx-max-width: 1;"/>
                <Region prefWidth="18"/>

                <!-- Navigation -->
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Button fx:id="btnHome" onAction="#handleHome"
                            prefHeight="36" prefWidth="110" text="Dashboard"
                            style="-fx-background-color: #2E7D5A; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>

                    <Button fx:id="btnDailyFood" onAction="#handleDailyFood"
                            prefHeight="36" prefWidth="110" text="Daily Food"
                            style="-fx-background-color: transparent; -fx-text-fill: #D7E6DF; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <MenuButton fx:id="btnMyKitchen"
                                prefHeight="36" prefWidth="110" text="My Kitchen"
                                style="-fx-background-color: transparent; -fx-text-fill: #D7E6DF; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;">
                        <items>
                            <MenuItem text="Ingredients" onAction="#handleIngredients"/>
                            <MenuItem text="Recipes" onAction="#handleRecipes"/>
                        </items>
                    </MenuButton>

                    <Button fx:id="btnBlog" onAction="#handleBlog"
                            prefHeight="36" prefWidth="80" text="Blog"
                            style="-fx-background-color: transparent; -fx-text-fill: #D7E6DF; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <Button fx:id="btnComplaints" onAction="#handleComplaints"
                            prefHeight="36" prefWidth="110" text="Complaints"
                            style="-fx-background-color: transparent; -fx-text-fill: #D7E6DF; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <Button fx:id="btnEvents" onAction="#handleEvents"
                            prefHeight="36" prefWidth="80" text="Events"
                            style="-fx-background-color: transparent; -fx-text-fill: #D7E6DF; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Right zone -->
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <VBox alignment="CENTER_RIGHT" spacing="1">
                        <Label text="Welcome back"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Sunday, Apr 5"
                               style="-fx-font-size: 10px; -fx-text-fill: #A7C4B8;"/>
                    </VBox>
                    <Button prefHeight="32" prefWidth="32" text="🔔"
                            style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"/>
                    <Button prefHeight="32" prefWidth="32" text="⚙"
                            style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"/>
                    <StackPane prefHeight="34" prefWidth="34"
                               style="-fx-background-color: #2E7D5A; -fx-background-radius: 17;">
                        <Label text="L"
                               style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </StackPane>
                    <Button prefHeight="32" prefWidth="86" text="Log Out"
                            style="-fx-background-color: #2E7D5A; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 11px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </HBox>

                <!-- Hidden buttons -->
                <VBox fx:id="submenuKitchen" managed="false" visible="false">
                    <Button fx:id="btnIngredients" onAction="#handleIngredients"
                            prefHeight="0" prefWidth="0" style="-fx-background-color: transparent;" text=""/>
                    <Button fx:id="btnRecipes" onAction="#handleRecipes"
                            prefHeight="0" prefWidth="0" style="-fx-background-color: transparent;" text=""/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- ===================== CENTER ===================== -->
    <center>
        <ScrollPane fx:id="mainScrollPane" fitToWidth="true" fitToHeight="false"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background: #F6FBF7; -fx-background-color: #F6FBF7; -fx-border-color: transparent;">

            <StackPane fx:id="contentArea" style="-fx-background-color: #F6FBF7;">

                <VBox fx:id="homeContent" spacing="24" style="-fx-background-color: #F6FBF7;">
                    <padding>
                        <Insets top="28" right="32" bottom="30" left="32"/>
                    </padding>

                    <!-- ══════════════════════════════════ -->
                    <!-- PAGE TITLE                         -->
                    <!-- ══════════════════════════════════ -->
                    <HBox alignment="CENTER_LEFT">
                        <VBox spacing="4">
                            <Label text="Dashboard"
                                   style="-fx-font-size: 25px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <Label text="Overview of your nutrition, kitchen and ethical management"
                                   style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="April 5, 2026"
                               style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 8 14; -fx-text-fill: #475569; -fx-font-size: 12px;"/>
                    </HBox>

                    <!-- ══════════════════════════════════ -->
                    <!-- STATS CARDS (4 cards)              -->
                    <!-- ══════════════════════════════════ -->
                    <HBox spacing="18">

                        <!-- Total Ingredients -->
                        <VBox prefWidth="270" prefHeight="122"
                              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #D6A46D; -fx-border-radius: 14; -fx-border-width: 1.2; -fx-padding: 18;">
                            <Label text="TOTAL INGREDIENTS"
                                   style="-fx-font-size: 11px; -fx-text-fill: #64748B; -fx-font-weight: bold;"/>
                            <Region VBox.vgrow="ALWAYS"/>
                            <Label fx:id="lblTotalIngredients" text="0"
                                   style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <Label text="Available in your kitchen"
                                   style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                        </VBox>

                        <!-- Total Recipes -->
                        <VBox prefWidth="270" prefHeight="122"
                              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #D6A46D; -fx-border-radius: 14; -fx-border-width: 1.2; -fx-padding: 18;">
                            <Label text="TOTAL RECIPES"
                                   style="-fx-font-size: 11px; -fx-text-fill: #64748B; -fx-font-weight: bold;"/>
                            <Region VBox.vgrow="ALWAYS"/>
                            <Label fx:id="lblTotalRecipes" text="0"
                                   style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <Label text="Recipes saved or created"
                                   style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                        </VBox>

                        <!-- Expired Items -->
                        <VBox prefWidth="270" prefHeight="122"
                              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #D6A46D; -fx-border-radius: 14; -fx-border-width: 1.2; -fx-padding: 18;">
                            <Label text="EXPIRED ITEMS"
                                   style="-fx-font-size: 11px; -fx-text-fill: #64748B; -fx-font-weight: bold;"/>
                            <Region VBox.vgrow="ALWAYS"/>
                            <Label fx:id="lblExpiredItems" text="0"
                                   style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #DC2626;"/>
                            <Label text="Need immediate attention"
                                   style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                        </VBox>

                        <!-- 🆕 Ethical Points Card -->
                        <VBox prefWidth="270" prefHeight="122"
                              style="-fx-background-color: #F0FFF4; -fx-background-radius: 14; -fx-border-color: #2ECC71; -fx-border-radius: 14; -fx-border-width: 1.2; -fx-padding: 18;">
                            <Label text="ETHICAL POINTS 🏆"
                                   style="-fx-font-size: 11px; -fx-text-fill: #27AE60; -fx-font-weight: bold;"/>
                            <Region VBox.vgrow="ALWAYS"/>
                            <Label fx:id="lblEthicalPoints" text="0"
                                   style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #27AE60;"/>
                            <Label fx:id="lblEthicalLevel" text="🌱 Beginner"
                                   style="-fx-font-size: 11px; -fx-text-fill: #27AE60;"/>
                        </VBox>

                    </HBox>

                    <!-- ══════════════════════════════════════════ -->
                    <!-- 🏆 ETHICAL POINTS + 🇵🇸 BOYCOTT CHECKER  -->
                    <!-- ══════════════════════════════════════════ -->
                    <GridPane hgap="20" vgap="20">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <!-- ══════════════════════ -->
                        <!-- 🏆 ETHICAL POINTS      -->
                        <!-- ══════════════════════ -->
                        <VBox spacing="16"
                              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 24;"
                              GridPane.columnIndex="0" GridPane.rowIndex="0">

                            <!-- Header -->
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <StackPane prefWidth="44" prefHeight="44"
                                           style="-fx-background-color: #E8F5EE; -fx-background-radius: 12;">
                                    <Label text="🏆" style="-fx-font-size: 22px;"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label text="Ethical Score"
                                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                    <Label text="Your ethical consumption progress"
                                           style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                </VBox>
                            </HBox>

                            <Separator/>

                            <!-- Level + Progress -->
                            <VBox spacing="10"
                                  style="-fx-background-color: #F0FFF4; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #A7F3D0; -fx-border-radius: 12;">
                                <HBox alignment="CENTER_LEFT">
                                    <Label fx:id="lblWidgetLevel" text="🌱 Beginner"
                                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblWidgetPoints" text="0 pts"
                                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #27AE60;"/>
                                </HBox>
                                <ProgressBar fx:id="progressEthical"
                                             progress="0"
                                             maxWidth="Infinity"
                                             prefHeight="14"
                                             style="-fx-accent: #2ECC71;"/>
                                <HBox alignment="CENTER_LEFT">
                                    <Label fx:id="lblProgressText" text="0% to next level"
                                           style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblEthicalPoints2" text="0 pts total"
                                           style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                                </HBox>
                            </VBox>

                            <!-- Badges -->
                            <VBox spacing="10">
                                <Label text="Achievement Badges"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>

                                <HBox spacing="14" alignment="CENTER">

                                    <!-- Badge 1 : First Scan -->
                                    <VBox fx:id="badgeBox1" alignment="CENTER" spacing="6"
                                          prefWidth="120" prefHeight="130"
                                          style="-fx-background-color: #F8FAFC; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 14;">
                                        <StackPane prefWidth="50" prefHeight="50"
                                                   style="-fx-background-color: #E8F5EE; -fx-background-radius: 25;">
                                            <Label text="📷" style="-fx-font-size: 24px;"/>
                                        </StackPane>
                                        <Label text="First Scan"
                                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                        <Label fx:id="badge1" text="🔒 Locked"
                                               style="-fx-font-size: 9px; -fx-text-fill: #94A3B8;"/>
                                    </VBox>

                                    <!-- Badge 2 : Palestine Supporter -->
                                    <VBox fx:id="badgeBox2" alignment="CENTER" spacing="6"
                                          prefWidth="120" prefHeight="130"
                                          style="-fx-background-color: #F8FAFC; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 14;">
                                        <StackPane prefWidth="50" prefHeight="50"
                                                   style="-fx-background-color: #FFF0F0; -fx-background-radius: 25;">
                                            <Label text="🛡️" style="-fx-font-size: 24px;"/>
                                        </StackPane>
                                        <Label text="Boycott Hero"
                                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                        <Label fx:id="badge2" text="🔒 Locked"
                                               style="-fx-font-size: 9px; -fx-text-fill: #94A3B8;"/>
                                    </VBox>

                                    <!-- Badge 3 : Eco Warrior -->
                                    <VBox fx:id="badgeBox3" alignment="CENTER" spacing="6"
                                          prefWidth="120" prefHeight="130"
                                          style="-fx-background-color: #F8FAFC; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 14;">
                                        <StackPane prefWidth="50" prefHeight="50"
                                                   style="-fx-background-color: #F0F9FF; -fx-background-radius: 25;">
                                            <Label text="🌍" style="-fx-font-size: 24px;"/>
                                        </StackPane>
                                        <Label text="Eco Warrior"
                                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                        <Label fx:id="badge3" text="🔒 Locked"
                                               style="-fx-font-size: 9px; -fx-text-fill: #94A3B8;"/>
                                    </VBox>

                                    <!-- Badge 4 : Health Expert -->
                                    <VBox fx:id="badgeBox4" alignment="CENTER" spacing="6"
                                          prefWidth="120" prefHeight="130"
                                          style="-fx-background-color: #F8FAFC; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 14;">
                                        <StackPane prefWidth="50" prefHeight="50"
                                                   style="-fx-background-color: #FFF7ED; -fx-background-radius: 25;">
                                            <Label text="🔬" style="-fx-font-size: 24px;"/>
                                        </StackPane>
                                        <Label text="Health Expert"
                                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                        <Label fx:id="badge4" text="🔒 Locked"
                                               style="-fx-font-size: 9px; -fx-text-fill: #94A3B8;"/>
                                    </VBox>

                                </HBox>
                            </VBox>

                        </VBox>

                        <!-- ══════════════════════ -->
                        <!-- 🇵🇸 BOYCOTT CHECKER   -->
                        <!-- ══════════════════════ -->
                        <VBox spacing="14"
                              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 20;"
                              GridPane.columnIndex="1" GridPane.rowIndex="0">

                            <!-- Header -->
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="🇵🇸"
                                       style="-fx-font-size: 22px;"/>
                                <VBox spacing="2">
                                    <Label text="Boycott Checker"
                                           style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                    <Label fx:id="lblBoycottTotal"
                                           text="90 brands in database"
                                           style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                </VBox>
                            </HBox>

                            <Separator/>

                            <!-- Search bar -->
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <TextField fx:id="txtBoycottSearch"
                                           promptText="🔍 Search a brand (e.g. Coca-Cola, Nestlé...)"
                                           HBox.hgrow="ALWAYS"
                                           prefHeight="42"
                                           style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12; -fx-font-size: 13px;"/>
                                <Button text="Search"
                                        onAction="#handleBoycottSearch"
                                        prefHeight="42" prefWidth="90"
                                        style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                            </HBox>

                            <!-- Results -->
                            <VBox fx:id="boycottResultsBox"
                                  spacing="8"
                                  style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-min-height: 180;">

                                <!-- Default state -->
                                <VBox alignment="CENTER" spacing="8" prefHeight="160">
                                    <Label text="🔍"
                                           style="-fx-font-size: 30px;"/>
                                    <Label text="Search a brand to check"
                                           style="-fx-font-size: 13px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                                    <Label text="Type a brand name and press Search"
                                           style="-fx-font-size: 11px; -fx-text-fill: #CBD5E1;"/>
                                </VBox>
                            </VBox>



                        </VBox>
                    </GridPane>



                    <!-- ══════════════════════════════════ -->
                    <!-- RECOMMENDATIONS                    -->
                    <!-- ══════════════════════════════════ -->
                    <VBox spacing="14">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Recommendations"
                                   style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="View all"
                                   style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                        </HBox>

                        <HBox spacing="18">
                            <VBox prefWidth="360"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 18; -fx-spacing: 10;">
                                <Label text="Healthy Avocado Bowl"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                <Label text="Trending recipe • 380 kcal"
                                       style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Button onAction="#handleRecipes" prefWidth="150" text="Open recipe"
                                        style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 12px; -fx-cursor: hand;"/>
                            </VBox>

                            <VBox prefWidth="360"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 18; -fx-spacing: 10;">
                                <Label text="Healthy Cooking Workshop"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                <Label text="Saturday 12 Apr • 10:00 AM"
                                       style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Button onAction="#handleEvents" prefWidth="150" text="See details"
                                        style="-fx-background-color: transparent; -fx-border-color: #1F4D3A; -fx-text-fill: #1F4D3A; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 12px; -fx-cursor: hand;"/>
                            </VBox>

                            <VBox prefWidth="360"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 18; -fx-spacing: 10;">
                                <Label text="Nutrition article of the week"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                <Label text="Reading time • 4 min"
                                       style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Button onAction="#handleBlog" prefWidth="150" text="Read article"
                                        style="-fx-background-color: #F59E0B; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 12px; -fx-cursor: hand;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                </VBox>
            </StackPane>
        </ScrollPane>
    </center>

</BorderPane>