<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainBorderPane" prefHeight="750.0" prefWidth="1250.0"
            style="-fx-background-color: #F6FBF7;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.projet.gui.MainLayoutController">

    <!-- ===================== TOP ===================== -->
    <top>
        <VBox style="-fx-background-color: #163A2E; -fx-border-color: transparent transparent #0F2A20 transparent; -fx-border-width: 0 0 2 0;">

            <HBox alignment="CENTER_LEFT" prefHeight="64"
                  style="-fx-background-color: #163A2E;">
                <padding>
                    <Insets top="0" right="22" bottom="0" left="22"/>
                </padding>

                <!-- Logo + branding -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fitHeight="36" fitWidth="36" preserveRatio="true">
                        <image>
                            <Image url="@../images/logo.png"/>
                        </image>
                    </ImageView>

                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label text="Nutri Coach Pro"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Smart nutrition dashboard"
                               style="-fx-font-size: 10px; -fx-text-fill: #A7C4B8;"/>
                    </VBox>
                </HBox>

                <!-- Divider -->
                <Region prefWidth="18"/>
                <Region prefWidth="1" prefHeight="34"
                        style="-fx-background-color: #2F5A4A; -fx-min-width: 1; -fx-max-width: 1;"/>
                <Region prefWidth="18"/>

                <!-- Navigation -->
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Button fx:id="btnHome" onAction="#handleHome"
                            prefHeight="36" prefWidth="110"
                            text="Dashboard"
                            style="-fx-background-color: #2E7D5A; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>

                    <Button fx:id="btnDailyFood" onAction="#handleDailyFood"
                            prefHeight="36" prefWidth="110"
                            text="Daily Food"
                            style="-fx-background-color: transparent; -fx-text-fill: #D7E6DF; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <MenuButton fx:id="btnMyKitchen"
                                prefHeight="36" prefWidth="110"
                                text="My Kitchen"
                                style="-fx-background-color: transparent; -fx-text-fill: #D7E6DF; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;">
                        <items>
                            <MenuItem text="Ingredients" onAction="#handleIngredients"/>
                            <MenuItem text="Recipes" onAction="#handleRecipes"/>
                        </items>
                    </MenuButton>

                    <Button fx:id="btnBlog" onAction="#handleBlog"
                            prefHeight="36" prefWidth="80"
                            text="Blog"
                            style="-fx-background-color: transparent; -fx-text-fill: #D7E6DF; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <Button fx:id="btnComplaints" onAction="#handleComplaints"
                            prefHeight="36" prefWidth="110"
                            text="Complaints"
                            style="-fx-background-color: transparent; -fx-text-fill: #D7E6DF; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <Button fx:id="btnEvents" onAction="#handleEvents"
                            prefHeight="36" prefWidth="80"
                            text="Events"
                            style="-fx-background-color: transparent; -fx-text-fill: #D7E6DF; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Right zone -->
                <HBox alignment="CENTER_RIGHT" spacing="10">

                    <VBox alignment="CENTER_RIGHT" spacing="1">
                        <Label text="Welcome back"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Sunday, Apr 5"
                               style="-fx-font-size: 10px; -fx-text-fill: #A7C4B8;"/>
                    </VBox>

                    <Button prefHeight="32" prefWidth="32"
                            text="🔔"
                            style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <Button prefHeight="32" prefWidth="32"
                            text="⚙"
                            style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <!-- Avatar -->
                    <StackPane prefHeight="34" prefWidth="34"
                               style="-fx-background-color: #2E7D5A; -fx-background-radius: 17;">
                        <Label text="L"
                               style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </StackPane>

                    <Button onAction="#handleProfile" prefHeight="32" prefWidth="86" text="Profile" style="-fx-background-color: transparent; -fx-text-fill: #163A2E; -fx-background-radius: 8; -fx-font-size: 11px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #2E7D5A; -fx-border-radius: 8;" />

                    <Button onAction="#handleLogout" prefHeight="32" prefWidth="86"
                            text="Log Out"
                            style="-fx-background-color: #2E7D5A; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 11px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </HBox>

                <!-- Hidden submenu -->
                <VBox fx:id="submenuKitchen" managed="false" visible="false" spacing="0">
                    <Button fx:id="btnIngredients" onAction="#handleIngredients"
                            prefHeight="0" prefWidth="0" style="-fx-background-color: transparent;" text=""/>
                    <Button fx:id="btnRecipes" onAction="#handleRecipes"
                            prefHeight="0" prefWidth="0" style="-fx-background-color: transparent;" text=""/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- ===================== CENTER ===================== -->
    <center>
        <ScrollPane fx:id="mainScrollPane" fitToWidth="true" fitToHeight="false"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background: #F6FBF7; -fx-background-color: #F6FBF7; -fx-border-color: transparent;">

            <StackPane fx:id="contentArea" style="-fx-background-color: #F6FBF7;">

                <VBox fx:id="homeContent" spacing="24" style="-fx-background-color: #F6FBF7;">
                    <padding>
                        <Insets top="28" right="32" bottom="30" left="32"/>
                    </padding>

                    <!-- Page title -->
                    <HBox alignment="CENTER_LEFT">
                        <VBox spacing="4">
                            <Label text="Dashboard"
                                   style="-fx-font-size: 25px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <Label text="Overview of your nutrition activity and kitchen management"
                                   style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="April 5, 2026"
                               style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 8 14; -fx-text-fill: #475569; -fx-font-size: 12px;"/>
                    </HBox>

                    <!-- Stats cards -->
                    <HBox spacing="18">

                        <VBox prefWidth="270" prefHeight="122"
                              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #D6A46D; -fx-border-radius: 14; -fx-border-width: 1.2; -fx-padding: 18;">
                            <Label text="TOTAL INGREDIENTS"
                                   style="-fx-font-size: 11px; -fx-text-fill: #64748B; -fx-font-weight: bold;"/>
                            <Region VBox.vgrow="ALWAYS"/>
                            <Label fx:id="lblTotalIngredients"
                                   text="0"
                                   style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <Label text="Available in your kitchen"
                                   style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                        </VBox>

                        <VBox prefWidth="270" prefHeight="122"
                              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #D6A46D; -fx-border-radius: 14; -fx-border-width: 1.2; -fx-padding: 18;">
                            <Label text="TOTAL RECIPES"
                                   style="-fx-font-size: 11px; -fx-text-fill: #64748B; -fx-font-weight: bold;"/>
                            <Region VBox.vgrow="ALWAYS"/>
                            <Label fx:id="lblTotalRecipes"
                                   text="0"
                                   style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <Label text="Recipes saved or created"
                                   style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                        </VBox>

                        <VBox prefWidth="270" prefHeight="122"
                              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #D6A46D; -fx-border-radius: 14; -fx-border-width: 1.2; -fx-padding: 18;">
                            <Label text="EXPIRED ITEMS"
                                   style="-fx-font-size: 11px; -fx-text-fill: #64748B; -fx-font-weight: bold;"/>
                            <Region VBox.vgrow="ALWAYS"/>
                            <Label fx:id="lblExpiredItems"
                                   text="0"
                                   style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #DC2626;"/>
                            <Label text="Need immediate attention"
                                   style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                        </VBox>

                        <VBox prefWidth="270" prefHeight="122"
                              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #D6A46D; -fx-border-radius: 14; -fx-border-width: 1.2; -fx-padding: 18;">
                            <Label text="TODAY CALORIES"
                                   style="-fx-font-size: 11px; -fx-text-fill: #64748B; -fx-font-weight: bold;"/>
                            <Region VBox.vgrow="ALWAYS"/>
                            <Label text="1 840"
                                   style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #F59E0B;"/>
                            <ProgressBar progress="0.72" prefWidth="220"
                                         style="-fx-accent: #1F4D3A;"/>
                            <Label text="72% of daily target"
                                   style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                        </VBox>

                    </HBox>

                    <!-- Main grid -->
                    <GridPane hgap="20" vgap="20">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <!-- Daily meals -->
                        <HBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14;"
                              GridPane.columnIndex="0" GridPane.rowIndex="0">

                            <Region prefWidth="6" style="-fx-background-color: #1F4D3A; -fx-background-radius: 14 0 0 14;"/>

                            <VBox spacing="16"
                                  style="-fx-padding: 20;"
                                  HBox.hgrow="ALWAYS">

                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Daily meals"
                                           style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label text="Today"
                                           style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                                </HBox>

                                <VBox spacing="8"
                                      style="-fx-background-color: #EDF7EE; -fx-background-radius: 12; -fx-padding: 14; -fx-border-color: #C8E6C9; -fx-border-radius: 12;">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <Label text="🌅" style="-fx-font-size: 20px;"/>
                                        <VBox spacing="3">
                                            <Label text="Petit-déjeuner"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                            <Label text="Flocons d'avoine, banane, amandes"
                                                   style="-fx-font-size: 11px; -fx-text-fill: #4A7A50;"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="420 kcal"
                                               style="-fx-background-color: #FF8C42; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 4 10; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                    </HBox>
                                </VBox>

                                <VBox spacing="8"
                                      style="-fx-background-color: #EDF7EE; -fx-background-radius: 12; -fx-padding: 14; -fx-border-color: #C8E6C9; -fx-border-radius: 12;">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <Label text="☀️" style="-fx-font-size: 20px;"/>
                                        <VBox spacing="3">
                                            <Label text="Déjeuner"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                            <Label text="Poulet grillé, quinoa, salade"
                                                   style="-fx-font-size: 11px; -fx-text-fill: #4A7A50;"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="680 kcal"
                                               style="-fx-background-color: #FF8C42; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 4 10; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                    </HBox>
                                </VBox>

                                <VBox spacing="8"
                                      style="-fx-background-color: #EDF7EE; -fx-background-radius: 12; -fx-padding: 14; -fx-border-color: #C8E6C9; -fx-border-radius: 12;">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <Label text="🌙" style="-fx-font-size: 20px;"/>
                                        <VBox spacing="3">
                                            <Label text="Dîner"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                            <Label text="Filet de saumon, légumes vapeur"
                                                   style="-fx-font-size: 11px; -fx-text-fill: #4A7A50;"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="740 kcal"
                                               style="-fx-background-color: #FF8C42; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 4 10; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                    </HBox>
                                </VBox>

                                <Button onAction="#handleDailyFood"
                                        prefWidth="260" prefHeight="40"
                                        text="Add a meal"
                                        style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                            </VBox>
                        </HBox>

                        <!-- Progress -->
                        <VBox spacing="16"
                              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 20;"
                              GridPane.columnIndex="1" GridPane.rowIndex="0">

                            <HBox alignment="CENTER_LEFT">
                                <Label text="Progress summary"
                                       style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="This month"
                                       style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                            </HBox>

                            <VBox spacing="6"
                                  style="-fx-background-color: #F8FAFC; -fx-background-radius: 12; -fx-padding: 16; -fx-border-color: #E2E8F0; -fx-border-radius: 12;">
                                <Label text="Tracking streak"
                                       style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                                <Label text="21 days"
                                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                <ProgressBar progress="0.70" prefWidth="480"
                                             style="-fx-accent: #1F4D3A;"/>
                                <Label text="Strong consistency this month"
                                       style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                            </VBox>

                            <Separator style="-fx-background-color: #E2E8F0;"/>

                            <VBox spacing="12">
                                <HBox alignment="CENTER_LEFT"
                                      style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                                    <Label text="Recipes tried this month"
                                           style="-fx-font-size: 13px; -fx-text-fill: #1E293B; -fx-font-weight: bold;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblTotalRecipes2"
                                           text="0"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1F4D3A;"/>
                                </HBox>

                                <HBox alignment="CENTER_LEFT"
                                      style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                                    <Label text="Ingredients in stock"
                                           style="-fx-font-size: 13px; -fx-text-fill: #1E293B; -fx-font-weight: bold;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblTotalIngredients2"
                                           text="0"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1F4D3A;"/>
                                </HBox>

                                <HBox alignment="CENTER_LEFT"
                                      style="-fx-background-color: #FFF7ED; -fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #FED7AA; -fx-border-radius: 10;">
                                    <Label text="Expired items"
                                           style="-fx-font-size: 13px; -fx-text-fill: #9A3412; -fx-font-weight: bold;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblExpiredItems2"
                                           text="0"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #DC2626;"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </GridPane>

                    <!-- Recommendations -->
                    <VBox spacing="14">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Recommendations"
                                   style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="View all"
                                   style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                        </HBox>

                        <HBox spacing="18">

                            <VBox prefWidth="360"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 18; -fx-spacing: 10;">
                                <Label text="Healthy Avocado Bowl"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                <Label text="Trending recipe • 380 kcal"
                                       style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Button onAction="#handleRecipes"
                                        prefWidth="150"
                                        text="Open recipe"
                                        style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 12px; -fx-cursor: hand;"/>
                            </VBox>

                            <VBox prefWidth="360"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 18; -fx-spacing: 10;">
                                <Label text="Healthy Cooking Workshop"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                <Label text="Saturday 12 Apr • 10:00 AM"
                                       style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Button onAction="#handleEvents"
                                        prefWidth="150"
                                        text="See details"
                                        style="-fx-background-color: transparent; -fx-border-color: #1F4D3A; -fx-text-fill: #1F4D3A; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 12px; -fx-cursor: hand;"/>
                            </VBox>

                            <VBox prefWidth="360"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 18; -fx-spacing: 10;">
                                <Label text="Nutrition article of the week"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                <Label text="Reading time • 4 min"
                                       style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Button onAction="#handleBlog"
                                        prefWidth="150"
                                        text="Read article"
                                        style="-fx-background-color: #F59E0B; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 12px; -fx-cursor: hand;"/>
                            </VBox>

                        </HBox>
                    </VBox>

                    <!-- Recent activity -->
                    <VBox spacing="14">
                        <Label text="Recent activity"
                               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>

                        <GridPane hgap="18" vgap="14">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints/>
                                <RowConstraints/>
                            </rowConstraints>

                            <HBox alignment="CENTER_LEFT" spacing="10"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-padding: 14;"
                                  GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <VBox spacing="3">
                                    <Label text="Mediterranean Salad"
                                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                    <Label text="2 days ago"
                                           style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="320 kcal"
                                       style="-fx-background-color: #FEF3C7; -fx-text-fill: #92400E; -fx-background-radius: 8; -fx-padding: 4 10; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="10"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-padding: 14;"
                                  GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <VBox spacing="3">
                                    <Label text="Blog post published"
                                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                    <Label text="3 days ago"
                                           style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Published"
