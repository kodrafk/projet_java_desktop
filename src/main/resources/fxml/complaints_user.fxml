<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>
<?import org.controlsfx.control.Rating?>

<VBox spacing="20" style="-fx-background-color: #F6FBF7; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.projet.gui.ComplaintsUserController">

    <!-- Header Section -->
    <VBox spacing="5">
        <Label text="My Complaints" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
        <Label text="Submit an issue or check the status of your previous complaints" style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
    </VBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- New Complaint Form -->
        <VBox spacing="15" prefWidth="350" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <Label text="Submit New Complaint" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1F4D3A;"/>
            
            <VBox spacing="5">
                <Label text="Title *" style="-fx-font-size: 12px; -fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="fldTitle" promptText="Enter complaint title" style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;"/>
            </VBox>
            
            <VBox spacing="5">
                <Label text="Phone Number" style="-fx-font-size: 12px; -fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="fldPhone" promptText="Enter phone number" style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;"/>
            </VBox>

            <HBox spacing="10">
                <VBox spacing="5" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                    <Label text="Rating (1-5) *" style="-fx-font-size: 12px; -fx-text-fill: #475569; -fx-font-weight: bold;"/>
                    <Rating fx:id="ratingControl" max="5" partialRating="false"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Incident Date *" style="-fx-font-size: 12px; -fx-text-fill: #475569; -fx-font-weight: bold;"/>
                    <DatePicker fx:id="dpDate" maxWidth="Infinity" style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                </VBox>
            </HBox>

            <VBox spacing="5" VBox.vgrow="ALWAYS">
                <Label text="Description *" style="-fx-font-size: 12px; -fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextArea fx:id="fldDescription" promptText="Describe the issue in detail..." wrapText="true" VBox.vgrow="ALWAYS" style="-fx-control-inner-background: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6;"/>
            </VBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Add Image" onAction="#handleSelectImage" style="-fx-background-color: #E2E8F0; -fx-text-fill: #1E293B; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 12;"/>
                <Label fx:id="lblImageName" text="" visible="false" managed="false" style="-fx-text-fill: #475569; -fx-font-size: 11px;"/>
            </HBox>

            <Label fx:id="lblError" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;" visible="false" managed="false"/>
            
            <Button fx:id="btnSubmit" onAction="#handleSubmit" text="Submit Complaint" maxWidth="Infinity" style="-fx-background-color: #2E7D5A; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-padding: 10; -fx-cursor: hand;"/>
        </VBox>

        <!-- Complaint History -->
        <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT">
                <Label text="Status tracking" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#handleRefresh" text="Refresh" style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>

            <TableView fx:id="tvComplaints" VBox.vgrow="ALWAYS" style="-fx-border-color: #E2E8F0; -fx-border-radius: 6;">
                <columns>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="120">
                        <cellValueFactory><PropertyValueFactory property="dateOfComplaint"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colTitle" text="Title" prefWidth="150">
                        <cellValueFactory><PropertyValueFactory property="title"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100">
                        <cellValueFactory><PropertyValueFactory property="status"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colResponse" text="Admin Response" prefWidth="250">
                        <cellValueFactory><PropertyValueFactory property="adminResponse"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

        </VBox>
    </HBox>

</VBox>
