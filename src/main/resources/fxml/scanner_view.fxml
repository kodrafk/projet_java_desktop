<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.projet.gui.ScannerController"
      spacing="15"
      style="-fx-background-color: #F5F5F5; -fx-padding: 20;">

    <!-- ============================= -->
    <!-- PARTIE GAUCHE : WEBCAM        -->
    <!-- ============================= -->
    <VBox spacing="15"
          prefWidth="380"
          style="-fx-background-color: white;
                 -fx-background-radius: 15;
                 -fx-padding: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">

        <!-- TITRE -->
        <Label text="📷 Scanner"
               style="-fx-font-size: 20px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #2C3E50;"/>

        <Separator/>

        <!-- FLUX WEBCAM -->
        <StackPane style="-fx-background-color: #2C3E50;
                          -fx-background-radius: 10;"
                   prefHeight="260">

            <!-- Image de la webcam -->
            <ImageView fx:id="webcamImageView"
                       fitWidth="340"
                       fitHeight="255"
                       preserveRatio="true"/>

            <!-- Overlay quand webcam inactive -->
            <VBox fx:id="cameraOffOverlay"
                  alignment="CENTER"
                  spacing="10">
                <Label text="📷"
                       style="-fx-font-size: 50px;"/>
                <Label text="Camera Off"
                       style="-fx-text-fill: white;
                              -fx-font-size: 14px;"/>
            </VBox>

            <!-- Cadre de scan animé -->
            <Rectangle fx:id="scanFrame"
                       width="200" height="150"
                       fill="transparent"
                       stroke="#2ECC71"
                       strokeWidth="3"
                       arcWidth="10" arcHeight="10"
                       visible="false"/>
        </StackPane>

        <!-- BOUTONS ACTIONS -->
        <VBox spacing="10">

            <!-- Bouton Démarrer/Arrêter caméra -->
            <Button fx:id="btnToggleCamera"
                    text="▶ Start Camera"
                    maxWidth="Infinity"
                    onAction="#toggleCamera"
                    style="-fx-background-color: #3498DB;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-padding: 10;
                           -fx-cursor: hand;"/>

            <!-- Bouton Scanner -->
            <Button fx:id="btnScan"
                    text="📷 Scan Barcode"
                    maxWidth="Infinity"
                    onAction="#scanBarcode"
                    disable="true"
                    style="-fx-background-color: #2ECC71;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-padding: 10;
                           -fx-cursor: hand;"/>

            <!-- Séparateur avec texte -->
            <HBox alignment="CENTER" spacing="10">
                <Separator HBox.hgrow="ALWAYS"/>
                <Label text="OR"
                       style="-fx-text-fill: #95A5A6;
                              -fx-font-size: 12px;"/>
                <Separator HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Saisie manuelle -->
            <HBox spacing="8">
                <TextField fx:id="manualBarcodeField"
                           promptText="Enter barcode manually..."
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #BDC3C7;
                                  -fx-padding: 8;"/>
                <Button text="✔"
                        onAction="#manualSearch"
                        style="-fx-background-color: #9B59B6;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-padding: 8 15;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <!-- STATUS BAR -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Circle fx:id="statusCircle" radius="6" fill="#E74C3C"/>
            <Label fx:id="statusLabel"
                   text="Camera inactive"
                   style="-fx-text-fill: #7F8C8D;
                          -fx-font-size: 12px;"/>
        </HBox>

    </VBox>

    <!-- ============================= -->
    <!-- PARTIE DROITE : RÉSULTATS     -->
    <!-- ============================= -->
    <ScrollPane HBox.hgrow="ALWAYS"
                fitToWidth="true"
                style="-fx-background: transparent;
                       -fx-background-color: transparent;">

        <VBox fx:id="resultsContainer"
              spacing="15">

            <!-- ========================= -->
            <!-- ÉTAT INITIAL : EN ATTENTE -->
            <!-- ========================= -->
            <VBox fx:id="waitingPane"
                  alignment="CENTER"
                  spacing="15"
                  prefHeight="500"
                  style="-fx-background-color: white;
                         -fx-background-radius: 15;
                         -fx-padding: 40;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                <Label text="📦"
                       style="-fx-font-size: 60px;"/>
                <Label text="Waiting for scan..."
                       style="-fx-font-size: 18px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #BDC3C7;"/>
                <Label text="Start the camera and scan a product"
                       style="-fx-font-size: 13px;
                              -fx-text-fill: #BDC3C7;"/>
            </VBox>

            <!-- ========================= -->
            <!-- INFO PRODUIT              -->
            <!-- ========================= -->
            <VBox fx:id="productInfoPane"
                  visible="false"
                  managed="false"
                  spacing="12"
                  style="-fx-background-color: white;
                         -fx-background-radius: 15;
                         -fx-padding: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">

                <Label text="📊 Product Information"
                       style="-fx-font-size: 16px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #2C3E50;"/>
                <Separator/>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <!-- Photo produit -->
                    <ImageView fx:id="productImage"
                               fitWidth="80"
                               fitHeight="80"
                               preserveRatio="true"
                               style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);"/>

                    <VBox spacing="5">
                        <Label fx:id="productName"
                               text="Product Name"
                               style="-fx-font-size: 16px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2C3E50;"/>
                        <Label fx:id="productBrand"
                               text="Brand"
                               style="-fx-font-size: 13px;
                                      -fx-text-fill: #7F8C8D;"/>
                        <Label fx:id="productBarcode"
                               text="Barcode"
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #95A5A6;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ========================= -->
            <!-- BOYCOTT STATUS            -->
            <!-- ========================= -->
            <VBox fx:id="boycottPane"
                  visible="false"
                  managed="false"
                  spacing="12"
                  style="-fx-background-color: white;
                         -fx-background-radius: 15;
                         -fx-padding: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">

                <Label text="🇵🇸 Boycott Status"
                       style="-fx-font-size: 16px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #2C3E50;"/>
                <Separator/>

                <!-- Badge statut -->
                <HBox fx:id="boycottBadge"
                      alignment="CENTER"
                      style="-fx-background-radius: 10;
                             -fx-padding: 15;">
                    <Label fx:id="boycottStatusLabel"
                           text="🔴 BOYCOTTED"
                           style="-fx-font-size: 18px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: white;"/>
                </HBox>

                <!-- Raison -->
                <VBox spacing="5"
                      style="-fx-background-color: #FAFAFA;
                             -fx-background-radius: 8;
                             -fx-padding: 12;">
                    <Label text="Reason:"
                           style="-fx-font-weight: bold;
                                  -fx-text-fill: #2C3E50;"/>
                    <Label fx:id="boycottReason"
                           text=""
                           wrapText="true"
                           style="-fx-text-fill: #7F8C8D;
                                  -fx-font-size: 12px;"/>
                </VBox>

                <!-- Alternatives -->
                <VBox fx:id="alternativesBox"
                      spacing="5"
                      visible="false"
                      managed="false"
                      style="-fx-background-color: #F0FFF4;
                             -fx-background-radius: 8;
                             -fx-padding: 12;
                             -fx-border-color: #2ECC71;
                             -fx-border-radius: 8;
                             -fx-border-width: 1;">
                    <Label text="💡 Alternatives:"
                           style="-fx-font-weight: bold;
                                  -fx-text-fill: #27AE60;"/>
                    <Label fx:id="alternativesLabel"
                           text=""
                           wrapText="true"
                           style="-fx-text-fill: #2C3E50;
                                  -fx-font-size: 12px;"/>
                </VBox>

            </VBox>

            <!-- ========================= -->
            <!-- ECO SCORE                 -->
            <!-- ========================= -->
            <VBox fx:id="ecoScorePane"
                  visible="false"
                  managed="false"
                  spacing="12"
                  style="-fx-background-color: white;
                         -fx-background-radius: 15;
                         -fx-padding: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">

                <Label text="🌍 Eco Score"
                       style="-fx-font-size: 16px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #2C3E50;"/>
                <Separator/>

                <!-- Lettres A B C D E -->
                <HBox spacing="8" alignment="CENTER">
                    <VBox fx:id="ecoA" alignment="CENTER" spacing="3"
                          prefWidth="55" prefHeight="60"
                          style="-fx-background-radius: 10; -fx-padding: 8;">
                        <Label text="A"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </VBox>
                    <VBox fx:id="ecoB" alignment="CENTER" spacing="3"
                          prefWidth="55" prefHeight="60"
                          style="-fx-background-radius: 10; -fx-padding: 8;">
                        <Label text="B"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </VBox>
                    <VBox fx:id="ecoC" alignment="CENTER" spacing="3"
                          prefWidth="55" prefHeight="60"
                          style="-fx-background-radius: 10; -fx-padding: 8;">
                        <Label text="C"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </VBox>
                    <VBox fx:id="ecoD" alignment="CENTER" spacing="3"
                          prefWidth="55" prefHeight="60"
                          style="-fx-background-radius: 10; -fx-padding: 8;">
                        <Label text="D"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </VBox>
                    <VBox fx:id="ecoE" alignment="CENTER" spacing="3"
                          prefWidth="55" prefHeight="60"
                          style="-fx-background-radius: 10; -fx-padding: 8;">
                        <Label text="E"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </VBox>
                </HBox>

                <Label fx:id="ecoScoreDesc"
                       text=""
                       wrapText="true"
                       style="-fx-text-fill: #7F8C8D;
                              -fx-font-size: 12px;"/>

            </VBox>

            <!-- ========================= -->
            <!-- INCI ANALYSE              -->
            <!-- ========================= -->
            <VBox fx:id="inciPane"
                  visible="false"
                  managed="false"
                  spacing="12"
                  style="-fx-background-color: white;
                         -fx-background-radius: 15;
                         -fx-padding: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">

                <Label text="🔬 INCI Analysis"
                       style="-fx-font-size: 16px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #2C3E50;"/>
                <Separator/>

                <!-- Score global -->
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Score:"
                           style="-fx-font-weight: bold;
                                  -fx-text-fill: #2C3E50;"/>
                    <Label fx:id="inciScoreLabel"
                           text="0/100"
                           style="-fx-font-size: 20px;
                                  -fx-font-weight: bold;"/>
                </HBox>

                <ProgressBar fx:id="inciProgressBar"
                             progress="0"
                             maxWidth="Infinity"
                             prefHeight="15"
                             style="-fx-accent: #2ECC71;"/>

                <!-- Liste des additifs -->
                <Label text="Detected Additives:"
                       style="-fx-font-weight: bold;
                              -fx-text-fill: #2C3E50;"/>

                <VBox fx:id="additivesList"
                      spacing="6"/>

                <!-- Warning -->
                <Label fx:id="inciWarning"
                       text=""
                       wrapText="true"
                       visible="false"
                       managed="false"
                       style="-fx-background-color: #FFF3CD;
                              -fx-background-radius: 8;
                              -fx-padding: 10;
                              -fx-text-fill: #856404;
                              -fx-font-size: 12px;"/>
                <!-- View INCI Details Button -->
                <Button fx:id="btnInciDetails"
                        text="📋 View INCI Details"
                        onAction="#openInciDetail"
                        maxWidth="Infinity"
                        visible="false"
                        managed="false"
                        style="-fx-background-color: #3498DB;
               -fx-text-fill: white;
               -fx-font-size: 12px;
               -fx-font-weight: bold;
               -fx-background-radius: 8;
               -fx-padding: 10;
               -fx-cursor: hand;"/>
            </VBox>

            <!-- ========================= -->
            <!-- BOUTONS ACTIONS FINALES   -->
            <!-- ========================= -->
            <HBox fx:id="actionButtons"
                  visible="false"
                  managed="false"
                  spacing="15">

                <Button text="❌ Reject"
                        onAction="#rejectProduct"
                        HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"
                        style="-fx-background-color: #E74C3C;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 12;
                               -fx-cursor: hand;"/>

                <Button text="✅ Add to Stock"
                        onAction="#addToStock"
                        HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"
                        style="-fx-background-color: #2ECC71;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 12;
                               -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </ScrollPane>

</HBox>