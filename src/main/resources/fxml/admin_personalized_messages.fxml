<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.projet.gui.AdminPersonalizedMessagesController"
           prefWidth="900" prefHeight="700"
           style="-fx-background-color:linear-gradient(to bottom right,#f0f9ff,#fefce8);">

    <VBox StackPane.alignment="TOP_CENTER" maxWidth="900" prefWidth="900">

        <!-- Header -->
        <HBox prefHeight="60" alignment="CENTER_LEFT"
              style="-fx-background-color:rgba(255,255,255,0.95);-fx-border-color:transparent transparent #E5E7EB transparent;-fx-border-width:0 0 1 0;-fx-padding:0 24;">
            <Label text="💬  Personalized Messages" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblUserInfo" text="Select a user to send a message" style="-fx-font-size:13px;-fx-text-fill:#64748B;"/>
            <Button text="✕" onAction="#handleClose"
                    style="-fx-background-color:transparent;-fx-text-fill:#94A3B8;-fx-font-size:18px;-fx-font-weight:bold;-fx-cursor:hand;-fx-border-color:transparent;-fx-padding:0 0 0 16;"
                    onMouseEntered="#handleCloseHover" onMouseExited="#handleCloseUnhover"/>
        </HBox>

        <HBox VBox.vgrow="ALWAYS" spacing="0">

            <!-- Left: User Selection -->
            <VBox prefWidth="280" style="-fx-background-color:white;-fx-border-color:transparent #E5E7EB transparent transparent;-fx-border-width:0 1 0 0;">
                
                <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:16 16 12 16;">
                    <Label text="👥 Users" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblUserCount" text="0 users" style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                </HBox>

                <TextField fx:id="txtSearchUser" promptText="🔍 Search users..."
                           style="-fx-background-color:#F8FAFC;-fx-border-color:#E5E7EB;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:8 12;-fx-font-size:12px;-fx-margin:0 16 12 16;"/>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                            style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;">
                    <VBox fx:id="userListContainer" spacing="4" style="-fx-padding:0 12 12 12;"/>
                </ScrollPane>
            </VBox>

            <!-- Right: Message Composer & History -->
            <VBox HBox.hgrow="ALWAYS" spacing="0">

                <!-- Message Composer -->
                <VBox spacing="14" style="-fx-padding:20;-fx-background-color:white;-fx-border-color:transparent transparent #E5E7EB transparent;-fx-border-width:0 0 1 0;">
                    
                    <Label text="✍️  Compose Message" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                    
                    <VBox spacing="6">
                        <Label text="Message content" style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#374151;"/>
                        <TextArea fx:id="txtMessageContent" promptText="Write a personalized message to motivate your user..."
                                  wrapText="true" prefRowCount="4"
                                  style="-fx-background-color:#F8FAFC;-fx-border-color:#E5E7EB;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:12;-fx-font-size:13px;"/>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label fx:id="lblCharCount" text="0 / 500" style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <CheckBox fx:id="chkSendSms" text="📱 Send via SMS" 
                                      style="-fx-font-size:12px;-fx-text-fill:#374151;-fx-font-weight:bold;"/>
                        </HBox>
                    </VBox>

                    <HBox spacing="10">
                        <Button text="📤  Send Message" onAction="#handleSendMessage"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="42"
                                style="-fx-background-color:#2E7D32;-fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;-fx-background-radius:10;-fx-cursor:hand;-fx-border-color:transparent;"/>
                        <Button text="🗑️" onAction="#handleClearMessage"
                                prefWidth="42" prefHeight="42"
                                style="-fx-background-color:#F8FAFC;-fx-text-fill:#64748B;-fx-font-size:16px;-fx-background-radius:10;-fx-cursor:hand;-fx-border-color:#E5E7EB;-fx-border-radius:10;"/>
                    </HBox>
                </VBox>

                <!-- Message History -->
                <VBox VBox.vgrow="ALWAYS" spacing="12" style="-fx-padding:20;-fx-background-color:#FAFBFC;">
                    
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="📋  Message History" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnRefreshHistory" text="🔄" onAction="#handleRefreshHistory"
                                style="-fx-background-color:#F8FAFC;-fx-text-fill:#64748B;-fx-font-size:14px;-fx-background-radius:6;-fx-cursor:hand;-fx-border-color:#E5E7EB;-fx-border-radius:6;-fx-padding:6 12;"/>
                    </HBox>

                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                                style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;">
                        <VBox fx:id="historyContainer" spacing="8"/>
                    </ScrollPane>
                </VBox>

            </VBox>

        </HBox>

    </VBox>
</StackPane>
