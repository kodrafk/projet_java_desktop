<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.projet.gui.GoogleAuthController"
      prefWidth="520" prefHeight="620" spacing="0"
      style="-fx-background-color:white;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color:#4285F4;-fx-padding:14 20;">
        <Label text="🌐" style="-fx-font-size:20px;"/>
        <Label text="Sign in with Google"
               style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:white;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕" onAction="#handleClose"
                style="-fx-background-color:transparent;-fx-text-fill:white;-fx-font-size:16px;
                       -fx-cursor:hand;-fx-border-color:transparent;"/>
    </HBox>

    <!-- Status / instructions -->
    <Label fx:id="statusLabel" text="Loading Google sign-in..." wrapText="true"
           style="-fx-font-size:12px;-fx-text-fill:#64748B;-fx-padding:8 16 4 16;"/>

    <!-- Spinner -->
    <HBox alignment="CENTER" style="-fx-padding:4 0;">
        <ProgressIndicator fx:id="spinner" prefWidth="24" prefHeight="24" visible="false"/>
    </HBox>

    <!-- WebView fills remaining space -->
    <WebView fx:id="webView" VBox.vgrow="ALWAYS"/>
</VBox>
