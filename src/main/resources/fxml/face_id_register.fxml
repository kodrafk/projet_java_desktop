<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.projet.gui.FaceIdRegisterController"
           prefWidth="580" prefHeight="660">

    <Pane style="-fx-background-color:linear-gradient(to bottom right,#e8f5e9,#fffde7,#fce4ec);"/>
    <Circle radius="22" fill="#66BB6A" opacity="0.5" StackPane.alignment="TOP_RIGHT" translateX="-30" translateY="40"/>
    <Circle radius="14" fill="#EF5350" opacity="0.4" StackPane.alignment="BOTTOM_LEFT" translateX="40" translateY="-40"/>

    <VBox spacing="0" StackPane.alignment="TOP_CENTER" maxWidth="Infinity">

        <!-- Header -->
        <HBox prefHeight="56" alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color:rgba(255,255,255,0.92);
                     -fx-border-color:transparent transparent #E8EDE8 transparent;
                     -fx-border-width:0 0 1 0;-fx-padding:0 24;">
            <Label text="🎭" style="-fx-font-size:20px;"/>
            <VBox spacing="1" HBox.hgrow="ALWAYS">
                <Label text="Face ID Enrollment"
                       style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                <Label fx:id="stepCounterLabel" text="Step 1 / 3"
                       style="-fx-font-size:11px;-fx-text-fill:#6B7280;"/>
            </VBox>
        </HBox>

        <ProgressBar fx:id="captureProgress" progress="0" maxWidth="Infinity" prefHeight="4"
                     style="-fx-accent:#2E7D32;-fx-background-color:#E8F5E9;"/>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                    style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;">
            <VBox alignment="TOP_CENTER" spacing="14"
                  style="-fx-background-color:transparent;-fx-padding:16 24 24 24;">

                <!-- Step instruction -->
                <VBox spacing="4"
                      style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:12 18;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),12,0,0,3);
                             -fx-border-color:#E8F5E9;-fx-border-radius:14;-fx-border-width:1;">
                    <Label fx:id="stepTitleLabel" text="Step 1 of 3 — Look Straight Ahead"
                           style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                    <Label fx:id="stepInstructionLabel" text="Position your face in front of the camera"
                           style="-fx-font-size:12px;-fx-text-fill:#6B7280;"/>
                </VBox>

                <!-- Live camera feed -->
                <StackPane style="-fx-background-color:#111827;-fx-background-radius:16;
                                  -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.15),16,0,0,4);">
                    <ImageView fx:id="cameraView" fitWidth="532" fitHeight="360"
                               preserveRatio="true" smooth="true"/>
                    <!-- Countdown overlay -->
                    <Label fx:id="countdownLabel" text=""
                           style="-fx-font-size:80px;-fx-font-weight:bold;-fx-text-fill:#4CAF50;
                                  -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.6),10,0,0,2);"/>
                </StackPane>

                <!-- Step dots -->
                <HBox alignment="CENTER" spacing="10">
                    <Circle fx:id="dot1" radius="6" fill="#2E7D32"/>
                    <Circle fx:id="dot2" radius="6" fill="#C8E6C9"/>
                    <Circle fx:id="dot3" radius="6" fill="#C8E6C9"/>
                </HBox>

                <!-- Status -->
                <Label fx:id="statusLabel" text="Opening camera..."
                       wrapText="true" maxWidth="532" alignment="CENTER"
                       style="-fx-font-size:12px;-fx-text-fill:#6B7280;-fx-alignment:center;"/>

                <!-- Buttons -->
                <HBox spacing="12">
                    <Button fx:id="startButton" text="▶  Capture" onAction="#handleCapture"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="46"
                            disable="true"
                            style="-fx-background-color:#2E7D32;-fx-text-fill:white;-fx-font-size:14px;
                                   -fx-font-weight:bold;-fx-background-radius:12;-fx-cursor:hand;"/>
                    <Button fx:id="cancelButton" text="Cancel" onAction="#handleCancel"
                            prefHeight="46" prefWidth="110"
                            style="-fx-background-color:white;-fx-text-fill:#6B7280;-fx-font-size:13px;
                                   -fx-background-radius:12;-fx-cursor:hand;
                                   -fx-border-color:#E2E8F0;-fx-border-width:1;-fx-border-radius:12;"/>
                </HBox>

                <!-- Info -->
                <VBox spacing="4"
                      style="-fx-background-color:#F0FDF4;-fx-background-radius:10;-fx-padding:12 16;
                             -fx-border-color:#BBF7D0;-fx-border-radius:10;-fx-border-width:1;">
                    <Label text="🤖  Powered by DeepFace ArcFace AI"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#166534;"/>
                    <Label text="State-of-the-art face recognition. 3 captures for maximum accuracy."
                           wrapText="true"
                           style="-fx-font-size:11px;-fx-text-fill:#166534;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</StackPane>
