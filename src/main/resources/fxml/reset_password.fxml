<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.projet.gui.ResetPasswordController"
           prefWidth="1100" prefHeight="720">

    <Pane style="-fx-background-color:linear-gradient(to bottom right,#e8f5e9,#fffde7,#fce4ec);"/>
    <Circle radius="24" fill="#66BB6A" opacity="0.6" StackPane.alignment="CENTER_LEFT" translateX="90" translateY="80"/>
    <Ellipse radiusX="26" radiusY="20" fill="#FFEE58" opacity="0.7" StackPane.alignment="BOTTOM_RIGHT" translateX="-90" translateY="-100"/>
    <Circle radius="14" fill="#EF5350" opacity="0.4" StackPane.alignment="TOP_LEFT" translateX="180" translateY="140"/>

    <VBox StackPane.alignment="TOP_CENTER" maxWidth="Infinity">
        <!-- Navbar -->
        <HBox prefHeight="60" alignment="CENTER_LEFT"
              style="-fx-background-color:rgba(255,255,255,0.9);-fx-border-color:transparent transparent #E8EDE8 transparent;-fx-border-width:0 0 1 0;-fx-padding:0 40;">
            <Label text="🥗 NutriLife" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Hyperlink text="Back to Login" onAction="#handleBackToLogin"
                       style="-fx-font-size:13px;-fx-text-fill:#2E7D32;-fx-border-color:transparent;"/>
        </HBox>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                    style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;">
            <VBox alignment="TOP_CENTER" style="-fx-background-color:transparent;-fx-padding:60 0 50 0;">

                <!-- Icon -->
                <StackPane prefWidth="64" prefHeight="64" alignment="CENTER">
                    <Label text="🔒" style="-fx-font-size:28px;"/>
                </StackPane>
                <Label text="" style="-fx-padding:0 0 8 0;"/>

                <Label text="Set New Password"
                       style="-fx-font-size:28px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                <Label text="Choose a strong password for your account"
                       style="-fx-font-size:13px;-fx-text-fill:#6B7280;-fx-padding:6 0 28 0;"/>

                <VBox spacing="16" prefWidth="440" maxWidth="440"
                      style="-fx-background-color:white;-fx-background-radius:20;-fx-padding:32 36;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.10),24,0,0,6);">

                    <!-- General error -->
                    <Label fx:id="errorLabel" text="" wrapText="true"
                           style="-fx-text-fill:#DC2626;-fx-font-size:12px;-fx-font-weight:bold;
                                  -fx-background-color:#FEF2F2;-fx-background-radius:8;-fx-padding:8 12;"/>

                    <!-- New password -->
                    <VBox spacing="4">
                        <Label text="New Password"
                               style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                        <PasswordField fx:id="passwordField" promptText="Minimum 8 characters"
                                       style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                              -fx-border-radius:10;-fx-background-radius:10;
                                              -fx-padding:12 14;-fx-font-size:13px;"/>
                        <Label fx:id="errPassword" text=""
                               style="-fx-text-fill:#DC2626;-fx-font-size:11px;"/>
                    </VBox>

                    <!-- Confirm password -->
                    <VBox spacing="4">
                        <Label text="Confirm Password"
                               style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="Repeat your new password"
                                       style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                              -fx-border-radius:10;-fx-background-radius:10;
                                              -fx-padding:12 14;-fx-font-size:13px;"/>
                        <Label fx:id="errConfirm" text=""
                               style="-fx-text-fill:#DC2626;-fx-font-size:11px;"/>
                    </VBox>

                    <!-- Password rules hint -->
                    <VBox spacing="3"
                          style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-padding:10 14;">
                        <Label text="Password requirements:"
                               style="-fx-font-size:11px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                        <Label text="• At least 8 characters"
                               style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                    </VBox>

                    <!-- Reset button -->
                    <Button fx:id="resetButton" text="Reset Password" onAction="#handleReset"
                            maxWidth="Infinity" prefHeight="48"
                            style="-fx-background-color:#2E7D32;-fx-text-fill:white;-fx-font-size:14px;
                                   -fx-font-weight:bold;-fx-background-radius:12;-fx-cursor:hand;
                                   -fx-border-color:transparent;"/>

                    <HBox alignment="CENTER">
                        <Hyperlink text="← Back to Login" onAction="#handleBackToLogin"
                                   style="-fx-font-size:12px;-fx-text-fill:#2E7D32;-fx-border-color:transparent;"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>
</StackPane>
