<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.projet.gui.ObjectiveEditActiveCustomController"
      style="-fx-background-color: #F6FBF7;" spacing="0">

    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #163A2E; -fx-padding: 20 32;">
        <VBox spacing="4">
            <Label text="Edit Active Plan"
                   style="-fx-font-size: 11px; -fx-text-fill: #A7C4B8; -fx-font-weight: bold;"/>
            <Label text="Edit Your Custom Targets"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="← Back" onAction="#handleBack"
                style="-fx-background-color: transparent; -fx-text-fill: #A7C4B8; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: #2F5A4A; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 16;"/>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background: #F6FBF7; -fx-background-color: #F6FBF7; -fx-border-color: transparent;">
        <StackPane style="-fx-background-color: #F6FBF7;">
        <VBox spacing="20" maxWidth="800" style="-fx-background-color: #F6FBF7;" alignment="CENTER">
            <padding><Insets top="24" right="32" bottom="32" left="32"/></padding>

            <!-- Active Warning -->
            <HBox alignment="TOP_LEFT" spacing="14"
                  style="-fx-background-color: #FFFBEB; -fx-background-radius: 12; -fx-padding: 16 20; -fx-border-color: #FDE68A; -fx-border-radius: 12; -fx-border-width: 1.5;">
                <Label text="⚠"
                       style="-fx-background-color: white; -fx-text-fill: #F59E0B; -fx-font-size: 16px; -fx-background-radius: 10; -fx-min-width: 36; -fx-min-height: 36; -fx-alignment: center;"/>
                <VBox spacing="4">
                    <Label text="This objective is currently active."
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #78350F;"/>
                    <Label text="Changes will take effect immediately. Your existing nutrition logs and progress will be preserved."
                           style="-fx-font-size: 12px; -fx-text-fill: #92400E; -fx-wrap-text: true;"/>
                </VBox>
            </HBox>

            <Label fx:id="lblError" text="" managed="false" visible="false"
                   style="-fx-background-color: #FEF2F2; -fx-text-fill: #991B1B; -fx-background-radius: 10; -fx-padding: 12 16; -fx-font-size: 13px; -fx-wrap-text: true;"/>

            <!-- Basic Info -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 28; -fx-border-color: #E2E8F0; -fx-border-radius: 14;" spacing="16">
                <Label text="Basic Information"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                <VBox spacing="6">
                    <Label text="Objective Title *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <TextField fx:id="titleField" prefHeight="42"
                               style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 12; -fx-font-size: 13px;"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Description" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <TextArea fx:id="descriptionField" prefHeight="80" wrapText="true"
                              style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 8 12; -fx-font-size: 13px;"/>
                </VBox>
            </VBox>

            <!-- Nutrition Targets -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 28; -fx-border-color: #E2E8F0; -fx-border-radius: 14;" spacing="16">
                <Label text="Daily Nutrition Targets"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                <GridPane hgap="16" vgap="16">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>
                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="🔥 Calories (kcal) *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="caloriesField" promptText="2000" prefHeight="42"
                                   style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 12; -fx-font-size: 13px;"/>
                        <Label text="500 – 5000 kcal" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                    </VBox>
                    <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="💪 Protein (g) *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="proteinField" promptText="150" prefHeight="42"
                                   style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 12; -fx-font-size: 13px;"/>
                        <Label text="10 – 300 g" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                    </VBox>
                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="🌾 Carbs (g) *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="carbsField" promptText="200" prefHeight="42"
                                   style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 12; -fx-font-size: 13px;"/>
                        <Label text="20 – 500 g" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                    </VBox>
                    <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label text="🥑 Fats (g) *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="fatsField" promptText="65" prefHeight="42"
                                   style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 12; -fx-font-size: 13px;"/>
                        <Label text="10 – 200 g" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                    </VBox>
                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <Label text="💧 Water (L)" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="waterField" promptText="2.5" prefHeight="42"
                                   style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 12; -fx-font-size: 13px;"/>
                        <Label text="0 – 10 L" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                    </VBox>
                </GridPane>
            </VBox>

            <!-- Actions -->
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Cancel" onAction="#handleBack"
                        style="-fx-background-color: white; -fx-text-fill: #374151; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px; -fx-padding: 12 24; -fx-cursor: hand;"/>
                <Button text="✓ Save Changes" onAction="#handleSave"
                        style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 12 24; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
        </StackPane>
    </ScrollPane>
</VBox>
