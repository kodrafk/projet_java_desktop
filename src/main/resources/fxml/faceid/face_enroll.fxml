<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.effect.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.projet.gui.faceid.FaceIDEnrollController"
            style="-fx-background-color: linear-gradient(to bottom, #064E3B, #065F46); -fx-background-radius: 20;">

    <!-- Header -->
    <top>
        <VBox alignment="CENTER" spacing="15" style="-fx-background-color: rgba(6, 78, 59, 0.8); -fx-padding: 30; -fx-background-radius: 20 20 0 0;">
            <effect>
                <DropShadow color="rgba(0,0,0,0.3)" radius="10" offsetY="5"/>
            </effect>
            
            <Label text="✨ Enroll Face ID" 
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.5), 10, 0, 0, 0);"/>
            
            <Label fx:id="statusLabel" 
                   text="Initializing camera..." 
                   style="-fx-font-size: 16px; -fx-text-fill: #A7F3D0; -fx-font-weight: 600;">
                <effect>
                    <Glow level="0.3"/>
                </effect>
            </Label>
        </VBox>
    </top>

    <!-- Center - Camera View -->
    <center>
        <VBox alignment="CENTER" spacing="25" style="-fx-padding: 40;">
            
            <!-- Camera Container with Green Glow -->
            <StackPane prefWidth="420" prefHeight="420"
                      style="-fx-background-color: #065F46; -fx-background-radius: 220; -fx-border-color: linear-gradient(to bottom, #10B981, #059669); -fx-border-width: 4; -fx-border-radius: 220;">
                
                <effect>
                    <DropShadow color="rgba(16,185,129,0.6)" radius="30" spread="0.3"/>
                </effect>
                
                <!-- Camera Feed -->
                <ImageView fx:id="cameraView" 
                          fitWidth="400" fitHeight="400" 
                          preserveRatio="false">
                    <clip>
                        <Circle radius="200" centerX="200" centerY="200"/>
                    </clip>
                </ImageView>
                
                <!-- Scanning Ring -->
                <Circle radius="200" 
                       stroke="linear-gradient(to bottom, rgba(16,185,129,0.8), rgba(5,150,105,0.8))" 
                       strokeWidth="3" 
                       fill="transparent"
                       strokeDashArray="15 5">
                    <effect>
                        <Glow level="0.9"/>
                    </effect>
                </Circle>
                
                <!-- Progress Indicator -->
                <ProgressIndicator fx:id="progressIndicator" 
                                  prefWidth="100" prefHeight="100"
                                  style="-fx-progress-color: #10B981;">
                    <effect>
                        <Glow level="0.8"/>
                    </effect>
                </ProgressIndicator>
            </StackPane>

            <!-- Instructions -->
            <HBox alignment="CENTER" spacing="10">
                <Label text="📸" style="-fx-font-size: 20px;"/>
                <Label fx:id="instructionLabel" 
                       text="Position your face in the circle" 
                       style="-fx-font-size: 15px; -fx-text-fill: #D1FAE5; -fx-font-weight: 500;"
                       wrapText="true" maxWidth="400"/>
            </HBox>

        </VBox>
    </center>

    <!-- Bottom - Action Buttons -->
    <bottom>
        <VBox spacing="15" style="-fx-background-color: rgba(6, 78, 59, 0.8); -fx-padding: 25; -fx-background-radius: 0 0 20 20;">
            <effect>
                <DropShadow color="rgba(0,0,0,0.3)" radius="10" offsetY="-5"/>
            </effect>
            
            <HBox alignment="CENTER" spacing="15">
                
                <Button fx:id="enrollButton" 
                        text="✅ Enroll Face" 
                        onAction="#handleEnroll"
                        style="-fx-background-color: linear-gradient(to bottom, #10B981, #059669); -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 14 40; -fx-background-radius: 25; -fx-cursor: hand;">
                    <effect>
                        <DropShadow color="rgba(16,185,129,0.6)" radius="15" spread="0.2"/>
                    </effect>
                </Button>
                
                <Button fx:id="cancelButton" 
                        text="✖️ Cancel" 
                        onAction="#handleCancel"
                        style="-fx-background-color: transparent; -fx-text-fill: #A7F3D0; -fx-font-size: 15px; -fx-font-weight: 600; -fx-padding: 12 35; -fx-border-color: #047857; -fx-border-width: 2; -fx-border-radius: 25; -fx-background-radius: 25; -fx-cursor: hand;"/>
            </HBox>
            
            <!-- Security Info -->
            <HBox alignment="CENTER" spacing="8" style="-fx-padding: 10 0 0 0;">
                <Label text="🛡️" style="-fx-font-size: 14px;"/>
                <Label text="Your face data is encrypted and secure" 
                       style="-fx-font-size: 12px; -fx-text-fill: #6EE7B7; -fx-font-style: italic;"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
