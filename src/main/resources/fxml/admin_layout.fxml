<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="780.0" prefWidth="1320.0"
            style="-fx-background-color: #F0F4F8;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.projet.gui.AdminLayoutController">

    <!-- ===================== SIDEBAR ===================== -->
    <left>
        <VBox prefWidth="230"
              style="-fx-background-color: #0F2820; -fx-border-color: transparent #0A1E16 transparent transparent; -fx-border-width: 0 1 0 0;">

            <HBox alignment="CENTER_LEFT" spacing="10" prefHeight="72"
                  style="-fx-padding: 16 16 16 16; -fx-background-color: #0A1E16;">
                <StackPane prefWidth="40" prefHeight="40"
                           style="-fx-background-color: #2E7D5A; -fx-background-radius: 10;">
                    <Label text="N" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Nutri Coach Pro" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Admin Panel" style="-fx-font-size: 10px; -fx-text-fill: #5A8A72;"/>
                </VBox>
            </HBox>

            <Label text="MAIN" style="-fx-text-fill: #4A7060; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 16 16 8 18;"/>
            <VBox spacing="2" style="-fx-padding: 0 10 0 10;">
                <Button fx:id="btnDashboard" text="Dashboard" onAction="#handleDashboard"
                        prefHeight="42" maxWidth="Infinity"
                        style="-fx-background-color: #2E7D5A; -fx-text-fill: white; -fx-font-size: 12.5px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
            </VBox>

            <Label text="MANAGEMENT" style="-fx-text-fill: #4A7060; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 14 16 8 18;"/>
            <VBox spacing="2" style="-fx-padding: 0 10 0 10;">
                <Button fx:id="btnUsers" text="Users" onAction="#handleUsers"
                        prefHeight="42" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12.5px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button fx:id="btnStatistics" text="Statistics" onAction="#handleStatistics"
                        prefHeight="42" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12.5px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button fx:id="btnObjectives" text="Objectives" onAction="#handleObjectives"
                        prefHeight="42" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12.5px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button fx:id="btnComplaints" text="📋 Complaints" onAction="#handleComplaints"
                        prefHeight="42" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12.5px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
            </VBox>

            <Label text="CONTENT" style="-fx-text-fill: #4A7060; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 14 16 8 18;"/>
            <VBox spacing="2" style="-fx-padding: 0 10 0 10;">
                <Button fx:id="btnIngredients" text="Ingredients" onAction="#handleIngredients"
                        prefHeight="42" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12.5px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button fx:id="btnRecipes" text="Recipes" onAction="#handleRecipes"
                        prefHeight="42" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12.5px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button fx:id="btnEvents" text="Events" onAction="#handleEvents"
                        prefHeight="42" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12.5px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button fx:id="btnBlogs" text="Blogs" onAction="#handleBlogs"
                        prefHeight="42" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12.5px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button fx:id="btnSponsors" text="Sponsors" onAction="#handleSponsors"
                        prefHeight="42" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12.5px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
            </VBox>

            <Label text="MODULES" style="-fx-text-fill: #4A7060; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 14 16 8 18;"/>
            <VBox spacing="2" style="-fx-padding: 0 10 0 10;">
                <Button fx:id="btnSMS" text="SMS" onAction="#handleSMS"
                        prefHeight="42" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12.5px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button fx:id="btnNutrition" text="Nutrition" onAction="#handleNutrition"
                        prefHeight="42" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12.5px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button fx:id="btnAnomalyDetection" text="🤖  AI Anomaly" onAction="#handleAnomalyDetection"
                        prefHeight="42" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12.5px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button fx:id="btnGroups" text="🫂  My Groups" onAction="#handleGroups"
                        prefHeight="42" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12.5px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8" style="-fx-padding: 12 12 16 12;">
                <Button text="← Back to Site" onAction="#handleBackToSite"
                        prefHeight="38" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button fx:id="btnLogout" text="Logout" onAction="#handleLogout"
                        prefHeight="38" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4B8; -fx-font-size: 12px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
            </VBox>
        </VBox>
    </left>

    <!-- ===================== MAIN CONTENT ===================== -->
    <center>
        <VBox style="-fx-background-color: #F0F4F8;">

            <!-- Dynamic Content Area -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" style="-fx-background-color: #F0F4F8;">
                <ScrollPane fx:id="dashboardScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="homeContent" spacing="20" style="-fx-background-color: #F0F4F8;">
                        <padding><Insets top="22" right="26" bottom="26" left="26"/></padding>

                        <!-- Welcome banner -->
                        <HBox alignment="CENTER_LEFT" prefHeight="112" spacing="0"
                              style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #E0E8F0; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">
                            <VBox spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 22 24;">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="Hello," style="-fx-font-size: 16px; -fx-text-fill: #475569;"/>
                                    <Label fx:id="lblAdminEmail" text="Admin 👋"
                                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                </HBox>
                                <Label text="Welcome to your Nutri Coach Pro dashboard."
                                       style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                            </VBox>
                            <VBox alignment="CENTER_RIGHT" spacing="4"
                                  style="-fx-padding: 22 28; -fx-background-color: #FAFCFE; -fx-background-radius: 0 16 16 0; -fx-border-color: transparent transparent transparent #E0E8F0; -fx-border-width: 0 0 0 1;">
                                <Label text="Today" style="-fx-font-size: 10px; -fx-text-fill: #94A3B8;"/>
                                <Label fx:id="lblDate" text="Loading..." style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                <Label fx:id="lblClock" text="00:00:00" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #2E7D5A;"/>
                            </VBox>
                        </HBox>

                        <!-- Stats cards -->
                        <HBox spacing="16">
                            <VBox prefHeight="140" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E0E8F0; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">
                                <HBox alignment="CENTER_LEFT">
                                    <StackPane prefWidth="38" prefHeight="38" style="-fx-background-color: #E8F5EE; -fx-background-radius: 10;">
                                        <Label text="👥" style="-fx-font-size: 16px;"/>
                                    </StackPane>
                                </HBox>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Label text="Total Users" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Label fx:id="lblTotalUsers" text="—" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            </VBox>
                            <VBox prefHeight="140" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E0E8F0; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">
                                <HBox alignment="CENTER_LEFT">
                                    <StackPane prefWidth="38" prefHeight="38" style="-fx-background-color: #EFF6FF; -fx-background-radius: 10;">
                                        <Label text="🥕" style="-fx-font-size: 16px;"/>
                                    </StackPane>
                                </HBox>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Label text="Ingredients" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Label fx:id="lblTotalIngredients" text="—" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            </VBox>
                            <VBox prefHeight="140" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E0E8F0; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">
                                <HBox alignment="CENTER_LEFT">
                                    <StackPane prefWidth="38" prefHeight="38" style="-fx-background-color: #FFF7ED; -fx-background-radius: 10;">
                                        <Label text="📋" style="-fx-font-size: 16px;"/>
                                    </StackPane>
                                </HBox>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Label text="Total Recipes" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Label fx:id="lblTotalRecipes" text="—" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            </VBox>
                            <VBox prefHeight="140" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E0E8F0; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">
                                <HBox alignment="CENTER_LEFT">
                                    <StackPane prefWidth="38" prefHeight="38" style="-fx-background-color: #FEF2F2; -fx-background-radius: 10;">
                                        <Label text="⚠" style="-fx-font-size: 16px;"/>
                                    </StackPane>
                                </HBox>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Label text="Complaints" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Label fx:id="lblTotalComplaints" text="—" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            </VBox>
                        </HBox>

                        <!-- Quick access -->
                        <HBox spacing="16">
                            <VBox HBox.hgrow="ALWAYS" spacing="10"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E0E8F0; -fx-border-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">
                                <Label text="Quick Actions" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                <HBox spacing="10">
                                    <Button text="👥 Manage Users" onAction="#handleUsers"
                                            style="-fx-background-color: #2E7D5A; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 16; -fx-font-size: 12px;"/>
                                    <Button text="📋 View Complaints" onAction="#handleComplaints"
                                            style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 16; -fx-font-size: 12px;"/>
                                    <Button text="🥕 Ingredients" onAction="#handleIngredients"
                                            style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 16; -fx-font-size: 12px;"/>
                                    <Button text="📊 Statistics" onAction="#handleStatistics"
                                            style="-fx-background-color: #7C3AED; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 16; -fx-font-size: 12px;"/>
                                </HBox>
                            </VBox>
                        </HBox>

                    </VBox>
                </ScrollPane>
            </StackPane>
        </VBox>
    </center>

</BorderPane>
