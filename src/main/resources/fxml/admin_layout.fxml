<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefWidth="1280" prefHeight="760"
            style="-fx-background-color: #F8FAFB;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.projet.gui.AdminLayoutController">

    <!-- ÔòÉÔòÉ SIDEBAR ÔòÉÔòÉ -->
    <left>
        <VBox prefWidth="200"
              style="-fx-background-color: #0D2B1F; -fx-min-height: 760;">

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10" prefHeight="64"
                  style="-fx-padding: 0 16; -fx-border-color: transparent transparent #1a3d2b transparent; -fx-border-width: 0 0 1 0;">
                <Label text="­ƒôù" style="-fx-font-size: 18px;"/>
                <Label text="Nutri Admin"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </HBox>

            <!-- MAIN section -->
            <Label text="MAIN" style="-fx-text-fill: #4a7060; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 16 0 6 16;"/>
            <VBox spacing="2" style="-fx-padding: 0 8;">
                <Button fx:id="btnDashboard" text="  Dashboard" onAction="#handleDashboard"
                        prefHeight="38" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8c4b8; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            </VBox>

            <!-- MANAGEMENT section -->
            <Label text="MANAGEMENT" style="-fx-text-fill: #4a7060; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 14 0 6 16;"/>
            <VBox spacing="2" style="-fx-padding: 0 8;">
                <Button fx:id="btnUsers" text="  Users" onAction="#handleUsers"
                        prefHeight="38" maxWidth="Infinity"
                        style="-fx-background-color: #1a4d35; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
                <Button fx:id="btnStatistics" text="  Statistics" onAction="#handleStatistics"
                        prefHeight="38" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8c4b8; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            </VBox>

            <!-- CONTENT section -->
            <Label text="CONTENT" style="-fx-text-fill: #4a7060; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 14 0 6 16;"/>
            <VBox spacing="2" style="-fx-padding: 0 8;">
                <Button fx:id="btnIngredients" text="  Ingredients" onAction="#handleIngredients"
                        prefHeight="38" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8c4b8; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
                <Button fx:id="btnRecipes" text="  Recipes" onAction="#handleRecipes"
                        prefHeight="38" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8c4b8; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
                <Button fx:id="btnEvents" text="  Events" onAction="#handleEvents"
                        prefHeight="38" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8c4b8; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
                <Button fx:id="btnSponsors" text="  Sponsors"
                        prefHeight="38" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8c4b8; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            </VBox>

            <!-- MODULES section -->
            <Label text="MODULES" style="-fx-text-fill: #4a7060; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 14 0 6 16;"/>
            <VBox spacing="2" style="-fx-padding: 0 8;">
                <Button text="  SMS"
                        prefHeight="38" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8c4b8; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
                <Button fx:id="btnBlogs" text="  Nutrition" onAction="#handleBlogs"
                        prefHeight="38" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8c4b8; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
                <Button text="  Wellness"
                        prefHeight="38" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8c4b8; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Bottom links -->
            <VBox spacing="2" style="-fx-padding: 0 8 16 8;">
                <Button text="  ÔåÉ Back to Site"
                        prefHeight="36" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8c4b8; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
                <Button text="  Logout" onAction="#handleLogout"
                        prefHeight="36" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8c4b8; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            </VBox>
        </VBox>
    </left>

    <!-- ÔòÉÔòÉ MAIN CONTENT ÔòÉÔòÉ -->
    <center>
        <VBox style="-fx-background-color: #F8FAFB;">

            <!-- Top header -->
            <HBox alignment="CENTER_LEFT" prefHeight="60" spacing="0"
                  style="-fx-background-color: white; -fx-border-color: transparent transparent #E8EEF2 transparent; -fx-border-width: 0 0 1 0; -fx-padding: 0 28;">
                <Label fx:id="lblPageTitle" text="User Management"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a7a4a;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Admin info top right -->
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <StackPane prefWidth="36" prefHeight="36"
                               style="-fx-background-color: #2E7D5A; -fx-background-radius: 18;">
                        <Label fx:id="lblAdminAvatar" text="A"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </StackPane>
                    <VBox spacing="1" alignment="CENTER_LEFT">
                        <Label fx:id="lblAdminEmail" text=""
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                        <Label text="ADMINISTRATOR PROFILE"
                               style="-fx-font-size: 9px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
            </HBox>

            <!-- Dynamic content area -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS">
                <ScrollPane fx:id="dashboardScrollPane" fitToWidth="true"
                            hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="homeContent" spacing="20"
                          style="-fx-background-color: #F8FAFB; -fx-padding: 28;">

                        <!-- Stats cards -->
                        <HBox spacing="16">
                            <VBox prefHeight="110" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E8EEF2; -fx-border-radius: 12; -fx-padding: 18;">
                                <Label text="Total Users" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Label fx:id="lblTotalUsers" text="0"
                                       style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            </VBox>
                            <VBox prefHeight="110" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E8EEF2; -fx-border-radius: 12; -fx-padding: 18;">
                                <Label text="Active" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Label fx:id="lblActiveUsers" text="0"
                                       style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #16A34A;"/>
                            </VBox>
                            <VBox prefHeight="110" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E8EEF2; -fx-border-radius: 12; -fx-padding: 18;">
                                <Label text="Inactive" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Label fx:id="lblInactiveUsers" text="0"
                                       style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #DC2626;"/>
                            </VBox>
                            <VBox prefHeight="110" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E8EEF2; -fx-border-radius: 12; -fx-padding: 18;">
                                <Label text="Admins" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Label fx:id="lblAdmins" text="0"
                                       style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #7C3AED;"/>
                            </VBox>
                            <VBox prefHeight="110" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E8EEF2; -fx-border-radius: 12; -fx-padding: 18;">
                                <Label text="New This Month" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Label fx:id="lblNewThisMonth" text="0"
                                       style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #0284C7;"/>
                            </VBox>
                        </HBox>

                        <!-- Quick actions -->
                        <HBox spacing="12">
                            <Button text="Manage Users" onAction="#handleUsers"
                                    prefHeight="38" prefWidth="150"
                                    style="-fx-background-color: #1a7a4a; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                            <Button text="+ Add New User" onAction="#handleAddUser"
                                    prefHeight="38" prefWidth="160"
                                    style="-fx-background-color: #0284C7; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                </ScrollPane>
            </StackPane>
        </VBox>
    </center>

</BorderPane>
