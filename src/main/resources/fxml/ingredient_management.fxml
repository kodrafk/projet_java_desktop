<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.effect.DropShadow?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.projet.gui.IngredientManagementController"
           style="-fx-background-color: #F0F4F8;">

    <!-- MAIN CONTENT -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #F0F4F8; -fx-background: #F0F4F8; -fx-border-color: transparent;">
        <VBox spacing="20">
            <padding><Insets top="24" right="28" bottom="28" left="28"/></padding>

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="16" prefHeight="90"
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #E0E8F0; -fx-border-radius: 16; -fx-padding: 20 24;">
                <effect><DropShadow color="rgba(0,0,0,0.08)" radius="12" offsetY="4"/></effect>

                <StackPane prefWidth="58" prefHeight="58"
                           style="-fx-background-color: linear-gradient(to bottom right, #1A5C40, #2E7D5A); -fx-background-radius: 14;">
                    <effect>
                        <DropShadow color="rgba(46,125,90,0.4)" radius="10" offsetY="4"/>
                    </effect>
                    <SVGPath content="M20 13H4c-.55 0-1 .45-1 1v6c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-6c0-.55-.45-1-1-1zM7 19c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm10 0c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm-7-11c0-1.1.9-2 2-2s2 .9 2 2v3h3c1.1 0 2 .9 2 2s-.9 2-2 2h-3v3c0 1.1-.9 2-2 2s-2-.9-2-2v-3H7c-1.1 0-2-.9-2-2s.9-2 2-2h3V8z"
                             fill="white" scaleX="1.4" scaleY="1.4"/>
                </StackPane>

                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Ingredient Management"
                           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-font-family: 'Segoe UI';"/>
                    <Label text="Manage your inventory, track expiration dates and optimize your stock"
                           style="-fx-font-size: 13px; -fx-text-fill: #64748B; -fx-font-family: 'Segoe UI';"/>
                </VBox>
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button fx:id="btnExpiryCalendar" onAction="#handleShowCalendar"
                            prefHeight="48" prefWidth="180"
                            style="-fx-background-color: white; -fx-text-fill: #1A5C40; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-border-color: #1A5C40; -fx-border-radius: 12; -fx-cursor: hand;">
                        <effect><DropShadow color="rgba(0,0,0,0.05)" radius="8" offsetY="3"/></effect>
                        <graphic>
                            <HBox alignment="CENTER" spacing="8">
                                <SVGPath content="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zM9 14H7v-2h2v2zm4 0h-2v-2h2v2zm4 0h-2v-2h2v2zm-8 4H7v-2h2v2zm4 0h-2v-2h2v2zm4 0h-2v-2h2v2z"
                                         fill="#1A5C40" scaleX="0.9" scaleY="0.9"/>
                                <Label text="Expiry Calendar" style="-fx-text-fill: #1A5C40; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                            </HBox>
                        </graphic>
                    </Button>

                    <Button fx:id="btnAddIngredient" text="+ New Ingredient" onAction="#handleAddNew"
                            prefHeight="48" prefWidth="180"
                            style="-fx-background-color: linear-gradient(to bottom, #2E7D5A, #1A5C40); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;"/>
                </HBox>
            </HBox>

            <!-- STATS CARDS -->
            <HBox spacing="18">
                <VBox prefHeight="110" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #E0E8F0; -fx-border-radius: 16; -fx-padding: 20;">
                    <effect><DropShadow color="rgba(0,0,0,0.05)" radius="8" offsetY="3"/></effect>
                    <HBox alignment="CENTER_LEFT" spacing="14">
                        <StackPane prefWidth="52" prefHeight="52"
                                   style="-fx-background-color: linear-gradient(to bottom right, #DCFCE7, #BBF7D0); -fx-background-radius: 12;">
                            <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"
                                     fill="#16A34A" scaleX="1.5" scaleY="1.5"/>
                        </StackPane>
                        <VBox spacing="4">
                            <Label text="TOTAL INGREDIENTS" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label fx:id="lblTotalCount" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                <Label text="items" style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>
                <VBox prefHeight="110" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #E0E8F0; -fx-border-radius: 16; -fx-padding: 20;">
                    <effect><DropShadow color="rgba(0,0,0,0.05)" radius="8" offsetY="3"/></effect>
                    <HBox alignment="CENTER_LEFT" spacing="14">
                        <StackPane prefWidth="52" prefHeight="52"
                                   style="-fx-background-color: linear-gradient(to bottom right, #FEF3C7, #FDE68A); -fx-background-radius: 12;">
                            <SVGPath content="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"
                                     fill="#F59E0B" scaleX="1.5" scaleY="1.5"/>
                        </StackPane>
                        <VBox spacing="4">
                            <Label text="EXPIRING SOON" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label fx:id="lblExpiringSoon" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #F59E0B;"/>
                                <Label text="⚠ warning" style="-fx-font-size: 11px; -fx-text-fill: #F59E0B;"/>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>
                <VBox prefHeight="110" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #E0E8F0; -fx-border-radius: 16; -fx-padding: 20;">
                    <effect><DropShadow color="rgba(0,0,0,0.05)" radius="8" offsetY="3"/></effect>
                    <HBox alignment="CENTER_LEFT" spacing="14">
                        <StackPane prefWidth="52" prefHeight="52"
                                   style="-fx-background-color: linear-gradient(to bottom right, #FEE2E2, #FECACA); -fx-background-radius: 12;">
                            <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                                     fill="#DC2626" scaleX="1.5" scaleY="1.5"/>
                        </StackPane>
                        <VBox spacing="4">
                            <Label text="EXPIRED" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label fx:id="lblExpired" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #DC2626;"/>
                                <Label text="✗ to discard" style="-fx-font-size: 11px; -fx-text-fill: #DC2626;"/>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>
                <VBox prefHeight="110" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #E0E8F0; -fx-border-radius: 16; -fx-padding: 20;">
                    <effect><DropShadow color="rgba(0,0,0,0.05)" radius="8" offsetY="3"/></effect>
                    <HBox alignment="CENTER_LEFT" spacing="14">
                        <StackPane prefWidth="52" prefHeight="52"
                                   style="-fx-background-color: linear-gradient(to bottom right, #DBEAFE, #BFDBFE); -fx-background-radius: 12;">
                            <SVGPath content="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                                     fill="#3B82F6" scaleX="1.4" scaleY="1.4"/>
                        </StackPane>
                        <VBox spacing="4">
                            <Label text="CATEGORIES" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label fx:id="lblCategoriesCount" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;"/>
                                <Label text="types" style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>
            </HBox>

            <!-- SEARCH & FILTERS BAR -->
            <HBox alignment="CENTER_LEFT" spacing="14" prefHeight="70"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E0E8F0; -fx-border-radius: 14; -fx-padding: 16 20;">
                <effect><DropShadow color="rgba(0,0,0,0.04)" radius="6" offsetY="2"/></effect>
                <HBox alignment="CENTER_LEFT" spacing="10" prefWidth="340" prefHeight="42"
                      style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-padding: 0 14;">
                    <TextField fx:id="txtSearch" promptText="🔍 Search by name..."
                               prefHeight="38" HBox.hgrow="ALWAYS"
                               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px; -fx-text-fill: #475569;"/>
                </HBox>
                <Separator orientation="VERTICAL" prefHeight="30"/>
                <VBox spacing="4">
                    <Label text="CATEGORY" style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                    <ComboBox fx:id="cmbFilterCategory" promptText="All" prefWidth="180" prefHeight="36"
                              style="-fx-font-size: 12px; -fx-background-radius: 8;"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="SORT BY" style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                    <ComboBox fx:id="cmbSortBy" promptText="Name (A-Z)" prefWidth="160" prefHeight="36"
                              style="-fx-font-size: 12px; -fx-background-radius: 8;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="↻" onAction="#handleRefresh" prefHeight="40" prefWidth="40"
                        style="-fx-background-color: #F1F5F9; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-size: 16px;"/>
                <Button text="📥 Export" onAction="#handleExport" prefHeight="40" prefWidth="110"
                        style="-fx-background-color: transparent; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>

            <!-- DATA TABLE -->
            <VBox prefHeight="400" spacing="0"
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #E0E8F0; -fx-border-radius: 16;">
                <effect><DropShadow color="rgba(0,0,0,0.06)" radius="10" offsetY="4"/></effect>
                <padding><Insets top="20" right="20" bottom="16" left="20"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 16 0;">
                    <Label text="Ingredient List"
                           style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblTableInfo" text="Showing 0 ingredients"
                           style="-fx-font-size: 12px; -fx-text-fill: #94A3B8; -fx-padding: 6 12; -fx-background-color: #F8FAFC; -fx-background-radius: 6;"/>
                </HBox>
                <TableView fx:id="tableIngredients" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-color: #F1F5F9; -fx-border-radius: 10;">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colNom" text="Ingredient" prefWidth="180" minWidth="150"/>
                        <TableColumn fx:id="colCategorie" text="Category" prefWidth="140" minWidth="120" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colQuantite" text="Quantity" prefWidth="100" minWidth="80" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colDatePeremption" text="Expiry Date" prefWidth="120" minWidth="100" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="130" minWidth="100" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colNotes" text="Notes" prefWidth="160" minWidth="120"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="180" minWidth="160" style="-fx-alignment: CENTER;" sortable="false"/>
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="16" style="-fx-padding: 60;">
                            <Label text="No ingredients found"
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                            <Label text="Click 'New Ingredient' to add your first item"
                                   style="-fx-font-size: 13px; -fx-text-fill: #94A3B8;"/>
                            <Button text="+ Add now" onAction="#handleAddNew"
                                    style="-fx-background-color: #2E7D5A; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                        </VBox>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- ★ NEW: AI SUBSTITUTION SECTION -->
            <VBox spacing="0"
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #E0E8F0; -fx-border-radius: 16;">
                <effect><DropShadow color="rgba(0,0,0,0.06)" radius="10" offsetY="4"/></effect>
                <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

                <!-- Section Header -->
                <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 0 0 18 0;">
                    <StackPane prefWidth="46" prefHeight="46"
                               style="-fx-background-color: linear-gradient(to bottom right, #EDE9FE, #DDD6FE); -fx-background-radius: 12;">
                        <Label text="🤖" style="-fx-font-size: 22px;"/>
                    </StackPane>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="AI Smart Substitution"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                        <Label text="Find intelligent substitutes for out-of-stock ingredients using AI"
                               style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                    </VBox>
                </HBox>

                <!-- Controls -->
                <HBox spacing="14" alignment="CENTER_LEFT" style="-fx-padding: 0 0 18 0;">
                    <VBox spacing="5">
                        <Label text="OUT OF STOCK INGREDIENT" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                        <ComboBox fx:id="cmbOutOfStock" promptText="Select ingredient..." prefWidth="300" prefHeight="42"
                                  style="-fx-font-size: 13px; -fx-background-radius: 10;"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text=" " style="-fx-font-size: 10px;"/>
                        <Button fx:id="btnFindSubstitutes" text="🔍 Find Substitutes" onAction="#handleFindSubstitutes"
                                prefHeight="42" prefWidth="200"
                                style="-fx-background-color: linear-gradient(to bottom, #7C3AED, #6D28D9); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;">
                            <effect><DropShadow color="rgba(124,58,237,0.4)" radius="8" offsetY="3"/></effect>
                        </Button>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <!-- Loading indicator -->
                    <HBox fx:id="loadingBox" visible="false" managed="false" alignment="CENTER" spacing="10">
                        <ProgressIndicator prefWidth="28" prefHeight="28"/>
                        <Label text="AI is analyzing..." style="-fx-font-size: 12px; -fx-text-fill: #7C3AED; -fx-font-weight: bold;"/>
                    </HBox>
                </HBox>

                <!-- Results Container -->
                <VBox fx:id="substitutionResults" spacing="10" style="-fx-padding: 0;">
                    <!-- Will be populated dynamically -->
                </VBox>
            </VBox>

            <!-- ★ NEW: SHOPPING LIST SECTION -->
            <VBox spacing="0"
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #E0E8F0; -fx-border-radius: 16;">
                <effect><DropShadow color="rgba(0,0,0,0.06)" radius="10" offsetY="4"/></effect>
                <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

                <!-- Section Header -->
                <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 0 0 18 0;">
                    <StackPane prefWidth="46" prefHeight="46"
                               style="-fx-background-color: linear-gradient(to bottom right, #FEF3C7, #FDE68A); -fx-background-radius: 12;">
                        <Label text="🛒" style="-fx-font-size: 22px;"/>
                    </StackPane>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Shopping List"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                        <Label fx:id="lblShoppingCount" text="0 items to buy"
                               style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                    </VBox>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="🧹 Clear Purchased" onAction="#handleClearPurchased"
                                prefHeight="38"
                                style="-fx-background-color: #FEF3C7; -fx-text-fill: #92400E; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="📄 Export PDF" onAction="#handleExportShoppingList"
                                prefHeight="38"
                                style="-fx-background-color: transparent; -fx-border-color: #CBD5E1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </HBox>
                </HBox>

                <!-- Shopping List Container -->
                <VBox fx:id="shoppingListContainer" spacing="8" style="-fx-padding: 0;">
                    <!-- Empty state (shown when no items) -->
                    <HBox fx:id="emptyShoppingState" alignment="CENTER" spacing="10"
                          style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-padding: 30;">
                        <VBox alignment="CENTER" spacing="8">
                            <Label text="🛒" style="-fx-font-size: 32px;"/>
                            <Label text="Your shopping list is empty"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #94A3B8;"/>
                            <Label text="Items will appear here when no substitute is found"
                                   style="-fx-font-size: 12px; -fx-text-fill: #CBD5E1;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- MODAL FORM OVERLAY (UNCHANGED) -->
    <StackPane fx:id="formOverlay" visible="false" managed="false"
               style="-fx-background-color: rgba(15, 23, 42, 0.78);">
        <VBox spacing="0" maxWidth="660" maxHeight="680"
              style="-fx-background-color: white; -fx-background-radius: 20;">
            <effect><DropShadow color="rgba(0,0,0,0.5)" radius="50" offsetY="15"/></effect>

            <HBox alignment="CENTER_LEFT" spacing="14" prefHeight="70"
                  style="-fx-background-color: linear-gradient(to right, #1A5C40, #2E7D5A, #3D9970); -fx-background-radius: 20 20 0 0; -fx-padding: 0 24;">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblFormTitle" text="Add Ingredient"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Fill in the information below"
                           style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.8);"/>
                </VBox>
                <Button text="✕" onAction="#handleCloseForm" prefWidth="36" prefHeight="36"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 10; -fx-cursor: hand; -fx-text-fill: white; -fx-font-size: 14px;"/>
            </HBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="530"
                        style="-fx-background-color: white; -fx-background: white; -fx-border-color: transparent;">
                <VBox spacing="22" style="-fx-padding: 28;">

                    <Label fx:id="lblError" text="" managed="false" visible="false" wrapText="true"
                           style="-fx-text-fill: #DC2626; -fx-font-size: 12px; -fx-background-color: #FEE2E2; -fx-background-radius: 8; -fx-padding: 10 14; -fx-border-color: #FECACA; -fx-border-radius: 8;"/>

                    <VBox spacing="14">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <StackPane prefWidth="24" prefHeight="24"
                                       style="-fx-background-color: #DCFCE7; -fx-background-radius: 6;">
                                <Label text="1" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #16A34A;"/>
                            </StackPane>
                            <Label text="Required Information"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                        </HBox>

                        <GridPane hgap="16" vgap="16" style="-fx-padding: 0 0 0 32;">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>

                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Name *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <TextField fx:id="txtNom" promptText="e.g. Cherry tomatoes"
                                           prefHeight="42"
                                           style="-fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 10; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-color: #FAFAFA;"/>
                                <Label fx:id="lblNomError" text="" style="-fx-font-size: 11px; -fx-text-fill: #DC2626;" visible="false" managed="false"/>
                            </VBox>

                            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Category *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <ComboBox fx:id="cmbCategorie" promptText="Select category..."
                                          prefHeight="42" maxWidth="Infinity"
                                          style="-fx-font-size: 13px; -fx-background-radius: 10;"/>
                                <Label fx:id="lblCategorieError" text="" style="-fx-font-size: 11px; -fx-text-fill: #DC2626;" visible="false" managed="false"/>
                            </VBox>

                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label text="Quantity *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <TextField fx:id="txtQuantite" promptText="e.g. 1.5"
                                           prefHeight="42"
                                           style="-fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 10; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-color: #FAFAFA;"/>
                                <Label fx:id="lblQuantiteError" text="" style="-fx-font-size: 11px; -fx-text-fill: #DC2626;" visible="false" managed="false"/>
                            </VBox>

                            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        </GridPane>
                    </VBox>

                    <Separator style="-fx-background-color: #E5E7EB;"/>

                    <VBox spacing="14">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <StackPane prefWidth="24" prefHeight="24"
                                       style="-fx-background-color: #DBEAFE; -fx-background-radius: 6;">
                                <Label text="2" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;"/>
                            </StackPane>
                            <Label text="Optional Information"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                        </HBox>

                        <GridPane hgap="16" vgap="16" style="-fx-padding: 0 0 0 32;">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>

                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Unit" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <ComboBox fx:id="cmbUnite" promptText="Select unit..."
                                          prefHeight="42" maxWidth="Infinity"
                                          style="-fx-font-size: 13px; -fx-background-radius: 10;"/>
                            </VBox>

                            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Expiry Date (≥ today)" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <DatePicker fx:id="datePeremption" promptText="MM/DD/YYYY"
                                            prefHeight="42" maxWidth="Infinity"
                                            style="-fx-font-size: 13px; -fx-background-radius: 10;"/>
                                <Label fx:id="lblDateError" text="" style="-fx-font-size: 11px; -fx-text-fill: #DC2626;" visible="false" managed="false"/>
                            </VBox>

                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label text="Image URL" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <TextField fx:id="txtImage" promptText="https://..."
                                           prefHeight="42"
                                           style="-fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 10; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-color: #FAFAFA;"/>
                            </VBox>

                            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label text="Notes" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <TextArea fx:id="txtNotes" promptText="Origin, supplier, allergens..."
                                          prefRowCount="2"
                                          style="-fx-font-size: 13px; -fx-background-radius: 10; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-color: #FAFAFA;"/>
                            </VBox>
                        </GridPane>
                    </VBox>

                </VBox>
            </ScrollPane>

            <HBox spacing="12" alignment="CENTER_RIGHT" prefHeight="70"
                  style="-fx-padding: 0 24; -fx-background-color: #F9FAFB; -fx-background-radius: 0 0 20 20; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0;">
                <Label text="* Required fields" HBox.hgrow="ALWAYS"
                       style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                <Button text="Cancel" onAction="#handleCloseForm"
                        prefHeight="42" prefWidth="110"
                        style="-fx-background-color: white; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #374151; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button fx:id="btnSaveIngredient" text="Save" onAction="#handleSaveIngredient"
                        prefHeight="42" prefWidth="140"
                        style="-fx-background-color: linear-gradient(to bottom, #2E7D5A, #1A5C40); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </StackPane>

</StackPane>