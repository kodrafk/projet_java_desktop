<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.effect.DropShadow?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.projet.gui.RecipeManagementController"
           style="-fx-background-color: #F0F4F8;">

    <!-- MAIN CONTENT -->
    <VBox spacing="20">
        <padding>
            <Insets top="24" right="28" bottom="28" left="28"/>
        </padding>

        <!-- HEADER SECTION -->
        <HBox alignment="CENTER_LEFT" spacing="16" prefHeight="90"
              style="-fx-background-color: white;
                     -fx-background-radius: 16;
                     -fx-border-color: #E0E8F0;
                     -fx-border-radius: 16;
                     -fx-padding: 20 24;">
            <effect>
                <DropShadow color="#00000014" radius="12" offsetY="4"/>
            </effect>

            <!-- Icon -->
            <StackPane prefWidth="58" prefHeight="58"
                       style="-fx-background-color: linear-gradient(to bottom right, #1A5C40, #2E7D5A);
                              -fx-background-radius: 14;">
                <effect>
                    <DropShadow color="#2E7D5A66" radius="10" offsetY="4"/>
                </effect>
                <SVGPath content="M18.06 22.99h1.66c.84 0 1.53-.64 1.63-1.46L23 5.05h-5V1h-1v4h-1V1h-1v4h-1V1H9v4H4v16.28c0 .8.59 1.46 1.4 1.46h1.66l-1.44 2.88c-.26.52.11 1.12.68 1.12h1.8c.21 0 .41-.1.54-.27l1.31-1.73h4.1l1.31 1.73c.13.17.33.27.54.27h1.8c.57 0 .94-.6.68-1.12l-1.44-2.88zM9 9h10v8H9V9z"
                         fill="white" scaleX="1.4" scaleY="1.4"/>
            </StackPane>

            <!-- Title -->
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Recipe Management"
                       style="-fx-font-size: 26px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1E293B;
                              -fx-font-family: 'Segoe UI';"/>
                <Label text="Create, organize and share your best culinary recipes"
                       style="-fx-font-size: 13px;
                              -fx-text-fill: #64748B;
                              -fx-font-family: 'Segoe UI';"/>
            </VBox>

            <!-- Action Buttons -->
            <HBox spacing="12" alignment="CENTER_RIGHT">

                <!-- Generate with AI -->
                <Button onAction="#handleOpenAIGenerator"
                        prefHeight="48" prefWidth="170"
                        style="-fx-background-color: white;
                               -fx-text-fill: #7C3AED;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 12;
                               -fx-border-color: #7C3AED;
                               -fx-border-radius: 12;
                               -fx-cursor: hand;">
                    <effect>
                        <DropShadow color="rgba(0,0,0,0.05)" radius="8" offsetY="3"/>
                    </effect>
                    <graphic>
                        <Label text="Generate with AI"
                               style="-fx-text-fill: #7C3AED;
                                      -fx-font-weight: bold;
                                      -fx-font-size: 13px;"/>
                    </graphic>
                </Button>

                <!-- Statistics -->
                <Button fx:id="btnStatistics"
                        onAction="#handleShowStatistics"
                        prefHeight="48" prefWidth="140"
                        style="-fx-background-color: white;
                               -fx-text-fill: #1A5C40;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 12;
                               -fx-border-color: #1A5C40;
                               -fx-border-radius: 12;
                               -fx-cursor: hand;">
                    <effect>
                        <DropShadow color="rgba(0,0,0,0.05)" radius="8" offsetY="3"/>
                    </effect>
                    <graphic>
                        <Label text="Statistics"
                               style="-fx-text-fill: #1A5C40;
                                      -fx-font-weight: bold;
                                      -fx-font-size: 13px;"/>
                    </graphic>
                </Button>

                <!-- New Recipe -->
                <Button fx:id="btnAddRecipe"
                        onAction="#handleAddNew"
                        prefHeight="48" prefWidth="150"
                        style="-fx-background-color: linear-gradient(to bottom, #2E7D5A, #1A5C40);
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 12;
                               -fx-cursor: hand;">
                    <effect>
                        <DropShadow color="rgba(46,125,90,0.45)" radius="10" offsetY="4"/>
                    </effect>
                    <graphic>
                        <Label text="+ New Recipe"
                               style="-fx-text-fill: white;
                                      -fx-font-weight: bold;
                                      -fx-font-size: 13px;"/>
                    </graphic>
                </Button>

            </HBox>
        </HBox>

        <!-- STATISTICS CARDS -->
        <HBox spacing="18">

            <!-- Total Recipes -->
            <VBox prefHeight="110" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white;
                         -fx-background-radius: 16;
                         -fx-border-color: #E0E8F0;
                         -fx-border-radius: 16;
                         -fx-padding: 20;">
                <effect>
                    <DropShadow color="rgba(0,0,0,0.05)" radius="8" offsetY="3"/>
                </effect>
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <StackPane prefWidth="52" prefHeight="52"
                               style="-fx-background-color: linear-gradient(to bottom right, #DCFCE7, #BBF7D0);
                                      -fx-background-radius: 12;">
                        <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"
                                 fill="#16A34A" scaleX="1.5" scaleY="1.5"/>
                    </StackPane>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="TOTAL RECIPES"
                               style="-fx-font-size: 10px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #64748B;"/>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label fx:id="lblTotalRecipes" text="0"
                                   style="-fx-font-size: 36px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #1E293B;"/>
                            <Label text="recipes"
                                   style="-fx-font-size: 12px;
                                          -fx-text-fill: #94A3B8;"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Entrées -->
            <VBox prefHeight="110" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white;
                         -fx-background-radius: 16;
                         -fx-border-color: #E0E8F0;
                         -fx-border-radius: 16;
                         -fx-padding: 20;">
                <effect>
                    <DropShadow color="rgba(0,0,0,0.05)" radius="8" offsetY="3"/>
                </effect>
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <StackPane prefWidth="52" prefHeight="52"
                               style="-fx-background-color: linear-gradient(to bottom right, #FEF3C7, #FDE68A);
                                      -fx-background-radius: 12;">
                        <Label text="🥗" style="-fx-font-size: 26px;"/>
                    </StackPane>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="ENTREES"
                               style="-fx-font-size: 10px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #64748B;"/>
                        <Label fx:id="lblEntrees" text="0"
                               style="-fx-font-size: 36px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #F59E0B;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Plats -->
            <VBox prefHeight="110" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white;
                         -fx-background-radius: 16;
                         -fx-border-color: #E0E8F0;
                         -fx-border-radius: 16;
                         -fx-padding: 20;">
                <effect>
                    <DropShadow color="rgba(0,0,0,0.05)" radius="8" offsetY="3"/>
                </effect>
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <StackPane prefWidth="52" prefHeight="52"
                               style="-fx-background-color: linear-gradient(to bottom right, #FEE2E2, #FECACA);
                                      -fx-background-radius: 12;">
                        <Label text="🍽️" style="-fx-font-size: 26px;"/>
                    </StackPane>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="MAIN DISHES"
                               style="-fx-font-size: 10px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #64748B;"/>
                        <Label fx:id="lblPlats" text="0"
                               style="-fx-font-size: 36px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #DC2626;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Desserts -->
            <VBox prefHeight="110" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white;
                         -fx-background-radius: 16;
                         -fx-border-color: #E0E8F0;
                         -fx-border-radius: 16;
                         -fx-padding: 20;">
                <effect>
                    <DropShadow color="rgba(0,0,0,0.05)" radius="8" offsetY="3"/>
                </effect>
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <StackPane prefWidth="52" prefHeight="52"
                               style="-fx-background-color: linear-gradient(to bottom right, #DBEAFE, #BFDBFE);
                                      -fx-background-radius: 12;">
                        <Label text="🍰" style="-fx-font-size: 26px;"/>
                    </StackPane>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="DESSERTS"
                               style="-fx-font-size: 10px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #64748B;"/>
                        <Label fx:id="lblDesserts" text="0"
                               style="-fx-font-size: 36px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #3B82F6;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Drinks -->
            <VBox prefHeight="110" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white;
                         -fx-background-radius: 16;
                         -fx-border-color: #E0E8F0;
                         -fx-border-radius: 16;
                         -fx-padding: 20;">
                <effect>
                    <DropShadow color="rgba(0,0,0,0.05)" radius="8" offsetY="3"/>
                </effect>
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <StackPane prefWidth="52" prefHeight="52"
                               style="-fx-background-color: linear-gradient(to bottom right, #FCE7F3, #FBCFE8);
                                      -fx-background-radius: 12;">
                        <Label text="🥤" style="-fx-font-size: 26px;"/>
                    </StackPane>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="DRINKS"
                               style="-fx-font-size: 10px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #64748B;"/>
                        <Label fx:id="lblBoissons" text="0"
                               style="-fx-font-size: 36px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #EC4899;"/>
                    </VBox>
                </HBox>
            </VBox>

        </HBox>

        <!-- SEARCH & FILTERS BAR -->
        <HBox alignment="CENTER_LEFT" spacing="14" prefHeight="70"
              style="-fx-background-color: white;
                     -fx-background-radius: 14;
                     -fx-border-color: #E0E8F0;
                     -fx-border-radius: 14;
                     -fx-padding: 16 20;">
            <effect>
                <DropShadow color="rgba(0,0,0,0.04)" radius="6" offsetY="2"/>
            </effect>

            <!-- Search -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  prefWidth="340" prefHeight="42"
                  style="-fx-background-color: #F8FAFC;
                         -fx-background-radius: 10;
                         -fx-border-color: #E2E8F0;
                         -fx-border-radius: 10;
                         -fx-padding: 0 14;">
                <SVGPath content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                         fill="#94A3B8" scaleX="0.85" scaleY="0.85"/>
                <TextField fx:id="txtSearch"
                           promptText="Search recipes..."
                           prefHeight="38"
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-color: transparent;
                                  -fx-border-color: transparent;
                                  -fx-font-size: 13px;
                                  -fx-text-fill: #475569;"/>
            </HBox>

            <Separator orientation="VERTICAL" prefHeight="30"/>

            <!-- Type Filter -->
            <VBox spacing="4">
                <Label text="TYPE"
                       style="-fx-font-size: 9px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #64748B;"/>
                <ComboBox fx:id="cmbFilterType"
                          promptText="All"
                          prefWidth="160" prefHeight="36"
                          style="-fx-font-size: 12px;
                                 -fx-background-radius: 8;"/>
            </VBox>

            <!-- Difficulty Filter -->
            <VBox spacing="4">
                <Label text="DIFFICULTY"
                       style="-fx-font-size: 9px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #64748B;"/>
                <ComboBox fx:id="cmbFilterDifficulty"
                          promptText="All"
                          prefWidth="150" prefHeight="36"
                          style="-fx-font-size: 12px;
                                 -fx-background-radius: 8;"/>
            </VBox>

            <!-- Time Filter -->
            <VBox spacing="4">
                <Label text="MAX TIME"
                       style="-fx-font-size: 9px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #64748B;"/>
                <ComboBox fx:id="cmbFilterTime"
                          promptText="All"
                          prefWidth="140" prefHeight="36"
                          style="-fx-font-size: 12px;
                                 -fx-background-radius: 8;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Refresh -->
            <Button onAction="#handleRefresh"
                    prefHeight="40" prefWidth="40"
                    style="-fx-background-color: #F1F5F9;
                           -fx-background-radius: 10;
                           -fx-cursor: hand;">
                <graphic>
                    <SVGPath content="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                             fill="#64748B" scaleX="0.9" scaleY="0.9"/>
                </graphic>
            </Button>

            <!-- Export -->
            <Button text="📥 Export"
                    onAction="#handleExport"
                    prefHeight="40" prefWidth="120"
                    style="-fx-background-color: transparent;
                           -fx-border-color: #CBD5E1;
                           -fx-border-radius: 10;
                           -fx-background-radius: 10;
                           -fx-text-fill: #475569;
                           -fx-font-size: 12px;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;"/>
        </HBox>

        <!-- RECIPES TABLE -->
        <VBox VBox.vgrow="ALWAYS" spacing="0"
              style="-fx-background-color: white;
                     -fx-background-radius: 16;
                     -fx-border-color: #E0E8F0;
                     -fx-border-radius: 16;">
            <effect>
                <DropShadow color="rgba(0,0,0,0.06)" radius="10" offsetY="4"/>
            </effect>
            <padding>
                <Insets top="20" right="20" bottom="16" left="20"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 0 0 16 0;">
                <Label text="Recipe List"
                       style="-fx-font-size: 17px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1E293B;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblTableInfo"
                       text="Showing 0 recipes"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #94A3B8;
                              -fx-padding: 6 12;
                              -fx-background-color: #F8FAFC;
                              -fx-background-radius: 6;"/>
            </HBox>

            <TableView fx:id="tableRecipes"
                       VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent;
                              -fx-border-color: #F1F5F9;
                              -fx-border-radius: 10;">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colNom"
                                 text="Recipe"
                                 prefWidth="200" minWidth="150"/>
                    <TableColumn fx:id="colType"
                                 text="Type"
                                 prefWidth="120" minWidth="100"
                                 style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colDifficulte"
                                 text="Difficulty"
                                 prefWidth="120" minWidth="100"
                                 style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colTemps"
                                 text="Time (min)"
                                 prefWidth="100" minWidth="80"
                                 style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colDescription"
                                 text="Description"
                                 prefWidth="250" minWidth="200"/>
                    <TableColumn fx:id="colActions"
                                 text="Actions"
                                 prefWidth="180" minWidth="160"
                                 style="-fx-alignment: CENTER;"
                                 sortable="false"/>
                </columns>
                <placeholder>
                    <VBox fx:id="emptyState"
                          alignment="CENTER" spacing="16"
                          style="-fx-padding: 60;">
                        <Label text="No recipes found"
                               style="-fx-font-size: 20px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #64748B;"/>
                        <Label text="Click 'New Recipe' to add your first dish"
                               style="-fx-font-size: 13px;
                                      -fx-text-fill: #94A3B8;"/>
                        <Button text="+ Add now"
                                onAction="#handleAddNew"
                                style="-fx-background-color: #2E7D5A;
                                       -fx-text-fill: white;
                                       -fx-font-size: 13px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 8;
                                       -fx-padding: 10 20;
                                       -fx-cursor: hand;"/>
                    </VBox>
                </placeholder>
            </TableView>
        </VBox>

    </VBox>

    <!-- MODAL ADD/EDIT -->
    <StackPane fx:id="modalOverlay"
               visible="false" managed="false"
               style="-fx-background-color: rgba(15, 23, 42, 0.78);">

        <VBox maxWidth="680" maxHeight="700" spacing="0"
              style="-fx-background-color: white;
                     -fx-background-radius: 20;">
            <effect>
                <DropShadow color="rgba(0,0,0,0.5)" radius="50" offsetY="15"/>
            </effect>

            <!-- Modal Header -->
            <HBox alignment="CENTER_LEFT" spacing="14" prefHeight="70"
                  style="-fx-background-color: linear-gradient(to right, #1A5C40, #2E7D5A, #3D9970);
                         -fx-background-radius: 20 20 0 0;
                         -fx-padding: 0 24;">

                <StackPane prefWidth="42" prefHeight="42"
                           style="-fx-background-color: rgba(255,255,255,0.2);
                                  -fx-background-radius: 12;">
                    <SVGPath content="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"
                             fill="white" scaleX="1.3" scaleY="1.3"/>
                </StackPane>

                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblModalTitle" text="New Recipe"
                           style="-fx-font-size: 18px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: white;"/>
                    <Label text="Fill in the information for your recipe"
                           style="-fx-font-size: 11px;
                                  -fx-text-fill: rgba(255,255,255,0.8);"/>
                </VBox>

                <Button onAction="#handleCloseModal"
                        prefWidth="36" prefHeight="36"
                        style="-fx-background-color: rgba(255,255,255,0.15);
                               -fx-background-radius: 10;
                               -fx-cursor: hand;">
                    <graphic>
                        <SVGPath content="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                 fill="white" scaleX="0.85" scaleY="0.85"/>
                    </graphic>
                </Button>
            </HBox>

            <!-- Modal Body -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                        prefHeight="550"
                        style="-fx-background-color: white;
                               -fx-background: white;">
                <VBox spacing="20" style="-fx-padding: 28;">

                    <!-- Section 1 -->
                    <VBox spacing="14">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <StackPane prefWidth="24" prefHeight="24"
                                       style="-fx-background-color: #DCFCE7;
                                              -fx-background-radius: 6;">
                                <Label text="1"
                                       style="-fx-font-size: 11px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #16A34A;"/>
                            </StackPane>
                            <Label text="Basic Information"
                                   style="-fx-font-size: 14px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #1E293B;"/>
                        </HBox>

                        <GridPane hgap="16" vgap="16"
                                  style="-fx-padding: 0 0 0 32;">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="60"/>
                                <ColumnConstraints percentWidth="40"/>
                            </columnConstraints>

                            <VBox spacing="6"
                                  GridPane.columnIndex="0"
                                  GridPane.rowIndex="0">
                                <Label text="Recipe name *"
                                       style="-fx-font-size: 12px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #374151;"/>
                                <TextField fx:id="txtNom"
                                           promptText="e.g. Caesar salad"
                                           prefHeight="42"
                                           style="-fx-font-size: 13px;
                                                  -fx-padding: 10 14;
                                                  -fx-background-radius: 10;
                                                  -fx-border-color: #D1D5DB;
                                                  -fx-border-radius: 10;
                                                  -fx-background-color: #FAFAFA;"/>
                                <Label fx:id="lblNomError" text=""
                                       style="-fx-text-fill: #DC2626;
                                              -fx-font-size: 11px;"
                                       visible="false" managed="false"/>
                            </VBox>

                            <VBox spacing="6"
                                  GridPane.columnIndex="1"
                                  GridPane.rowIndex="0">
                                <Label text="Type of dish *"
                                       style="-fx-font-size: 12px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #374151;"/>
                                <ComboBox fx:id="cmbType"
                                          promptText="Select"
                                          prefHeight="42"
                                          maxWidth="Infinity"
                                          style="-fx-font-size: 13px;
                                                 -fx-background-radius: 10;"/>
                                <Label fx:id="lblTypeError" text=""
                                       style="-fx-text-fill: #DC2626;
                                              -fx-font-size: 11px;"
                                       visible="false" managed="false"/>
                            </VBox>

                            <VBox spacing="6"
                                  GridPane.columnIndex="0"
                                  GridPane.rowIndex="1"
                                  GridPane.columnSpan="2">
                                <Label text="Image URL"
                                       style="-fx-font-size: 12px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #374151;"/>
                                <TextField fx:id="txtImage"
                                           promptText="https://exemple.com/photo.jpg"
                                           prefHeight="42"
                                           style="-fx-font-size: 13px;
                                                  -fx-padding: 10 14;
                                                  -fx-background-radius: 10;
                                                  -fx-border-color: #D1D5DB;
                                                  -fx-border-radius: 10;
                                                  -fx-background-color: #FAFAFA;"/>
                                <Label fx:id="lblImageError" text=""
                                       style="-fx-text-fill: #DC2626;
                                              -fx-font-size: 11px;"
                                       visible="false" managed="false"/>
                            </VBox>
                        </GridPane>
                    </VBox>

                    <Separator style="-fx-background-color: #E5E7EB;"/>

                    <!-- Section 2 -->
                    <VBox spacing="14">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <StackPane prefWidth="24" prefHeight="24"
                                       style="-fx-background-color: #DBEAFE;
                                              -fx-background-radius: 6;">
                                <Label text="2"
                                       style="-fx-font-size: 11px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #3B82F6;"/>
                            </StackPane>
                            <Label text="Preparation Details"
                                   style="-fx-font-size: 14px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #1E293B;"/>
                        </HBox>

                        <GridPane hgap="16" vgap="16"
                                  style="-fx-padding: 0 0 0 32;">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>

                            <VBox spacing="6"
                                  GridPane.columnIndex="0"
                                  GridPane.rowIndex="0">
                                <Label text="Preparation time (min) *"
                                       style="-fx-font-size: 12px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #374151;"/>
                                <TextField fx:id="txtTemps"
                                           promptText="30"
                                           prefHeight="42"
                                           style="-fx-font-size: 13px;
                                                  -fx-padding: 10 14;
                                                  -fx-background-radius: 10;
                                                  -fx-border-color: #D1D5DB;
                                                  -fx-border-radius: 10;
                                                  -fx-background-color: #FAFAFA;"/>
                                <Label fx:id="lblTempsError" text=""
                                       style="-fx-text-fill: #DC2626;
                                              -fx-font-size: 11px;"
                                       visible="false" managed="false"/>
                            </VBox>

                            <VBox spacing="6"
                                  GridPane.columnIndex="1"
                                  GridPane.rowIndex="0">
                                <Label text="Difficulty *"
                                       style="-fx-font-size: 12px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #374151;"/>
                                <ComboBox fx:id="cmbDifficulte"
                                          promptText="Select"
                                          prefHeight="42"
                                          maxWidth="Infinity"
                                          style="-fx-font-size: 13px;
                                                 -fx-background-radius: 10;"/>
                                <Label fx:id="lblDifficulteError" text=""
                                       style="-fx-text-fill: #DC2626;
                                              -fx-font-size: 11px;"
                                       visible="false" managed="false"/>
                            </VBox>
                        </GridPane>

                        <VBox spacing="6" style="-fx-padding: 0 0 0 32;">
                            <Label text="Description"
                                   style="-fx-font-size: 12px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #374151;"/>
                            <TextArea fx:id="txtDescription"
                                      promptText="Describe your recipe briefly..."
                                      prefRowCount="3"
                                      style="-fx-font-size: 13px;
                                             -fx-background-radius: 10;
                                             -fx-border-color: #D1D5DB;
                                             -fx-border-radius: 10;
                                             -fx-background-color: #FAFAFA;"/>
                            <Label fx:id="lblDescriptionError" text=""
                                   style="-fx-text-fill: #DC2626;
                                          -fx-font-size: 11px;"
                                   visible="false" managed="false"/>
                        </VBox>
                    </VBox>

                    <Separator style="-fx-background-color: #E5E7EB;"/>

                    <!-- Section 3 Steps -->
                    <VBox spacing="14">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <StackPane prefWidth="24" prefHeight="24"
                                       style="-fx-background-color: #FEF3C7;
                                              -fx-background-radius: 6;">
                                <Label text="3"
                                       style="-fx-font-size: 11px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #F59E0B;"/>
                            </StackPane>
                            <Label text="Preparation Steps"
                                   style="-fx-font-size: 14px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #1E293B;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="+ Add Step"
                                    onAction="#handleAddStep"
                                    prefHeight="32"
                                    style="-fx-background-color: #FEF3C7;
                                           -fx-text-fill: #F59E0B;
                                           -fx-font-size: 11px;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 8;
                                           -fx-cursor: hand;"/>
                        </HBox>

                        <VBox fx:id="stepsContainer" spacing="10"
                              style="-fx-padding: 0 0 0 32;"/>
                    </VBox>

                </VBox>
            </ScrollPane>

            <!-- Modal Footer -->
            <HBox spacing="12" alignment="CENTER_RIGHT" prefHeight="75"
                  style="-fx-padding: 0 24;
                         -fx-background-color: #F9FAFB;
                         -fx-background-radius: 0 0 20 20;
                         -fx-border-color: #E5E7EB;
                         -fx-border-width: 1 0 0 0;">

                <Label text="* Required fields"
                       HBox.hgrow="ALWAYS"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #94A3B8;"/>

                <Button text="Cancel"
                        onAction="#handleCloseModal"
                        prefHeight="42" prefWidth="130"
                        style="-fx-background-color: white;
                               -fx-border-color: #D1D5DB;
                               -fx-border-radius: 10;
                               -fx-background-radius: 10;
                               -fx-text-fill: #374151;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-cursor: hand;"/>

                <Button fx:id="btnSave"
                        onAction="#handleSave"
                        prefHeight="42" prefWidth="180"
                        style="-fx-background-color: linear-gradient(to bottom, #2E7D5A, #1A5C40);
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;">
                    <effect>
                        <DropShadow color="rgba(46,125,90,0.4)" radius="8" offsetY="3"/>
                    </effect>
                    <graphic>
                        <HBox alignment="CENTER" spacing="8">
                            <SVGPath content="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                     fill="white" scaleX="0.8" scaleY="0.8"/>
                            <Label text="Save Recipe"
                                   style="-fx-text-fill: white;
                                          -fx-font-weight: bold;
                                          -fx-font-size: 13px;"/>
                        </HBox>
                    </graphic>
                </Button>

            </HBox>
        </VBox>
    </StackPane>

    <!-- TOAST NOTIFICATION -->
    <HBox fx:id="toastNotification"
          visible="false" managed="false"
          alignment="CENTER" spacing="12"
          StackPane.alignment="BOTTOM_CENTER"
          style="-fx-background-color: #1E293B;
                 -fx-background-radius: 12;
                 -fx-padding: 14 24;">
        <StackPane.margin>
            <Insets bottom="30"/>
        </StackPane.margin>
        <Label fx:id="lblToastIcon" text="✓"
               style="-fx-font-size: 18px;
                      -fx-text-fill: #4ADE80;"/>
        <Label fx:id="lblToastMessage" text="Operation successful!"
               style="-fx-text-fill: white;
                      -fx-font-size: 13px;
                      -fx-font-weight: bold;"/>
    </HBox>

</StackPane>