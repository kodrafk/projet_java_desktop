<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.projet.gui.ObjectiveConfirmController"
      style="-fx-background-color: #F6FBF7;"
      spacing="0">

    <!-- ═══ HEADER ═══ -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #163A2E; -fx-padding: 20 32;">
        <VBox spacing="4">
            <Label text="Your Weekly Journey"
                   style="-fx-font-size: 11px; -fx-text-fill: #A7C4B8; -fx-font-weight: bold;"/>
            <Label text="Weekly Objectives"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="← Change Plan" onAction="#handleBack"
                style="-fx-background-color: transparent; -fx-text-fill: #A7C4B8; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: #2F5A4A; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 16;"/>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background: #F6FBF7; -fx-background-color: #F6FBF7; -fx-border-color: transparent;">
        <VBox spacing="24" style="-fx-background-color: #F6FBF7;" maxWidth="700">
            <padding><Insets top="24" right="32" bottom="32" left="32"/></padding>

            <!-- ═══ WIZARD STEPS ═══ -->
            <HBox alignment="CENTER" spacing="8">
                <VBox alignment="CENTER" spacing="4">
                    <Label text="✓"
                           style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 50%; -fx-min-width: 32; -fx-min-height: 32; -fx-alignment: center;"/>
                    <Label text="Goal" style="-fx-font-size: 11px; -fx-text-fill: #1F4D3A; -fx-font-weight: bold;"/>
                </VBox>
                <Label text="────────" style="-fx-text-fill: #2E7D5A;"/>
                <VBox alignment="CENTER" spacing="4">
                    <Label text="✓"
                           style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 50%; -fx-min-width: 32; -fx-min-height: 32; -fx-alignment: center;"/>
                    <Label text="Plan" style="-fx-font-size: 11px; -fx-text-fill: #1F4D3A; -fx-font-weight: bold;"/>
                </VBox>
                <Label text="────────" style="-fx-text-fill: #2E7D5A;"/>
                <VBox alignment="CENTER" spacing="4">
                    <Label text="3"
                           style="-fx-background-color: #2E7D5A; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 50%; -fx-min-width: 32; -fx-min-height: 32; -fx-alignment: center;"/>
                    <Label text="Confirm" style="-fx-font-size: 11px; -fx-text-fill: #2E7D5A; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- ═══ SUMMARY CARD ═══ -->
            <VBox style="-fx-background-color: #163A2E; -fx-background-radius: 14; -fx-padding: 28;" spacing="16">
                <VBox spacing="6">
                    <Label text="Your Plan" style="-fx-font-size: 11px; -fx-text-fill: #A7C4B8;"/>
                    <Label fx:id="lblSummaryTitle" text=""
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label fx:id="lblSummarySub" text=""
                           style="-fx-font-size: 13px; -fx-text-fill: #A7C4B8;"/>
                </VBox>
                <HBox spacing="12">
                    <VBox alignment="CENTER" spacing="4" prefWidth="100"
                          style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 10; -fx-padding: 14;">
                        <Label text="🔥" style="-fx-font-size: 16px;"/>
                        <Label fx:id="lblSumCal" text="—"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Calories" style="-fx-font-size: 10px; -fx-text-fill: #A7C4B8;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" prefWidth="100"
                          style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 10; -fx-padding: 14;">
                        <Label text="💪" style="-fx-font-size: 16px;"/>
                        <Label fx:id="lblSumProtein" text="—"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Protein (g)" style="-fx-font-size: 10px; -fx-text-fill: #A7C4B8;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" prefWidth="100"
                          style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 10; -fx-padding: 14;">
                        <Label text="🌾" style="-fx-font-size: 16px;"/>
                        <Label fx:id="lblSumCarbs" text="—"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Carbs (g)" style="-fx-font-size: 10px; -fx-text-fill: #A7C4B8;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" prefWidth="100"
                          style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 10; -fx-padding: 14;">
                        <Label text="🥑" style="-fx-font-size: 16px;"/>
                        <Label fx:id="lblSumFats" text="—"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Fats (g)" style="-fx-font-size: 10px; -fx-text-fill: #A7C4B8;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" prefWidth="100"
                          style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 10; -fx-padding: 14;">
                        <Label text="💧" style="-fx-font-size: 16px;"/>
                        <Label fx:id="lblSumWater" text="—"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Water (L)" style="-fx-font-size: 10px; -fx-text-fill: #A7C4B8;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ═══ FORM CARD ═══ -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 28; -fx-border-color: #E2E8F0; -fx-border-radius: 14;" spacing="20">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📅" style="-fx-font-size: 18px;"/>
                    <Label text="When do you want to start?"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                </HBox>

                <VBox spacing="8">
                    <Label text="Start Date"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <DatePicker fx:id="startDatePicker" prefWidth="300"
                                style="-fx-font-size: 13px;"/>
                    <Label text="The 7-day plan runs from this date."
                           style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                </VBox>

                <!-- Quick date buttons -->
                <HBox spacing="10">
                    <Button text="Today" onAction="#setToday"
                            style="-fx-background-color: #F1F5F9; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 8 14;"/>
                    <Button text="Tomorrow" onAction="#setTomorrow"
                            style="-fx-background-color: #F1F5F9; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 8 14;"/>
                    <Button text="Next Monday" onAction="#setNextMonday"
                            style="-fx-background-color: #F1F5F9; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 8 14;"/>
                    <Button text="In 1 Week" onAction="#setNextWeek"
                            style="-fx-background-color: #F1F5F9; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 8 14;"/>
                </HBox>

                <!-- Auto-activate -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <CheckBox fx:id="autoActivateCheck" selected="true"/>
                    <VBox spacing="2">
                        <Label text="⚡ Auto-activate on start date"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                        <Label text="Automatically starts the 7-day plan when the date arrives"
                               style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                    </VBox>
                </HBox>

                <Button text="✓ Create My Plan" onAction="#handleCreate" prefWidth="9999" prefHeight="48"
                        style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
