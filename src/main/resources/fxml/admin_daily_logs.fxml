<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.projet.gui.AdminDailyLogsController"
      style="-fx-background-color: #F0F4F8;" spacing="0" VBox.vgrow="ALWAYS">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-border-width: 0 0 1 0; -fx-padding: 18 26;">
        <VBox spacing="3">
            <Label fx:id="lblObjectiveTitle" text="Daily Logs"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
            <Label text="7-day log management for this objective"
                   style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="← Back to Objectives" onAction="#handleBack"
                style="-fx-background-color: transparent; -fx-text-fill: #2E7D5A; -fx-border-color: #2E7D5A; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 12px; -fx-padding: 8 14; -fx-cursor: hand;"/>
    </HBox>

    <!-- Table header -->
    <HBox style="-fx-background-color: #F8FAFC; -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-padding: 10 26;">
        <Label text="Day" prefWidth="60" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
        <Label text="Date" prefWidth="120" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
        <Label text="Status" prefWidth="100" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
        <Label text="Calories" prefWidth="90" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
        <Label text="Protein" prefWidth="80" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
        <Label text="Carbs" prefWidth="80" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
        <Label text="Fats" prefWidth="80" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Actions" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
    </HBox>

    <!-- Rows -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS"
                style="-fx-background: #F0F4F8; -fx-background-color: #F0F4F8; -fx-border-color: transparent;">
        <VBox fx:id="logsContainer" spacing="1" style="-fx-background-color: #F0F4F8;">
            <padding><Insets top="4" right="0" bottom="8" left="0"/></padding>
        </VBox>
    </ScrollPane>

    <!-- Edit panel (shown inline when editing a log) -->
    <VBox fx:id="editPanel" visible="false" managed="false" spacing="14"
          style="-fx-background-color: white; -fx-border-color: #E2E8F0 transparent transparent transparent; -fx-border-width: 1 0 0 0; -fx-padding: 20 26;">
        <Label text="Edit Daily Log" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
        <GridPane hgap="16" vgap="12">
            <columnConstraints>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
            </columnConstraints>
            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="🔥 Calories" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TextField fx:id="editCalField" prefHeight="38"
                           style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10; -fx-font-size: 13px;"/>
                <Label fx:id="errCal" text="" visible="false" managed="false" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
            </VBox>
            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="💪 Protein (g)" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TextField fx:id="editProteinField" prefHeight="38"
                           style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10; -fx-font-size: 13px;"/>
                <Label fx:id="errProtein" text="" visible="false" managed="false" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
            </VBox>
            <VBox spacing="4" GridPane.columnIndex="2" GridPane.rowIndex="0">
                <Label text="🌾 Carbs (g)" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TextField fx:id="editCarbsField" prefHeight="38"
                           style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10; -fx-font-size: 13px;"/>
                <Label fx:id="errCarbs" text="" visible="false" managed="false" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
            </VBox>
            <VBox spacing="4" GridPane.columnIndex="3" GridPane.rowIndex="0">
                <Label text="🥑 Fats (g)" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TextField fx:id="editFatsField" prefHeight="38"
                           style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10; -fx-font-size: 13px;"/>
                <Label fx:id="errFats" text="" visible="false" managed="false" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
            </VBox>
        </GridPane>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Cancel" onAction="#handleCancelEdit"
                    style="-fx-background-color: white; -fx-text-fill: #374151; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 12px; -fx-padding: 8 18; -fx-cursor: hand;"/>
            <Button text="✓ Save Log" onAction="#handleSaveEdit"
                    style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 18; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</VBox>
