<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.projet.gui.AdminAlertsController"
      prefWidth="1060" prefHeight="700" spacing="0"
      style="-fx-background-color:#F0F4F8;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color:white;-fx-padding:20;">
        <Label text="🔔 User Alerts Management" style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblUserInfo" text="Select a user to send an alert" 
               style="-fx-font-size:12px;-fx-text-fill:#64748B;"/>
    </HBox>

    <!-- Main Content -->
    <HBox VBox.vgrow="ALWAYS" spacing="16" style="-fx-padding:16;">
        
        <!-- Left: User List -->
        <VBox spacing="12" prefWidth="280" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:16;">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="👥 Users" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblUserCount" text="0 users" style="-fx-font-size:11px;-fx-text-fill:#64748B;"/>
            </HBox>
            
            <TextField fx:id="txtSearchUser" promptText="🔍 Search users..." 
                      style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-padding:8;-fx-border-color:#E5E7EB;-fx-border-radius:8;"/>
            
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" 
                       style="-fx-background-color:transparent;-fx-border-color:transparent;">
                <VBox fx:id="userListContainer" spacing="8" style="-fx-padding:4;"/>
            </ScrollPane>
        </VBox>

        <!-- Center: Alert Form -->
        <VBox spacing="16" HBox.hgrow="ALWAYS" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20;">
            <Label text="✉️ Create Alert" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
            
            <VBox spacing="8">
                <Label text="Alert Title" style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#374151;"/>
                <TextField fx:id="txtAlertTitle" promptText="Enter alert title..." 
                          style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-padding:10;-fx-border-color:#E5E7EB;-fx-border-radius:8;"/>
            </VBox>
            
            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="Alert Message" style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#374151;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblCharCount" text="0 / 500" style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                </HBox>
                <TextArea fx:id="txtAlertMessage" promptText="Write your alert message..." 
                         wrapText="true" prefRowCount="4"
                         style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-padding:10;-fx-border-color:#E5E7EB;-fx-border-radius:8;"/>
            </VBox>
            
            <HBox spacing="12">
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Alert Type" style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#374151;"/>
                    <ComboBox fx:id="cmbAlertType" maxWidth="Infinity" 
                             style="-fx-background-color:#F8FAFC;-fx-background-radius:8;"/>
                </VBox>
                
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Category" style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#374151;"/>
                    <ComboBox fx:id="cmbAlertCategory" maxWidth="Infinity" 
                             style="-fx-background-color:#F8FAFC;-fx-background-radius:8;"/>
                </VBox>
            </HBox>
            
            <!-- Expiry Section -->
            <VBox spacing="8">
                <CheckBox fx:id="chkHasExpiry" text="Set expiration date" 
                         style="-fx-font-size:12px;-fx-text-fill:#374151;"/>
                <HBox spacing="12">
                    <DatePicker fx:id="dpExpiryDate" promptText="Select date" HBox.hgrow="ALWAYS"
                               style="-fx-background-color:#F8FAFC;-fx-background-radius:8;"/>
                    <TextField fx:id="txtExpiryTime" promptText="HH:MM" prefWidth="100"
                              style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-padding:8;"/>
                </HBox>
            </VBox>
            
            <!-- Action Section -->
            <VBox spacing="8">
                <CheckBox fx:id="chkHasAction" text="Add action button" 
                         style="-fx-font-size:12px;-fx-text-fill:#374151;"/>
                <TextField fx:id="txtActionUrl" promptText="Action URL (e.g., /profile)" 
                          style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-padding:10;"/>
                <TextField fx:id="txtActionLabel" promptText="Button label (e.g., View Profile)" 
                          style="-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-padding:10;"/>
            </VBox>
            
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Clear" onAction="#handleClearForm"
                       style="-fx-background-color:#F1F5F9;-fx-text-fill:#64748B;-fx-font-size:13px;-fx-background-radius:8;-fx-padding:10 24;-fx-cursor:hand;"/>
                <Button text="Send Alert" onAction="#handleSendAlert"
                       style="-fx-background-color:#7C3AED;-fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;-fx-background-radius:8;-fx-padding:10 24;-fx-cursor:hand;"/>
            </HBox>
        </VBox>

        <!-- Right: History -->
        <VBox spacing="12" prefWidth="320" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:16;">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="📋 History" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnRefreshHistory" text="🔄" onAction="#handleRefreshHistory"
                       style="-fx-background-color:#F1F5F9;-fx-text-fill:#64748B;-fx-font-size:12px;-fx-background-radius:6;-fx-padding:4 10;-fx-cursor:hand;"/>
            </HBox>
            
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" 
                       style="-fx-background-color:transparent;-fx-border-color:transparent;">
                <VBox fx:id="historyContainer" spacing="10" style="-fx-padding:4;"/>
            </ScrollPane>
        </VBox>
    </HBox>
</VBox>
