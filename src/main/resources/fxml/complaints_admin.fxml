<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-background-color: #F0F4F8; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.projet.gui.ComplaintsAdminController">

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5">
            <Label text="Complaints Management" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
            <Label text="Review and respond to active user issues" style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleExportExcel" text="Export to Excel" 
                style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 16; -fx-font-weight: bold;"/>
        <Button onAction="#handleRefresh" text="Refresh Data" 
                style="-fx-background-color: #E2E8F0; -fx-text-fill: #475569; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 16;"/>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        
        <!-- Table List (Left side) -->
        <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Search:" style="-fx-font-size: 12px; -fx-text-fill: #475569; font-weight: bold;"/>
                <TextField fx:id="fldSearch" promptText="Search by title or status" 
                           style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6;" />
            </HBox>

            <TableView fx:id="tvComplaints" VBox.vgrow="ALWAYS" style="-fx-border-color: #E2E8F0; -fx-border-radius: 6;">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50">
                        <cellValueFactory><PropertyValueFactory property="id"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colUserName" text="User Name" prefWidth="120">
                        <cellValueFactory><PropertyValueFactory property="userName"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="120">
                        <cellValueFactory><PropertyValueFactory property="dateOfComplaint"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colTitle" text="Title" prefWidth="150">
                        <cellValueFactory><PropertyValueFactory property="title"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100">
                        <cellValueFactory><PropertyValueFactory property="status"/></cellValueFactory>
                    </TableColumn>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- Response Panel (Right side) -->
        <VBox spacing="15" prefWidth="380" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <Label text="Complaint Details" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
            
            <VBox spacing="5" style="-fx-background-color: #F8FAFC; -fx-padding: 12; -fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8;">
                <HBox>
                    <Label text="Title: " style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <Label fx:id="lblTitle" text="-" style="-fx-font-size: 12px; -fx-text-fill: #1E293B;"/>
                </HBox>
                <HBox>
                    <Label text="Phone: " style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <Label fx:id="lblPhone" text="-" style="-fx-font-size: 12px; -fx-text-fill: #1E293B;"/>
                </HBox>
                <HBox>
                    <Label text="Rate (1-5): " style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <Label fx:id="lblRate" text="-" style="-fx-font-size: 12px; -fx-text-fill: #1E293B;"/>
                </HBox>
            </VBox>

            <VBox spacing="5" VBox.vgrow="ALWAYS">
                <Label text="User Description" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextArea fx:id="lblDescription" editable="false" wrapText="true" VBox.vgrow="ALWAYS" 
                          style="-fx-control-inner-background: #F1F5F9; -fx-border-color: #CBD5E1; -fx-border-radius: 6;"/>
            </VBox>

            <Button fx:id="btnViewImage" text="View Attached Image" onAction="#handleViewImage" 
                    visible="false" managed="false" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 12; -fx-cursor: hand;"/>

            <Separator style="-fx-background-color: #E2E8F0;"/>
            
            <Label text="Admin Action" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>

            <VBox spacing="5">
                <Label text="Change Status *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <ComboBox fx:id="cmbStatus" maxWidth="Infinity" style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6;"/>
            </VBox>

            <VBox spacing="5" VBox.vgrow="ALWAYS">
                <Label text="Response *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextArea fx:id="fldResponse" promptText="Type the resolution/response here..." wrapText="true" VBox.vgrow="ALWAYS" 
                          style="-fx-control-inner-background: white; -fx-border-color: #CBD5E1; -fx-border-radius: 6;"/>
            </VBox>

            <HBox spacing="10">
                <Button onAction="#handleSave" text="Save Response" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                        style="-fx-background-color: #2E7D5A; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-padding: 10; -fx-cursor: hand;"/>
                <Button onAction="#handleDeleteResponse" text="Delete Response" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                        style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-padding: 10; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
