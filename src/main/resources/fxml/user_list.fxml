<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0" style="-fx-background-color: #F8FAFB;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.projet.gui.UserListController">

    <!-- White card wrapper -->
    <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E8EEF2; -fx-border-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 8, 0, 0, 2);"
          VBox.vgrow="ALWAYS">
        <padding><Insets top="0" right="20" bottom="20" left="20"/></padding>

        <!-- Header row: All Users + bell + Create New User -->
        <HBox alignment="CENTER_LEFT" prefHeight="60" spacing="12">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Region prefWidth="4" prefHeight="22"
                        style="-fx-background-color: #1a7a4a; -fx-background-radius: 2;"/>
                <Label text="All Users"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <!-- Bell icon -->
            <StackPane prefWidth="42" prefHeight="36" style="-fx-cursor: hand;">
                <Button fx:id="btnBell" text="🔔"
                        style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 6 10; -fx-font-size: 14px;"
                        prefWidth="42" prefHeight="36"/>
                <Label fx:id="lblBellBadge" text="0"
                       style="-fx-background-color: #9ca3af; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 1 5;"
                       StackPane.alignment="TOP_RIGHT"
                       translateX="4" translateY="-4"/>
            </StackPane>
            <!-- Create New User button -->
            <Button text="+ Create New User" onAction="#handleAddUser"
                    prefHeight="36"
                    style="-fx-background-color: #1a7a4a; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 16;"/>
        </HBox>

        <!-- Search bar -->
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 16 0;">
            <TextField fx:id="searchField" promptText="Search users by name or email..."
                       prefHeight="36" prefWidth="280"
                       style="-fx-background-color: #F8FAFB; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12; -fx-font-size: 12px;"/>
            <Button text="Search" onAction="#handleSearch"
                    prefHeight="36" prefWidth="80"
                    style="-fx-background-color: #1a7a4a; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblCount" text=""
                   style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
        </HBox>

        <!-- Table header row -->
        <HBox prefHeight="36" alignment="CENTER_LEFT"
              style="-fx-background-color: #F8FAFB; -fx-border-color: #E8EEF2; -fx-border-radius: 8 8 0 0; -fx-padding: 0 12;">
            <Label text="USER PROFILE (FIRST NAME) / (LAST NAME)" prefWidth="340"
                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #94A3B8;"/>
            <Label text="ROLE" prefWidth="120"
                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #94A3B8;"/>
            <Label text="STATUS" prefWidth="120"
                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #94A3B8;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="ACTIONS"
                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #94A3B8;"/>
        </HBox>

        <!-- Table -->
        <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white; -fx-border-color: #E8EEF2; -fx-border-radius: 0 0 12 12; -fx-table-cell-border-color: transparent;">
            <columns>
                <TableColumn fx:id="colProfile"   text=""        prefWidth="340"/>
                <TableColumn fx:id="colRoles"     text=""        prefWidth="120"/>
                <TableColumn fx:id="colStatus"    text=""        prefWidth="120"/>
                <TableColumn fx:id="colActions"   text=""        prefWidth="280"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <placeholder>
                <Label text="No users found." style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;"/>
            </placeholder>
        </TableView>
    </VBox>
</VBox>
