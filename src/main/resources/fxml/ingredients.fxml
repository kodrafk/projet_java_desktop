<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.projet.gui.IngredientManagementController"
           style="-fx-background-color: #F8FAFC;">

    <!-- MAIN CONTENT -->
    <VBox spacing="24">
        <padding><Insets top="28" right="32" bottom="30" left="32"/></padding>

        <!-- HEADER & BREADCRUMB -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="My kitchen" style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
                    <Label text="/" style="-fx-text-fill: #CBD5E1; -fx-font-size: 13px;"/>
                    <Label text="Ingredients" style="-fx-text-fill: #1E293B; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                </HBox>
                <Label text="Ingredients Management"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                <Label text="Organize your food stock intelligently"
                       style="-fx-font-size: 14px; -fx-text-fill: #64748B;"/>
            </VBox>
            <Button fx:id="btnAddIngredient" text="+ Add an ingredient" onAction="#handleAddNew"
                    prefHeight="46" prefWidth="190"
                    style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;">
                <effect><DropShadow color="#1F4D3A4D" radius="10" offsetY="4"/></effect>
            </Button>
        </HBox>

        <!-- STATS GRID (6 CARDS) -->
        <GridPane hgap="18" vgap="18">
            <columnConstraints>
                <ColumnConstraints percentWidth="16.66"/>
                <ColumnConstraints percentWidth="16.66"/>
                <ColumnConstraints percentWidth="16.66"/>
                <ColumnConstraints percentWidth="16.66"/>
                <ColumnConstraints percentWidth="16.66"/>
                <ColumnConstraints percentWidth="16.66"/>
            </columnConstraints>

            <!-- Total In Stock -->
            <VBox spacing="10" GridPane.columnIndex="0"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 16;">
                <StackPane alignment="CENTER_LEFT">
                    <Region prefWidth="36" prefHeight="36" maxWidth="36" maxHeight="36"
                            style="-fx-background-color: #F1F5F9; -fx-background-radius: 8;"/>
                    <SVGPath content="M21 8V20.9932C21 21.5501 20.5552 22 20.0066 22H3.9934C3.44476 22 3 21.5552 3 20.9932V8H21ZM12 12H7V14H12V12ZM21 4V7H3V4C3 3.44772 3.44772 3 4 3H20C20.5523 3 21 3.44772 21 4Z"
                             fill="#475569" scaleX="0.6" scaleY="0.6"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="lblTotalCount" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                    <Label text="Ingredients in stock" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                </VBox>
            </VBox>

            <!-- Categories -->
            <VBox spacing="10" GridPane.columnIndex="1"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 16;">
                <StackPane alignment="CENTER_LEFT">
                    <Region prefWidth="36" prefHeight="36" maxWidth="36" maxHeight="36"
                            style="-fx-background-color: #F1F5F9; -fx-background-radius: 8;"/>
                    <SVGPath content="M4 4h16v16H4V4zm2 2v12h12V6H6zm3 3h6v2H9V9zm0 4h6v2H9v-2z"
                             fill="#475569" scaleX="0.8" scaleY="0.8"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="lblCategoriesCount" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                    <Label text="Categories" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                </VBox>
            </VBox>

            <!-- Expiring Soon -->
            <VBox spacing="10" GridPane.columnIndex="2"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 16;">
                <StackPane alignment="CENTER_LEFT">
                    <Region prefWidth="36" prefHeight="36" maxWidth="36" maxHeight="36"
                            style="-fx-background-color: #FEF3C7; -fx-background-radius: 8;"/>
                    <SVGPath content="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm1 11h-4v-2h2V7h2v6z"
                             fill="#D97706" scaleX="0.8" scaleY="0.8"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="lblExpiringSoon" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #D97706;"/>
                    <Label text="Close to expiry" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                </VBox>
            </VBox>

            <!-- Expired -->
            <VBox spacing="10" GridPane.columnIndex="3"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 16;">
                <StackPane alignment="CENTER_LEFT">
                    <Region prefWidth="36" prefHeight="36" maxWidth="36" maxHeight="36"
                            style="-fx-background-color: #FEE2E2; -fx-background-radius: 8;"/>
                    <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                             fill="#DC2626" scaleX="0.8" scaleY="0.8"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="lblExpired" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #DC2626;"/>
                    <Label text="Expired" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                </VBox>
            </VBox>

            <!-- Low Stock -->
            <VBox spacing="10" GridPane.columnIndex="4"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 16;">
                <StackPane alignment="CENTER_LEFT">
                    <Region prefWidth="36" prefHeight="36" maxWidth="36" maxHeight="36"
                            style="-fx-background-color: #FFF7ED; -fx-background-radius: 8;"/>
                    <SVGPath content="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"
                             fill="#EA580C" scaleX="0.8" scaleY="0.8"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="lblLowStock" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #EA580C;"/>
                    <Label text="Low Stock" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                </VBox>
            </VBox>

            <!-- Out of Stock -->
            <VBox spacing="10" GridPane.columnIndex="5"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-padding: 16;">
                <StackPane alignment="CENTER_LEFT">
                    <Region prefWidth="36" prefHeight="36" maxWidth="36" maxHeight="36"
                            style="-fx-background-color: #F8FAFC; -fx-background-radius: 8;"/>
                    <SVGPath content="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z"
                             fill="#0F172A" scaleX="0.8" scaleY="0.8"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="lblOutOfStock" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                    <Label text="Out of Stock" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                </VBox>
            </VBox>
        </GridPane>

        <!-- CONTROL BAR (SEARCH + FILTERS + RESET) -->
        <HBox alignment="CENTER_LEFT" spacing="14" prefHeight="66"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-padding: 0 20;">
            
            <!-- Search Box -->
            <HBox alignment="CENTER_LEFT" spacing="10" prefWidth="320" prefHeight="40"
                  style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-padding: 0 12;">
                <Label text="🔍" style="-fx-font-size: 14px; -fx-text-fill: #64748B;"/>
                <TextField fx:id="txtSearch" promptText="Search an ingredient..."
                           prefHeight="38" HBox.hgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px; -fx-text-fill: #1E293B;"/>
            </HBox>

            <!-- Category Filter -->
            <ComboBox fx:id="cmbFilterCategory" promptText="All categories" prefWidth="180" prefHeight="40"
                      style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-font-size: 13px;"/>

            <!-- Sort Filter -->
            <ComboBox fx:id="cmbSortBy" promptText="Sort by..." prefWidth="180" prefHeight="40"
                      style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-font-size: 13px;"/>

            <!-- Search Button -->
            <Button text="Search" onAction="#applyFilters" prefHeight="40" prefWidth="110"
                    style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <!-- Reset Button -->
            <Button fx:id="btnReset" text="✕ Reset" onAction="#handleRefresh" prefHeight="40" prefWidth="100"
                    style="-fx-background-color: transparent; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-text-fill: #64748B; -fx-font-size: 13px; -fx-cursor: hand;"/>

            <Region HBox.hgrow="ALWAYS"/>
            
            <Label fx:id="lblTableInfo" text="0 result(s)"
                   style="-fx-font-size: 12px; -fx-text-fill: #64748B; -fx-padding: 6 12; -fx-background-color: #F1F5F9; -fx-background-radius: 6;"/>
        </HBox>

        <!-- DATA TABLE -->
        <VBox VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #E2E8F0; -fx-border-radius: 16; -fx-padding: 0;">
            <TableView fx:id="tableIngredients" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colSelect" prefWidth="40" maxWidth="40" minWidth="40" resizable="false" sortable="false"/>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="250" minWidth="200"/>
                    <TableColumn fx:id="colCategorie" text="Category" prefWidth="180" minWidth="150" style="-fx-alignment: CENTER-LEFT;"/>
                    <TableColumn fx:id="colQuantite" text="Quantity" prefWidth="120" minWidth="100" style="-fx-alignment: CENTER-LEFT;"/>
                    <TableColumn fx:id="colDatePeremption" text="Expiry Date" prefWidth="150" minWidth="120" style="-fx-alignment: CENTER-LEFT;"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="180" minWidth="150" style="-fx-alignment: CENTER-LEFT;"/>
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="180" minWidth="160" style="-fx-alignment: CENTER;" sortable="false"/>
                </columns>
                <placeholder>
                    <VBox alignment="CENTER" spacing="12" style="-fx-padding: 60;">
                        <Label text="No ingredients found"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                        <Button text="+ Add now" onAction="#handleAddNew"
                                style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand;"/>
                    </VBox>
                </placeholder>
            </TableView>
        </VBox>
    </VBox>

    <!-- MODAL FORM OVERLAY -->
    <StackPane fx:id="formOverlay" visible="false" managed="false"
               style="-fx-background-color: #0F172AA6;">
        <VBox spacing="0" maxWidth="600" maxHeight="620"
              style="-fx-background-color: white; -fx-background-radius: 16;">
            <effect><DropShadow color="#0000004D" radius="40" offsetY="10"/></effect>

            <!-- MODAL HEADER -->
            <HBox alignment="CENTER_LEFT" prefHeight="64"
                  style="-fx-background-color: #1F4D3A; -fx-background-radius: 16 16 0 0; -fx-padding: 0 24;">
                <Label fx:id="lblFormTitle" text="Add an ingredient"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="✕" onAction="#handleCloseForm"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 18px; -fx-cursor: hand;"/>
            </HBox>

            <!-- MODAL BODY -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: white; -fx-background: white; -fx-border-color: transparent;">
                <VBox spacing="20" style="-fx-padding: 30;">
                    
                    <VBox spacing="8">
                        <Label text="Name *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                        <TextField fx:id="txtNom" promptText="e.g. Tomato" prefHeight="42"
                                   style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12;"/>
                        <Label fx:id="lblNomError" visible="false" managed="false" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
                    </VBox>

                    <HBox spacing="16">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Category *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <ComboBox fx:id="cmbCategorie" promptText="Select..." prefHeight="42" maxWidth="Infinity"
                                      style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                            <Label fx:id="lblCategorieError" visible="false" managed="false" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
                        </VBox>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Expiry Date" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <DatePicker fx:id="datePeremption" prefHeight="42" maxWidth="Infinity"
                                        style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                            <Label fx:id="lblDateError" visible="false" managed="false" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="16">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Quantity *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <TextField fx:id="txtQuantite" promptText="e.g. 500" prefHeight="42"
                                       style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12;"/>
                            <Label fx:id="lblQuantiteError" visible="false" managed="false" style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
                        </VBox>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Unit" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                            <ComboBox fx:id="cmbUnite" promptText="Select..." prefHeight="42" maxWidth="Infinity"
                                      style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="8">
                        <Label text="Image URL" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                        <TextField fx:id="txtImage" promptText="https://..." prefHeight="42"
                                   style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12;"/>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="Notes" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                        <TextArea fx:id="txtNotes" promptText="Add some notes..." prefHeight="80" wrapText="true"
                                  style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- MODAL FOOTER -->
            <HBox spacing="12" alignment="CENTER_RIGHT" prefHeight="80"
                  style="-fx-padding: 0 30; -fx-border-color: #E2E8F0; -fx-border-width: 1 0 0 0;">
                <Button text="Cancel" onAction="#handleCloseForm" prefHeight="40" prefWidth="100"
                        style="-fx-background-color: transparent; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-text-fill: #64748B; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button fx:id="btnSaveIngredient" text="Save" onAction="#handleSaveIngredient" prefHeight="40" prefWidth="120"
                        style="-fx-background-color: #1F4D3A; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </StackPane>

</StackPane>
