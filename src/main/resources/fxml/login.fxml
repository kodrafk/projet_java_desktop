<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.projet.gui.LoginController"
           prefWidth="1100" prefHeight="720">

    <!-- Gradient background -->
    <Pane style="-fx-background-color: linear-gradient(to bottom right, #e8f5e9, #fffde7, #fce4ec);"/>

    <!-- Colored floating food circles (decorative) -->
    <!-- Apple - red circle -->
    <Circle radius="28" fill="#EF5350" opacity="0.75"
             StackPane.alignment="CENTER_LEFT" translateX="100" translateY="80"/>
    <Circle radius="8" fill="#66BB6A" opacity="0.9"
             StackPane.alignment="CENTER_LEFT" translateX="118" translateY="52"/>

    <!-- Avocado - green oval -->
    <Ellipse radiusX="22" radiusY="30" fill="#66BB6A" opacity="0.8"
             StackPane.alignment="TOP_RIGHT" translateX="-100" translateY="130"/>
    <Ellipse radiusX="10" radiusY="14" fill="#A5D6A7" opacity="0.9"
             StackPane.alignment="TOP_RIGHT" translateX="-100" translateY="130"/>

    <!-- Carrot - orange -->
    <Ellipse radiusX="14" radiusY="26" fill="#FF7043" opacity="0.8"
             StackPane.alignment="BOTTOM_RIGHT" translateX="-120" translateY="-140"/>
    <Circle radius="6" fill="#66BB6A" opacity="0.9"
             StackPane.alignment="BOTTOM_RIGHT" translateX="-120" translateY="-166"/>

    <!-- Lemon - yellow -->
    <Ellipse radiusX="26" radiusY="20" fill="#FFEE58" opacity="0.85"
             StackPane.alignment="BOTTOM_LEFT" translateX="80" translateY="-80"/>

    <!-- Blueberry cluster -->
    <Circle radius="14" fill="#7E57C2" opacity="0.7"
             StackPane.alignment="TOP_LEFT" translateX="220" translateY="160"/>
    <Circle radius="10" fill="#9575CD" opacity="0.6"
             StackPane.alignment="TOP_LEFT" translateX="244" translateY="148"/>
    <Circle radius="10" fill="#9575CD" opacity="0.6"
             StackPane.alignment="TOP_LEFT" translateX="208" translateY="148"/>

    <!-- Strawberry - red -->
    <Ellipse radiusX="16" radiusY="20" fill="#E53935" opacity="0.75"
             StackPane.alignment="BOTTOM_RIGHT" translateX="-260" translateY="-300"/>
    <Circle radius="5" fill="#66BB6A" opacity="0.9"
             StackPane.alignment="BOTTOM_RIGHT" translateX="-260" translateY="-320"/>

    <!-- Watermelon slice - pink/green -->
    <Arc centerX="0" centerY="0" radiusX="30" radiusY="30"
         startAngle="0" length="180" type="ROUND" fill="#EF9A9A" opacity="0.7"
         StackPane.alignment="TOP_LEFT" translateX="60" translateY="500"/>

    <!-- Top nav bar -->
    <VBox StackPane.alignment="TOP_CENTER" maxWidth="Infinity">
        <HBox prefHeight="64" alignment="CENTER_LEFT"
              style="-fx-background-color: rgba(255,255,255,0.88); -fx-border-color: transparent transparent #E8EDE8 transparent; -fx-border-width: 0 0 1 0; -fx-padding: 0 40;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <!-- Logo bowl shape -->
                <StackPane prefWidth="36" prefHeight="36">
                    <Ellipse radiusX="18" radiusY="12" fill="#2E7D32"/>
                    <Ellipse radiusX="14" radiusY="8" fill="#4CAF50" translateY="-2"/>
                    <Circle radius="4" fill="#FF7043" translateX="-5" translateY="-4"/>
                    <Circle radius="3" fill="#FFEE58" translateX="4" translateY="-5"/>
                    <Circle radius="3" fill="#EF5350" translateX="0" translateY="-6"/>
                </StackPane>
                <Label text="Nutri Coach Pro"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a2e1a; -fx-font-family: Georgia;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="28" alignment="CENTER">
                <Label text="Home"       style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-cursor: hand;"/>
                <Label text="About"      style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-cursor: hand;"/>
                <Label text="My Kitchen" style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-cursor: hand;"/>
                <Label text="Events"     style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-cursor: hand;"/>
                <Label text="Wellness"   style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-cursor: hand;"/>
                <Label text="Blog"       style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-cursor: hand;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="12" alignment="CENTER">
                <Label text="Sign In"
                       style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-cursor: hand; -fx-font-weight: bold;"/>
                <Button fx:id="btnSignUp" text="Sign Up" onAction="#handleGoRegister"
                        style="-fx-background-color: #F97316; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 22; -fx-cursor: hand; -fx-border-color: transparent;"/>
            </HBox>
        </HBox>

        <!-- Centered form -->
        <VBox alignment="CENTER" VBox.vgrow="ALWAYS" style="-fx-padding: 40 0 50 0;">

            <Label text="Welcome Back"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1a2e1a; -fx-font-family: Georgia;"/>
            <Label text="Sign in to continue your nutrition journey"
                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-padding: 5 0 24 0;"/>

            <!-- White card — fixed width, centered -->
            <VBox spacing="16" prefWidth="400" maxWidth="400"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 32 36; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 24, 0, 0, 6);">

                <!-- Email -->
                <VBox spacing="6">
                    <Label text="Email" style="-fx-font-size: 13px; -fx-text-fill: #1a2e1a; -fx-font-weight: bold;"/>
                    <TextField fx:id="fieldEmail" promptText="your.email@example.com"
                               style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 11 14; -fx-font-size: 13px; -fx-text-fill: #374151;"/>
                    <Label fx:id="errEmail" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 10px;"/>
                </VBox>

                <!-- Password -->
                <VBox spacing="6">
                    <Label text="Password" style="-fx-font-size: 13px; -fx-text-fill: #1a2e1a; -fx-font-weight: bold;"/>
                    <HBox spacing="0" alignment="CENTER_LEFT">
                        <PasswordField fx:id="fieldPassword" promptText="Enter your password"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10 0 0 10; -fx-background-radius: 10 0 0 10; -fx-padding: 11 14; -fx-font-size: 13px;"/>
                        <TextField fx:id="fieldPasswordVisible" promptText="Enter your password"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 10 0 0 10; -fx-background-radius: 10 0 0 10; -fx-padding: 11 14; -fx-font-size: 13px;"/>
                        <Button fx:id="btnTogglePassword" text="👁" onAction="#handleTogglePassword"
                                prefHeight="44" prefWidth="44"
                                style="-fx-background-color: #F0F7F0; -fx-border-color: #C8E6C9; -fx-border-radius: 0 10 10 0; -fx-background-radius: 0 10 10 0; -fx-font-size: 14px; -fx-cursor: hand; -fx-border-width: 1 1 1 0;"/>
                    </HBox>
                    <Label fx:id="errPassword" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 10px;"/>
                </VBox>

                <Label fx:id="errGeneral" text=""
                       style="-fx-text-fill: #DC2626; -fx-font-size: 11px; -fx-font-weight: bold;"/>

                <!-- Sign In button -->
                <Button text="Sign In" onAction="#handleLogin"
                        maxWidth="Infinity" prefHeight="48"
                        style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: transparent;"/>

                <!-- Register link -->
                <HBox alignment="CENTER" spacing="6">
                    <Label text="Don't have an account?"
                           style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
                    <Button text="Register" onAction="#handleGoRegister"
                            style="-fx-background-color: transparent; -fx-text-fill: #2E7D32; -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: transparent; -fx-padding: 0;"/>
                </HBox>
            </VBox>
        </VBox>
    </VBox>

</StackPane>
