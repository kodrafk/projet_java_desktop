<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.web.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.projet.gui.LoginController"
           prefWidth="1100" prefHeight="720">

    <Pane style="-fx-background-color:linear-gradient(to bottom right,#e8f5e9,#fffde7,#fce4ec);"/>

    <!-- Decorative shapes -->
    <Circle radius="30" fill="#EF5350" opacity="0.6" StackPane.alignment="CENTER_LEFT" translateX="80" translateY="60"/>
    <Ellipse radiusX="22" radiusY="32" fill="#66BB6A" opacity="0.7" StackPane.alignment="TOP_RIGHT" translateX="-90" translateY="120"/>
    <Ellipse radiusX="26" radiusY="20" fill="#FFEE58" opacity="0.8" StackPane.alignment="BOTTOM_LEFT" translateX="80" translateY="-80"/>
    <Circle radius="16" fill="#7E57C2" opacity="0.6" StackPane.alignment="TOP_LEFT" translateX="220" translateY="160"/>

    <VBox StackPane.alignment="TOP_CENTER" maxWidth="Infinity">
        <!-- Navbar -->
        <HBox prefHeight="60" alignment="CENTER_LEFT"
              style="-fx-background-color:rgba(255,255,255,0.9);-fx-border-color:transparent transparent #E8EDE8 transparent;-fx-border-width:0 0 1 0;-fx-padding:0 40;">
            <Label text="🥗 NutriLife"
                   style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="signUpButton" text="Sign Up" onAction="#handleGoRegister"
                    style="-fx-background-color:#F97316;-fx-text-fill:white;-fx-font-size:13px;
                           -fx-font-weight:bold;-fx-background-radius:20;-fx-padding:8 22;
                           -fx-cursor:hand;-fx-border-color:transparent;"/>
        </HBox>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                    style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;">
            <VBox alignment="TOP_CENTER" style="-fx-background-color:transparent;-fx-padding:36 0 50 0;">

                <Label text="Welcome Back"
                       style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#1a2e1a;"/>
                <Label text="Sign in to continue your nutrition journey"
                       style="-fx-font-size:13px;-fx-text-fill:#6B7280;-fx-padding:6 0 20 0;"/>

                <VBox spacing="14" prefWidth="440" maxWidth="440"
                      style="-fx-background-color:white;-fx-background-radius:20;-fx-padding:28 36;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.10),24,0,0,6);">

                    <!-- Error label -->
                    <Label fx:id="errorLabel" text="" wrapText="true" maxWidth="368"
                           style="-fx-text-fill:#DC2626;-fx-font-size:12px;-fx-font-weight:bold;
                                  -fx-background-color:#FEF2F2;-fx-background-radius:8;-fx-padding:8 12;"/>

                    <!-- ── Quick sign-in options ── -->
                    <VBox spacing="8">
                        <Label text="Quick sign-in"
                               style="-fx-font-size:11px;-fx-text-fill:#94A3B8;-fx-font-weight:bold;"/>
                        <HBox spacing="10">
                            <Button fx:id="googleButton" text="🌐  Continue with Google"
                                    onAction="#handleGoogleLogin"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="42"
                                    style="-fx-background-color:#FFF7ED;-fx-text-fill:#EA580C;
                                           -fx-font-size:12px;-fx-font-weight:bold;
                                           -fx-background-radius:10;-fx-cursor:hand;
                                           -fx-border-color:#FED7AA;-fx-border-radius:10;
                                           -fx-border-width:1;"/>
                            <Button fx:id="faceIdButton" text="🎭  Face ID Login"
                                    onAction="#handleFaceIdLogin"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="42"
                                    style="-fx-background-color:#EFF6FF;-fx-text-fill:#1D4ED8;
                                           -fx-font-size:12px;-fx-font-weight:bold;
                                           -fx-background-radius:10;-fx-cursor:hand;
                                           -fx-border-color:#BFDBFE;-fx-border-radius:10;
                                           -fx-border-width:1;"/>
                        </HBox>
                    </VBox>

                    <!-- Divider -->
                    <HBox alignment="CENTER" spacing="10">
                        <Separator HBox.hgrow="ALWAYS"/>
                        <Label text="or sign in with password"
                               style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                        <Separator HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <!-- Email -->
                    <VBox spacing="5">
                        <Label text="Email"
                               style="-fx-font-size:13px;-fx-text-fill:#1a2e1a;-fx-font-weight:bold;"/>
                        <TextField fx:id="emailField" promptText="your.email@example.com"
                                   style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                          -fx-border-radius:10;-fx-background-radius:10;
                                          -fx-padding:11 14;-fx-font-size:13px;"/>
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="5">
                        <Label text="Password"
                               style="-fx-font-size:13px;-fx-text-fill:#1a2e1a;-fx-font-weight:bold;"/>
                        <PasswordField fx:id="passwordField" promptText="Enter your password"
                                       style="-fx-background-color:#F0F7F0;-fx-border-color:#C8E6C9;
                                              -fx-border-radius:10;-fx-background-radius:10;
                                              -fx-padding:11 14;-fx-font-size:13px;"/>
                    </VBox>

                    <!-- Remember me hidden + Forgot -->
                    <HBox alignment="CENTER_LEFT">
                        <!-- <CheckBox fx:id="rememberMeCheckbox" text="Remember me"
                                  style="-fx-font-size:12px;-fx-text-fill:#374151;"/> -->
                        <Region HBox.hgrow="ALWAYS"/>
                        <Hyperlink text="Forgot password?" onAction="#handleForgotPassword"
                                   style="-fx-font-size:12px;-fx-text-fill:#2E7D32;-fx-border-color:transparent;"/>
                    </HBox>

                    <!-- reCAPTCHA -->
                    <VBox spacing="4">
                        <Label text="Security Verification"
                               style="-fx-font-size:13px;-fx-text-fill:#1a2e1a;-fx-font-weight:bold;"/>
                        <StackPane prefHeight="90"
                                   style="-fx-background-color:#F8FAFC;-fx-background-radius:10;
                                          -fx-border-color:#E2E8F0;-fx-border-radius:10;-fx-border-width:1;">
                            <javafx.scene.web.WebView fx:id="recaptchaView" prefHeight="90" maxWidth="Infinity"/>
                        </StackPane>
                        <Label fx:id="captchaLabel" text=""
                               style="-fx-font-size:10px;-fx-text-fill:#DC2626;"/>
                    </VBox>

                    <!-- Sign In button -->
                    <Button fx:id="loginButton" text="Sign In" onAction="#handleLogin"
                            maxWidth="Infinity" prefHeight="48"
                            style="-fx-background-color:#2E7D32;-fx-text-fill:white;-fx-font-size:15px;
                                   -fx-font-weight:bold;-fx-background-radius:12;-fx-cursor:hand;
                                   -fx-border-color:transparent;"/>

                    <!-- Register link -->
                    <HBox alignment="CENTER" spacing="4">
                        <Label text="No account?"
                               style="-fx-font-size:12px;-fx-text-fill:#6B7280;"/>
                        <Hyperlink text="Register" onAction="#handleGoRegister"
                                   style="-fx-font-size:12px;-fx-text-fill:#2E7D32;
                                          -fx-font-weight:bold;-fx-border-color:transparent;"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>
</StackPane>
