<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="640" prefHeight="720"
            style="-fx-background-color:#F0F4F8;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.projet.gui.ProfileController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="54" spacing="12"
              style="-fx-background-color:#0F2820;-fx-padding:0 20;">
            <Label text="My Profile" style="-fx-font-size:17px;-fx-font-weight:bold;-fx-text-fill:white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#handleClose" 
                    style="-fx-background-color:transparent;-fx-text-fill:white;-fx-font-size:20px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:5 15;-fx-background-radius:5;"
                    onMouseEntered="#handleCloseHover" onMouseExited="#handleCloseExit"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color:#F0F4F8;-fx-background:#F0F4F8;-fx-border-color:transparent;">
            <VBox spacing="12" style="-fx-padding:16 20 20 20;-fx-background-color:#F0F4F8;">

                <!-- Avatar + name card -->
                <VBox style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:18;-fx-border-color:#E2E8F0;-fx-border-radius:14;" spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <StackPane prefWidth="72" prefHeight="72"
                                   style="-fx-background-color:#2E7D5A;-fx-background-radius:36;">
                            <Label fx:id="lblAvatarInitials" text="?"
                                   style="-fx-font-size:24px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                            <ImageView fx:id="photoView" fitWidth="72" fitHeight="72" preserveRatio="true" visible="false"/>
                        </StackPane>
                        <VBox spacing="4">
                            <Label fx:id="lblFullName" text="—" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                            <Label fx:id="lblEmail"    text="—" style="-fx-font-size:12px;-fx-text-fill:#64748B;"/>
                            <HBox spacing="8">
                                <Label fx:id="lblRole"   text="User"   style="-fx-background-color:#DCFCE7;-fx-text-fill:#166534;-fx-background-radius:6;-fx-padding:2 10;-fx-font-size:11px;-fx-font-weight:bold;"/>
                                <Label fx:id="lblStatus" text="Active" style="-fx-background-color:#DCFCE7;-fx-text-fill:#166534;-fx-background-radius:6;-fx-padding:2 10;-fx-font-size:11px;-fx-font-weight:bold;"/>
                                <Label fx:id="lblRankBadge" text=""
                                       style="-fx-background-radius:6;-fx-padding:2 10;-fx-font-size:11px;-fx-font-weight:bold;"/>
                            </HBox>
                            <Label fx:id="lblMemberSince" text="—" style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- XP / RANK CARD -->
                <VBox fx:id="rankCard" spacing="10"
                      style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:16;
                             -fx-border-color:#E2E8F0;-fx-border-radius:14;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="lblRankEmoji" text="🌱" style="-fx-font-size:28px;"/>
                        <VBox spacing="2">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label fx:id="lblRankTitle" text="Beginner"
                                       style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                                <Label fx:id="lblRankRarity" text=""
                                       style="-fx-font-size:10px;-fx-font-weight:bold;-fx-background-radius:8;-fx-padding:2 8;"/>
                            </HBox>
                            <Label fx:id="lblRankMotivation" text=""
                                   style="-fx-font-size:11px;-fx-text-fill:#64748B;-fx-font-style:italic;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <VBox alignment="CENTER_RIGHT" spacing="2">
                            <Label fx:id="lblTotalXP" text="0 XP"
                                   style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#7C3AED;"/>
                            <Label text="Total XP" style="-fx-font-size:9px;-fx-text-fill:#94A3B8;-fx-font-weight:bold;"/>
                        </VBox>
                    </HBox>
                    <VBox spacing="4">
                        <HBox alignment="CENTER_LEFT">
                            <Label fx:id="lblXpProgress" text=""
                                   style="-fx-font-size:11px;-fx-text-fill:#64748B;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblNextRank" text=""
                                   style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                        </HBox>
                        <ProgressBar fx:id="xpBar" progress="0" maxWidth="Infinity" prefHeight="10"
                                     style="-fx-accent:#7C3AED;-fx-background-color:#F1F5F9;-fx-background-radius:5;"/>
                        <Label fx:id="lblXpToNext" text=""
                               style="-fx-font-size:10px;-fx-text-fill:#94A3B8;-fx-font-style:italic;"/>
                    </VBox>
                </VBox>

                <!-- Health objective card — shown when weight+height are set -->
                <VBox fx:id="healthCard" spacing="10"
                      style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:16;
                             -fx-border-color:#E2E8F0;-fx-border-radius:14;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🎯" style="-fx-font-size:18px;"/>
                        <Label text="🎯 Health Goal"
                               style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                    </HBox>
                    <Label fx:id="lblHealthGoal" text="—" wrapText="true"
                           style="-fx-font-size:12px;-fx-text-fill:#374151;"/>
                    <ProgressBar fx:id="healthProgress" progress="0" maxWidth="Infinity" prefHeight="8"
                                 style="-fx-accent:#2E7D32;-fx-background-color:#E8F5E9;-fx-background-radius:4;"/>
                    <Label fx:id="lblHealthTip" text="" wrapText="true"
                           style="-fx-font-size:11px;-fx-text-fill:#6B7280;-fx-font-style:italic;"/>
                </VBox>

                <!-- Stats row -->
                <HBox spacing="10">
                    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="3"
                          style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:12;-fx-border-color:#E2E8F0;-fx-border-radius:12;">
                        <Label text="AGE"    style="-fx-font-size:9px;-fx-text-fill:#94A3B8;-fx-font-weight:bold;"/>
                        <Label fx:id="lblAge" text="—" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="3"
                          style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:12;-fx-border-color:#E2E8F0;-fx-border-radius:12;">
                        <Label text="BMI"    style="-fx-font-size:9px;-fx-text-fill:#94A3B8;-fx-font-weight:bold;"/>
                        <Label fx:id="lblBmi" text="—" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E293B;" wrapText="true"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="3"
                          style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:12;-fx-border-color:#E2E8F0;-fx-border-radius:12;">
                        <Label text="WEIGHT" style="-fx-font-size:9px;-fx-text-fill:#94A3B8;-fx-font-weight:bold;"/>
                        <Label fx:id="lblWeight" text="—" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="3"
                          style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:12;-fx-border-color:#E2E8F0;-fx-border-radius:12;">
                        <Label text="HEIGHT" style="-fx-font-size:9px;-fx-text-fill:#94A3B8;-fx-font-weight:bold;"/>
                        <Label fx:id="lblHeight" text="—" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                    </VBox>
                </HBox>

                <!-- Detail rows -->
                <VBox style="-fx-background-color:white;-fx-background-radius:12;-fx-border-color:#E2E8F0;-fx-border-radius:12;" spacing="0">
                    <HBox prefHeight="42" alignment="CENTER_LEFT" style="-fx-border-color:transparent transparent #F1F5F9 transparent;-fx-border-width:0 0 1 0;-fx-padding:0 16;">
                        <Label text="Birthday"    prefWidth="140" style="-fx-font-size:12px;-fx-text-fill:#64748B;"/>
                        <Label fx:id="lblBirthday" text="—" style="-fx-font-size:12px;-fx-text-fill:#1E293B;-fx-font-weight:bold;"/>
                    </HBox>
                    <HBox prefHeight="42" alignment="CENTER_LEFT" style="-fx-border-color:transparent transparent #F1F5F9 transparent;-fx-border-width:0 0 1 0;-fx-padding:0 16;">
                        <Label text="Face ID"     prefWidth="140" style="-fx-font-size:12px;-fx-text-fill:#64748B;"/>
                        <Label fx:id="lblFaceId"  text="—" style="-fx-font-size:12px;-fx-text-fill:#1E293B;-fx-font-weight:bold;"/>
                    </HBox>
                    <HBox prefHeight="42" alignment="CENTER_LEFT" style="-fx-padding:0 16;">
                        <Label text="Welcome message" prefWidth="140" style="-fx-font-size:12px;-fx-text-fill:#64748B;"/>
                        <Label fx:id="lblWelcomeMessage" text="" wrapText="true" maxWidth="360"
                               style="-fx-font-size:12px;-fx-text-fill:#475569;-fx-font-style:italic;"/>
                    </HBox>
                </VBox>

                <!-- Gallery Access Toggle -->
                <VBox spacing="10"
                      style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:16;-fx-border-color:#E0E7FF;-fx-border-radius:12;-fx-border-width:1;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🔐" style="-fx-font-size:18px;"/>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Admin Gallery Access"
                                   style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                            <Label text="Allow admin to view your weight progress photos"
                                   style="-fx-font-size:11px;-fx-text-fill:#64748B;"/>
                        </VBox>
                        <CheckBox fx:id="chkGalleryAccess" onAction="#handleGalleryAccessToggle"
                                  style="-fx-cursor:hand;"/>
                    </HBox>
                    <Label fx:id="lblGalleryAccessStatus"
                           text="🔒 Your photos are private — only you can see them."
                           wrapText="true"
                           style="-fx-font-size:11px;-fx-text-fill:#64748B;-fx-background-color:#F8FAFC;-fx-background-radius:8;-fx-padding:8 12;"/>
                </VBox>

                <!-- Action buttons -->
                <VBox spacing="8">
                    <Button text="Edit Profile"           onAction="#handleEditProfile"    maxWidth="Infinity" prefHeight="40"
                            style="-fx-background-color:#2E7D5A;-fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;-fx-background-radius:10;-fx-cursor:hand;-fx-border-color:transparent;"/>
                    <Button text="Change Password"        onAction="#handleChangePassword" maxWidth="Infinity" prefHeight="40"
                            style="-fx-background-color:#F1F5F9;-fx-border-color:#CBD5E1;-fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;-fx-cursor:hand;"/>
                    <Button text="🎭 Manage Face ID"      onAction="#handleManageFaceId"   maxWidth="Infinity" prefHeight="40"
                            style="-fx-background-color:#EFF6FF;-fx-border-color:#BFDBFE;-fx-border-radius:10;-fx-background-radius:10;-fx-text-fill:#1D4ED8;-fx-font-size:13px;-fx-cursor:hand;"/>
                    <!-- HIDDEN: Edit Welcome Message -->
                    <!-- <Button text="✏ Edit Welcome Message" onAction="#handleWelcomeMessage" maxWidth="Infinity" prefHeight="40"
                            style="-fx-background-color:#F0FDF4;-fx-border-color:#BBF7D0;-fx-border-radius:10;-fx-background-radius:10;-fx-text-fill:#166534;-fx-font-size:13px;-fx-cursor:hand;"/> -->
                    <Button fx:id="btnMyBadges" text="🏆 My Badges"           onAction="#handleMyBadges"       maxWidth="Infinity" prefHeight="40"
                            style="-fx-background-color:#FEF3C7;-fx-border-color:#FDE68A;-fx-border-radius:10;-fx-background-radius:10;-fx-text-fill:#D97706;-fx-font-size:13px;-fx-cursor:hand;"/>
                    <Button fx:id="btnWeightGoal" text="⚖️ My Weight Goal"  onAction="#handleWeightObjective" maxWidth="Infinity" prefHeight="40"
                            style="-fx-background-color:#EFF6FF;-fx-border-color:#BFDBFE;-fx-border-radius:10;-fx-background-radius:10;-fx-text-fill:#1D4ED8;-fx-font-size:13px;-fx-cursor:hand;-fx-font-weight:bold;"/>
                    <Button text="Deactivate My Account"  onAction="#handleDeactivate"     maxWidth="Infinity" prefHeight="40"
                            style="-fx-background-color:transparent;-fx-border-color:#EF4444;-fx-border-radius:10;-fx-background-radius:10;-fx-text-fill:#EF4444;-fx-font-size:13px;-fx-cursor:hand;"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
