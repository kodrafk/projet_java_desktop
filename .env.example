# NutriLife - Configuration des clés API
# Copier ce fichier en .env et remplir les valeurs

# OpenRouter API (AI Recipes & Substitutions)
# Inscription: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# Unsplash API (images recettes)
# Inscription: https://unsplash.com/developers
UNSPLASH_API_KEY=...

# Gmail SMTP (reset password)
# Utiliser un App Password: https://myaccount.google.com/apppasswords
MAIL_SENDER_EMAIL=your-email@gmail.com
MAIL_SENDER_PASS=xxxx xxxx xxxx xxxx

# Base de données
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nutrilife_db
DB_USER=root
DB_PASS=
