<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="0" style="-fx-background-color: #f0f4f8;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.projet.gui.AdminEvenementController">

    <!-- ══ HEADER ══ -->
    <HBox alignment="CENTER_LEFT" spacing="16" prefHeight="72"
          style="-fx-background-color: white;
                 -fx-border-color: transparent transparent #e2e8f0 transparent;
                 -fx-border-width: 0 0 1 0;">
        <padding><Insets left="28" right="28"/></padding>

        <VBox spacing="3">
            <Label text="📅  Gestion des Événements" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Créez, modifiez et gérez les événements et leurs sponsors"
                   style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Recherche -->
        <HBox alignment="CENTER_LEFT" spacing="8" prefHeight="38" prefWidth="260"
              style="-fx-background-color: #f8fafc; -fx-background-radius: 10;
                     -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-padding: 0 12;">
            <Label text="🔍" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
            <TextField fx:id="tfRechercheAdmin"
                       promptText="Rechercher..."
                       onAction="#handleRechercheAdmin"
                       HBox.hgrow="ALWAYS"
                       style="-fx-background-color: transparent; -fx-border-color: transparent;
                              -fx-font-size: 12px; -fx-text-fill: #475569;"/>
        </HBox>

        <Button onAction="#allerPageAjout" prefHeight="42" prefWidth="200"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"
                text="+ Nouvel Événement"/>
    </HBox>

    <!-- ══ CARDS ══ -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: #f0f4f8; -fx-border-color: transparent;">
        <content>
            <FlowPane fx:id="flowPane" hgap="22" vgap="22"
                      style="-fx-background-color: #f0f4f8;">
                <padding><Insets top="26" right="28" bottom="26" left="28"/></padding>
            </FlowPane>
        </content>
    </ScrollPane>
</VBox>
