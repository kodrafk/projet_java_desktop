<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="32.0" prefHeight="750.0" prefWidth="1250.0"
      style="-fx-background-color: #F8FAFC;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.projet.gui.AccueilController">

    <padding><Insets top="80" bottom="60" left="400" right="400"/></padding>

    <!-- ══ LOGO ══ -->
    <VBox alignment="CENTER" spacing="14">
        <StackPane prefWidth="90" prefHeight="90"
                   style="-fx-background-color: linear-gradient(to bottom right, #4F46E5, #10b981);
                          -fx-background-radius: 22;">
            <Label text="N" style="-fx-font-size: 44px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </StackPane>

        <Label text="NUTRI COACH PRO" textFill="#1E293B">
            <font><Font name="System Bold" size="42.0"/></font>
        </Label>
        <Label text="Plateforme de gestion des Événements, Coachs &amp; Sponsors"
               textFill="#64748B">
            <font><Font size="15.0"/></font>
        </Label>
    </VBox>

    <!-- ══ SÉPARATEUR ══ -->
    <Separator maxWidth="300"/>

    <!-- ══ BOUTONS DE NAVIGATION ══ -->
    <VBox alignment="CENTER" spacing="14" maxWidth="420">

        <!-- Espace Utilisateur (FRONT) -->
        <Button onAction="#allerFrontLayout"
                prefHeight="58" maxWidth="Infinity"
                style="-fx-background-color: linear-gradient(to right, #10b981, #059669);
                       -fx-text-fill: white; -fx-background-radius: 14;
                       -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 15px;
                       -fx-effect: dropshadow(three-pass-box, rgba(16,185,129,0.4), 10, 0, 0, 4);"
                text="🌐  ESPACE UTILISATEUR — Voir les Événements"/>

        <!-- Espace Admin (BACK) -->
        <Button onAction="#allerAdminLayout"
                prefHeight="58" maxWidth="Infinity"
                style="-fx-background-color: linear-gradient(to right, #4F46E5, #7C3AED);
                       -fx-text-fill: white; -fx-background-radius: 14;
                       -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 15px;
                       -fx-effect: dropshadow(three-pass-box, rgba(79,70,229,0.4), 10, 0, 0, 4);"
                text="🔐  ESPACE ADMIN — Gérer les Événements"/>

    </VBox>

    <!-- ══ DESCRIPTION ══ -->
    <HBox alignment="CENTER" spacing="40">
        <VBox alignment="CENTER" spacing="6" prefWidth="180">
            <Label text="🎯" style="-fx-font-size: 28px;"/>
            <Label text="Événements" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 13px;"/>
            <Label text="Consultez et participez" style="-fx-text-fill: #64748b; -fx-font-size: 11px;" wrapText="true"/>
        </VBox>
        <VBox alignment="CENTER" spacing="6" prefWidth="180">
            <Label text="🤝" style="-fx-font-size: 28px;"/>
            <Label text="Sponsors" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 13px;"/>
            <Label text="Partenaires liés aux événements" style="-fx-text-fill: #64748b; -fx-font-size: 11px;" wrapText="true"/>
        </VBox>
        <VBox alignment="CENTER" spacing="6" prefWidth="180">
            <Label text="👤" style="-fx-font-size: 28px;"/>
            <Label text="Coachs" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 13px;"/>
            <Label text="Experts qui encadrent" style="-fx-text-fill: #64748b; -fx-font-size: 11px;" wrapText="true"/>
        </VBox>
    </HBox>

    <!-- ══ FOOTER ══ -->
    <Label text="Nutri Coach Pro © 2026  —  Tous droits réservés" textFill="#CBD5E1">
        <font><Font size="11.0"/></font>
    </Label>

</VBox>
